   983 000005CF 83C702                      add di, 2
   984 000005D2 B079                        mov al, 'y'
   985 000005D4 8905                        mov [di], ax
   986                                  
   987                                      ; Update cursor position in BDA to row 5 (below splash)
   988 000005D6 B84000                      mov ax, BDA_SEG
   989 000005D9 8ED8                        mov ds, ax
   990 000005DB C606500000                  mov byte [0x0050], 0   ; col
   991 000005E0 C606510005                  mov byte [0x0051], 5   ; row
   992                                  
   993                                      ; --- Boot status messages via INT 10h ---
   994 000005E5 FB                          sti                        ; enable interrupts for INT calls
   995 000005E6 BE[1606]                    mov si, msg_ivt
   996 000005E9 E81100                      call bios_print
   997 000005EC BE[1F06]                    mov si, msg_boot
   998 000005EF E80B00                      call bios_print
   999                                  
  1000                                      ; --- Jump to DOS kernel ---
  1001                                      ; KERNEL.SYS is pre-loaded at 0060:0000 by the transpiler.
  1002                                      ; Kernel expects BL = boot drive (0x00 = A:)
  1003 000005F2 31C0                        xor ax, ax
  1004 000005F4 8ED8                        mov ds, ax             ; DS = 0 (kernel expects this)
  1005 000005F6 B300                        mov bl, 0x00
  1006 000005F8 EA00006000                  jmp 0x0060:0x0000
  1007                                  
  1008                                  ; --- BIOS print: print null-terminated string at CS:SI via INT 10h ---
  1009                                  bios_print:
  1010 000005FD 50                          push ax
  1011 000005FE 53                          push bx
  1012                                  .bp_loop:
  1013                                      ; Read byte from CS:SI (BIOS ROM segment)
  1014                                      ; We need CS: prefix but can't use segment overrides easily.
  1015                                      ; Instead, set DS=CS temporarily.
  1016 000005FF 1E                          push ds
  1017 00000600 0E                          push cs
  1018 00000601 1F                          pop ds
  1019 00000602 8A04                        mov al, [si]
  1020 00000604 1F                          pop ds
  1021 00000605 84C0                        test al, al
  1022 00000607 740A                        jz .bp_done
  1023 00000609 B40E                        mov ah, 0x0E
  1024 0000060B BB0700                      mov bx, 0x0007         ; page 0, light gray
  1025 0000060E CD10                        int 0x10
  1026 00000610 46                          inc si
  1027 00000611 EBEC                        jmp short .bp_loop
  1028                                  .bp_done:
  1029 00000613 5B                          pop bx
  1030 00000614 58                          pop ax
  1031 00000615 C3                          ret
  1032                                  
  1033 00000616 495654204F4B0D0A00      msg_ivt:    db 'IVT OK', 13, 10, 0
  1034 0000061F 426F6F74696E672044-     msg_boot:   db 'Booting DOS...', 13, 10, 0
  1034 00000628 4F532E2E2E0D0A00   
  1035                                  
  1036                                  bios_end:
