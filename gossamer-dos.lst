  1222 000006D9 02                          db 0x02                ; bytes per sector (2 = 512)
  1223 000006DA 12                          db DISK_SPT            ; sectors per track (18)
  1224 000006DB 1B                          db 0x1B                ; gap length
  1225 000006DC FF                          db 0xFF                ; data length
  1226 000006DD 50                          db 0x50                ; format gap length
