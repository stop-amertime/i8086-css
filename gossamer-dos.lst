   424 00000222 88F0                        mov al, dh
   425 00000224 B350                        mov bl, 80
   426 00000226 F6E3                        mul bl
   427 00000228 30FF                        xor bh, bh
   428 0000022A 88D3                        mov bl, dl
   429 0000022C 01D8                        add ax, bx
   430 0000022E D1E0                        shl ax, 1
   431 00000230 89C7                        mov di, ax
   432 00000232 58                          pop ax
   433 00000233 BB00B8                      mov bx, VGA_SEG
   434 00000236 8EDB                        mov ds, bx
   435                                  .wco_loop:
