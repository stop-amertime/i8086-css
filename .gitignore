*.bin
*.lst
*.start
*.o
!bios/gossamer/gossamer.bin
!bios/gossamer/gossamer.lst

# Build outputs
bios/corduroy/build/
bios/corduroy/bios.map

# Node
node_modules/
dist/

# Python
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db

