   449                                  ; ============================================================
   450                                  ; scroll_up_one — scroll VGA text up by one line
   451                                  ; ============================================================
   452                                  scroll_up_one:
   453 00000248 1E                          push ds
   454 00000249 56                          push si
   455 0000024A 57                          push di
   456 0000024B 51                          push cx
   457 0000024C 50                          push ax
   458 0000024D B800B8                      mov ax, VGA_SEG
   459 00000250 8ED8                        mov ds, ax
   460 00000252 BEA000                      mov si, 160            ; source = row 1
   461 00000255 31FF                        xor di, di             ; dest = row 0
   462 00000257 B98007                      mov cx, 1920           ; 24 rows * 80 cols
   463                                  .scopy:
   464 0000025A 8B04                        mov ax, [si]
   465 0000025C 8905                        mov [di], ax
   466 0000025E 83C602                      add si, 2
   467 00000261 83C702                      add di, 2
   468 00000264 49                          dec cx
   469 00000265 75F3                        jnz .scopy
   470 00000267 B95000                      mov cx, 80
   471 0000026A B82007                      mov ax, 0x0720
   472                                  .sclear:
   473 0000026D 8905                        mov [di], ax
   474 0000026F 83C702                      add di, 2
   475 00000272 49                          dec cx
   476 00000273 75F8                        jnz .sclear
   477 00000275 58                          pop ax
   478 00000276 59                          pop cx
   479 00000277 5F                          pop di
   480 00000278 5E                          pop si
   481 00000279 1F                          pop ds
   482 0000027A C3                          ret
   483                                  
   484                                  ; ============================================================
   485                                  ; INT 11h — Equipment List (read from BDA, like reference BIOS)
   486                                  ; ============================================================
   487                                  int11h_handler:
   488 0000027B FB                          sti
   489 0000027C 1E                          push ds
   490 0000027D B84000                      mov ax, BDA_SEG
   491 00000280 8ED8                        mov ds, ax
   492 00000282 A11000                      mov ax, [equipment_list]
   493 00000285 1F                          pop ds
   494 00000286 CF                          iret
   495                                  
   496                                  ; ============================================================
   497                                  ; INT 12h — Memory Size (read from BDA, like reference BIOS)
   498                                  ; ============================================================
   499                                  int12h_handler:
   500 00000287 FB                          sti
   501 00000288 1E                          push ds
   502 00000289 B84000                      mov ax, BDA_SEG
   503 0000028C 8ED8                        mov ds, ax
   504 0000028E A11300                      mov ax, [memory_size]
   505 00000291 1F                          pop ds
   506 00000292 CF                          iret
   507                                  
   508                                  ; ============================================================
   509                                  ; INT 13h — Disk Services (memory-resident disk image)
   510                                  ; ============================================================
   511                                  int13h_handler:
   512 00000293 80FC00                      cmp ah, 0x00
   513 00000296 7413                        je .disk_reset
   514 00000298 80FC02                      cmp ah, 0x02
   515 0000029B 742E                        je .disk_read
   516 0000029D 80FC08                      cmp ah, 0x08
   517 000002A0 740D                        je .disk_params
   518 000002A2 80FC15                      cmp ah, 0x15
   519 000002A5 7420                        je .disk_type
   520                                      ; Unknown function — return error
   521 000002A7 B401                        mov ah, 0x01           ; invalid function
   522 000002A9 F9                          stc
   523 000002AA CF                          iret
   524                                  
   525                                  .disk_reset:
   526 000002AB 30E4                        xor ah, ah
   527 000002AD F8                          clc
   528 000002AE CF                          iret
   529                                  
   530                                  .disk_params:
   531                                      ; Return drive parameters for 1.44MB floppy
   532 000002AF B400                        mov ah, 0
   533 000002B1 B304                        mov bl, 0x04           ; drive type: 1.44MB
   534 000002B3 B54F                        mov ch, DISK_CYLS - 1  ; max cylinder (79)
   535 000002B5 B112                        mov cl, DISK_SPT       ; max sector (18)
   536 000002B7 B601                        mov dh, DISK_HEADS - 1 ; max head (1)
   537 000002B9 B201                        mov dl, 1              ; 1 floppy drive
   538                                      ; ES:DI = disk parameter table
   539 000002BB 53                          push bx
   540 000002BC BB00F0                      mov bx, BIOS_SEG
   541 000002BF 8EC3                        mov es, bx
   542 000002C1 BF[AA06]                    mov di, disk_param_table
   543 000002C4 5B                          pop bx
   544 000002C5 F8                          clc
   545 000002C6 CF                          iret
   546                                  
   547                                  .disk_type:
   548                                      ; AH=15h: Get disk type — floppy without change detection
   549 000002C7 B401                        mov ah, 0x01
   550 000002C9 F8                          clc
   551 000002CA CF                          iret
   552                                  
   553                                  .disk_read:
   554                                      ; AH=02h: Read sectors
   555                                      ; AL=count, CH=cylinder, CL=sector(1-based), DH=head, DL=drive, ES:BX=dest
   556 000002CB 55                          push bp
   557 000002CC 89E5                        mov bp, sp
   558 000002CE 1E                          push ds
   559 000002CF 56                          push si
   560 000002D0 57                          push di
   561 000002D1 50                          push ax
   562 000002D2 52                          push dx
   563 000002D3 51                          push cx
   564                                  
   565                                      ; Reload from stack since we need all values
   566 000002D4 59                          pop cx
   567 000002D5 5A                          pop dx
   568 000002D6 52                          push dx
   569 000002D7 51                          push cx
   570                                  
   571                                      ; Compute LBA = (CH * 2 + DH) * 18 + (CL - 1)
   572 000002D8 88E8                        mov al, ch
   573 000002DA 30E4                        xor ah, ah
   574 000002DC D1E0                        shl ax, 1              ; AX = cyl * 2
   575 000002DE 89C6                        mov si, ax
   576 000002E0 30E4                        xor ah, ah
   577 000002E2 88F0                        mov al, dh
   578 000002E4 01F0                        add ax, si             ; AX = cyl*2 + head
   579 000002E6 BE1200                      mov si, DISK_SPT
   580 000002E9 52                          push dx
   581 000002EA F7E6                        mul si                 ; AX = (cyl*2+head) * 18
   582 000002EC 5A                          pop dx
   583 000002ED 89C6                        mov si, ax
   584 000002EF 30ED                        xor ch, ch
   585 000002F1 FEC9                        dec cl                 ; sector is 1-based
   586 000002F3 01CE                        add si, cx             ; SI = LBA
   587                                  
   588                                      ; Source segment = DISK_SEG + LBA * 32
   589 000002F5 89F0                        mov ax, si
   590 000002F7 B105                        mov cl, 5
   591 000002F9 D3E0                        shl ax, cl
   592 000002FB 0500D0                      add ax, DISK_SEG
   593 000002FE 8ED8                        mov ds, ax
   594 00000300 31F6                        xor si, si
   595                                  
   596                                      ; Destination = ES:BX
   597 00000302 89DF                        mov di, bx
   598                                  
   599                                      ; Count
   600 00000304 59                          pop cx
   601 00000305 5A                          pop dx
   602 00000306 58                          pop ax
   603 00000307 30E4                        xor ah, ah
   604 00000309 89C1                        mov cx, ax
   605 0000030B 51                          push cx
   606                                  
   607                                      ; Copy CX sectors * 512 bytes
   608                                  .read_sector_loop:
   609 0000030C 51                          push cx
   610 0000030D B90001                      mov cx, 256
   611                                  .read_word_loop:
   612 00000310 8B04                        mov ax, [si]
   613 00000312 1E                          push ds
   614 00000313 53                          push bx
   615 00000314 8CC3                        mov bx, es
   616 00000316 8EDB                        mov ds, bx
   617 00000318 8905                        mov [di], ax
   618 0000031A 5B                          pop bx
   619 0000031B 1F                          pop ds
   620 0000031C 83C602                      add si, 2
   621 0000031F 83C702                      add di, 2
   622 00000322 49                          dec cx
   623 00000323 75EB                        jnz .read_word_loop
   624 00000325 59                          pop cx
   625 00000326 49                          dec cx
   626 00000327 75E3                        jnz .read_sector_loop
   627                                  
   628                                      ; Success
   629 00000329 58                          pop ax                 ; AL = sectors read
   630 0000032A 30E4                        xor ah, ah
   631 0000032C F8                          clc
   632 0000032D 5F                          pop di
   633 0000032E 5E                          pop si
   634 0000032F 1F                          pop ds
   635 00000330 5D                          pop bp
   636 00000331 CF                          iret
   637                                  
   638                                  ; ============================================================
   639                                  ; INT 16h — Keyboard Services (matches reference BIOS contracts)
   640                                  ; ============================================================
   641                                  int16h_handler:
   642 00000332 FB                          sti
   643 00000333 53                          push bx
   644 00000334 1E                          push ds
   645 00000335 BB4000                      mov bx, BDA_SEG
   646 00000338 8EDB                        mov ds, bx
   647 0000033A 80FC00                      cmp ah, 0x00
   648 0000033D 741C                        je .read_key
   649 0000033F 80FC01                      cmp ah, 0x01
   650 00000342 742F                        je .check_key
   651 00000344 80FC02                      cmp ah, 0x02
   652 00000347 744A                        je .shift_flags
   653 00000349 80FC10                      cmp ah, 0x10
   654 0000034C 740D                        je .read_key           ; enhanced = same for us
   655 0000034E 80FC11                      cmp ah, 0x11
   656 00000351 7420                        je .check_key          ; enhanced = same for us
   657 00000353 80FC12                      cmp ah, 0x12
   658 00000356 7441                        je .ext_shift_flags
   659                                      ; Unknown function
   660 00000358 1F                          pop ds
   661 00000359 5B                          pop bx
   662 0000035A CF                          iret
   663                                  
   664                                  .read_key:
   665                                      ; Busy-wait on keyboard buffer at 0000:0500
   666 0000035B 1F                          pop ds
   667 0000035C 5B                          pop bx
   668 0000035D 1E                          push ds
   669 0000035E 53                          push bx
   670 0000035F 31DB                        xor bx, bx
   671 00000361 8EDB                        mov ds, bx
   672                                  .key_wait:
   673 00000363 A10005                      mov ax, [0x0500]
   674 00000366 85C0                        test ax, ax
   675 00000368 74F9                        jz .key_wait
   676 0000036A C70600050000                mov word [0x0500], 0
   677 00000370 5B                          pop bx
   678 00000371 1F                          pop ds
   679 00000372 CF                          iret
   680                                  
   681                                  .check_key:
   682                                      ; Check if key is available (non-destructive)
   683 00000373 1F                          pop ds
   684 00000374 5B                          pop bx
   685 00000375 1E                          push ds
   686 00000376 53                          push bx
   687 00000377 31DB                        xor bx, bx
   688 00000379 8EDB                        mov ds, bx
   689 0000037B A10005                      mov ax, [0x0500]
   690 0000037E 5B                          pop bx
   691 0000037F 1F                          pop ds
   692 00000380 85C0                        test ax, ax
   693 00000382 55                          push bp
   694 00000383 89E5                        mov bp, sp
   695 00000385 7406                        jz .ck_none
   696                                      ; Key available: clear ZF
   697 00000387 836606BF                    and word [bp+6], 0xFFBF
   698 0000038B EB04                        jmp short .ck_ret
   699                                  .ck_none:
   700                                      ; No key: set ZF
   701 0000038D 834E0640                    or word [bp+6], 0x0040
   702                                  .ck_ret:
   703 00000391 5D                          pop bp
   704 00000392 CF                          iret
   705                                  
   706                                  .shift_flags:
   707                                      ; AH=02h: Return shift flags from BDA
   708 00000393 A01700                      mov al, [kbd_flags_1]
   709 00000396 1F                          pop ds
   710 00000397 5B                          pop bx
   711 00000398 CF                          iret
   712                                  
   713                                  .ext_shift_flags:
   714                                      ; AH=12h: Return extended shift flags
   715 00000399 A01700                      mov al, [kbd_flags_1]
   716 0000039C 8A261800                    mov ah, [kbd_flags_2]
   717 000003A0 1F                          pop ds
   718 000003A1 5B                          pop bx
   719 000003A2 CF                          iret
   720                                  
   721                                  ; ============================================================
   722                                  ; INT 1Ah — Timer Services (matches reference BIOS contract)
   723                                  ; ============================================================
   724                                  int1ah_handler:
   725 000003A3 FB                          sti
   726 000003A4 53                          push bx
   727 000003A5 1E                          push ds
   728 000003A6 BB4000                      mov bx, BDA_SEG
   729 000003A9 8EDB                        mov ds, bx
   730 000003AB 80FC00                      cmp ah, 0x00
   731 000003AE 7408                        je .timer_read
   732 000003B0 80FC01                      cmp ah, 0x01
   733 000003B3 741F                        je .timer_set
   734                                      ; Unknown function
   735 000003B5 1F                          pop ds
   736 000003B6 5B                          pop bx
   737 000003B7 CF                          iret
   738                                  
   739                                  .timer_read:
   740                                      ; AH=00h: Read tick count
   741                                      ; Returns: CX=high, DX=low, AL=midnight flag
   742                                      ; Reference: reads ticks, clears midnight flag via XOR
   743 000003B8 8B166C00                    mov dx, [ticks_lo]
   744 000003BC 8B0E6E00                    mov cx, [ticks_hi]
   745 000003C0 A07000                      mov al, [new_day]
   746 000003C3 30067000                    xor byte [new_day], al  ; clear midnight flag (reference method)
   747                                      ; Auto-increment workaround since we have no timer IRQ
   748 000003C7 83066C0001                  add word [ticks_lo], 1
   749 000003CC 83166E0000                  adc word [ticks_hi], 0
   750 000003D1 1F                          pop ds
   751 000003D2 5B                          pop bx
   752 000003D3 CF                          iret
   753                                  
   754                                  .timer_set:
   755                                      ; AH=01h: Set tick count
   756 000003D4 89166C00                    mov [ticks_lo], dx
   757 000003D8 890E6E00                    mov [ticks_hi], cx
   758 000003DC C606700000                  mov byte [new_day], 0
   759 000003E1 1F                          pop ds
   760 000003E2 5B                          pop bx
   761 000003E3 CF                          iret
   762                                  
   763                                  ; ============================================================
   764                                  ; INT 08h — Timer Tick (IRQ0)
   765                                  ; Increments BDA tick count, checks for midnight, calls INT 1Ch.
   766                                  ; We don't have a real PIT, so this won't fire automatically,
   767                                  ; but having the handler means any code that triggers INT 08h
   768                                  ; will work correctly.
   769                                  ; ============================================================
   770                                  int08h_handler:
   771 000003E4 50                          push ax
   772 000003E5 52                          push dx
   773 000003E6 1E                          push ds
   774 000003E7 B84000                      mov ax, BDA_SEG
   775 000003EA 8ED8                        mov ds, ax
   776                                      ; Increment tick counter
   777 000003EC FF066C00                    inc word [ticks_lo]
   778 000003F0 7504                        jnz .no_overflow
   779 000003F2 FF066E00                    inc word [ticks_hi]
   780                                  .no_overflow:
   781                                      ; Check for midnight rollover (1573042 = 0x18:0x00B2 ticks/day)
   782 000003F6 833E6E0018                  cmp word [ticks_hi], 0x18
   783 000003FB 7519                        jnz .no_midnight
   784 000003FD 813E6C00B200                cmp word [ticks_lo], 0x00B2
   785 00000403 7511                        jnz .no_midnight
   786 00000405 C7066E000000                mov word [ticks_hi], 0
   787 0000040B C7066C000000                mov word [ticks_lo], 0
   788 00000411 C606700001                  mov byte [new_day], 1
   789                                  .no_midnight:
   790 00000416 CD1C                        int 0x1C               ; User timer tick hook
   791 00000418 1F                          pop ds
   792 00000419 5A                          pop dx
   793 0000041A 58                          pop ax
   794 0000041B CF                          iret
   795                                  
   796                                  ; ============================================================
   797                                  ; INT 15h — Miscellaneous System Services (matches reference)
   798                                  ; ============================================================
   799                                  int15h_handler:
   800 0000041C FB                          sti
   801 0000041D 80FC4F                      cmp ah, 0x4F
   802 00000420 741F                        je .kbd_intercept
   803 00000422 80FCC0                      cmp ah, 0xC0
   804 00000425 7429                        je .sys_config
   805 00000427 80FC88                      cmp ah, 0x88
   806 0000042A 7419                        je .ext_mem_size
   807                                      ; AH=90h/91h: OS hooks — return success
   808 0000042C 80FC90                      cmp ah, 0x90
   809 0000042F 7411                        je .os_hook
   810 00000431 80FC91                      cmp ah, 0x91
   811 00000434 740C                        je .os_hook
   812                                      ; Unknown function — CF set, AH=86h (like reference)
   813 00000436 B486                        mov ah, 0x86
   814 00000438 55                          push bp
   815 00000439 89E5                        mov bp, sp
   816 0000043B 804E0601                    or byte [bp+6], 0x01   ; set CF in stacked FLAGS
   817 0000043F 5D                          pop bp
   818 00000440 CF                          iret
   819                                  
   820                                  .kbd_intercept:
   821                                      ; AH=4Fh: Keyboard intercept — just IRET (pass through)
   822 00000441 CF                          iret
   823                                  
   824                                  .os_hook:
   825                                      ; AH=90h/91h: Device busy/interrupt complete — AH=0, IRET
   826 00000442 B400                        mov ah, 0x00
   827 00000444 CF                          iret
   828                                  
   829                                  .ext_mem_size:
   830                                      ; AH=88h: Extended memory size (above 1MB) — none
   831 00000445 31C0                        xor ax, ax
   832 00000447 55                          push bp
   833 00000448 89E5                        mov bp, sp
   834 0000044A 806606FE                    and byte [bp+6], 0xFE  ; clear CF
   835 0000044E 5D                          pop bp
   836 0000044F CF                          iret
   837                                  
   838                                  .sys_config:
   839                                      ; AH=C0h: Get system configuration table
   840 00000450 B400                        mov ah, 0x00
   841 00000452 BB00F0                      mov bx, BIOS_SEG
   842 00000455 8EC3                        mov es, bx
   843 00000457 BB[A006]                    mov bx, config_table
   844 0000045A 55                          push bp
   845 0000045B 89E5                        mov bp, sp
   846 0000045D 806606FE                    and byte [bp+6], 0xFE  ; clear CF
   847 00000461 5D                          pop bp
   848 00000462 CF                          iret
   849                                  
   850                                  ; ============================================================
   851                                  ; INT 19h — Bootstrap (halt in our system)
   852                                  ; ============================================================
   853                                  int19h_handler:
   854 00000463 1E                          push ds
   855 00000464 31C0                        xor ax, ax
   856 00000466 8ED8                        mov ds, ax
   857 00000468 C606040501                  mov byte [HALT_ADDR], 1
   858 0000046D 1F                          pop ds
   859 0000046E EBF3                        jmp int19h_handler
   860                                  
   861                                  ; ============================================================
   862                                  ; INT 20h — Program Terminate (halt)
   863                                  ; ============================================================
   864                                  int20h_handler:
   865 00000470 1E                          push ds
   866 00000471 31C0                        xor ax, ax
   867 00000473 8ED8                        mov ds, ax
   868 00000475 C606040501                  mov byte [HALT_ADDR], 1
   869 0000047A 1F                          pop ds
   870 0000047B EBF3                        jmp int20h_handler
   871                                  
   872                                  ; ============================================================
   873                                  ; INT 01h — Single-step trap handler
   874                                  ; Clears TF from stacked FLAGS so execution resumes normally.
   875                                  ; ============================================================
   876                                  int01h_handler:
   877 0000047D 55                          push bp
   878 0000047E 89E5                        mov bp, sp
   879 00000480 816606FFFE                  and word [bp+6], 0xFEFF    ; clear TF (bit 8) in stacked FLAGS
   880 00000485 5D                          pop bp
   881 00000486 CF                          iret
   882                                  
   883                                  ; ============================================================
   884                                  ; int_dummy — Dummy interrupt handler (IRET only)
   885                                  ; Matches reference BIOS int_dummy at FF53h.
   886                                  ; ============================================================
   887                                  int_dummy:
   888 00000487 CF                          iret
   889                                  
   890                                  ; ============================================================
   891                                  ; default_handler — For unimplemented INTs
   892                                  ; Returns with CF set to signal "not supported".
   893                                  ; ============================================================
   894                                  default_handler:
   895 00000488 55                          push bp
   896 00000489 89E5                        mov bp, sp
   897 0000048B 834E0601                    or word [bp+6], 0x0001     ; set CF in stacked FLAGS
   898 0000048F 5D                          pop bp
   899 00000490 CF                          iret
   900                                  
   901                                  ; ============================================================
   902                                  ; Interrupt vector table — offsets only (segment always F000h)
   903                                  ; Matches reference 8088_bios interrupt_table layout exactly.
   904                                  ; 32 entries: INT 00h through INT 1Fh.
   905                                  ; ============================================================
   906                                  interrupt_table:
   907 00000491 [8704]                      dw int_dummy            ; INT 00 - Divide by zero
   908 00000493 [7D04]                      dw int01h_handler       ; INT 01 - Single step (clears TF)
   909 00000495 [8704]                      dw int_dummy            ; INT 02 - NMI (no-op for us)
   910 00000497 [8704]                      dw int_dummy            ; INT 03 - Breakpoint
   911 00000499 [8704]                      dw int_dummy            ; INT 04 - Overflow (INTO)
   912 0000049B [8704]                      dw int_dummy            ; INT 05 - Print Screen (stub)
   913 0000049D [8704]                      dw int_dummy            ; INT 06 - Invalid opcode
   914 0000049F [8704]                      dw int_dummy            ; INT 07 - Coprocessor N/A
   915 000004A1 [E403]                      dw int08h_handler       ; INT 08 - IRQ0 Timer
   916 000004A3 [8704]                      dw int_dummy            ; INT 09 - IRQ1 Keyboard (no hw kbd)
   917 000004A5 [8704]                      dw int_dummy            ; INT 0A - IRQ2
   918 000004A7 [8704]                      dw int_dummy            ; INT 0B - IRQ3
   919 000004A9 [8704]                      dw int_dummy            ; INT 0C - IRQ4
   920 000004AB [8704]                      dw int_dummy            ; INT 0D - IRQ5
   921 000004AD [8704]                      dw int_dummy            ; INT 0E - IRQ6 Floppy
   922 000004AF [8704]                      dw int_dummy            ; INT 0F - IRQ7
   923 000004B1 [0000]                      dw int10h_handler       ; INT 10 - Video Services
   924 000004B3 [7B02]                      dw int11h_handler       ; INT 11 - Equipment List
   925 000004B5 [8702]                      dw int12h_handler       ; INT 12 - Memory Size
   926 000004B7 [9302]                      dw int13h_handler       ; INT 13 - Disk Services
   927 000004B9 [8804]                      dw default_handler      ; INT 14 - Serial (stub)
   928 000004BB [1C04]                      dw int15h_handler       ; INT 15 - Misc System Services
   929 000004BD [3203]                      dw int16h_handler       ; INT 16 - Keyboard Services
   930 000004BF [8804]                      dw default_handler      ; INT 17 - Printer (stub)
   931 000004C1 [8704]                      dw int_dummy            ; INT 18 - ROM BASIC (stub)
   932 000004C3 [6304]                      dw int19h_handler       ; INT 19 - Bootstrap
   933 000004C5 [A303]                      dw int1ah_handler       ; INT 1A - Timer Services
   934 000004C7 [8704]                      dw int_dummy            ; INT 1B - Keyboard Break
   935 000004C9 [8704]                      dw int_dummy            ; INT 1C - User Timer Tick (IRET hook)
   936 000004CB [8704]                      dw int_dummy            ; INT 1D - Video Parameters (stub)
   937 000004CD [AA06]                      dw disk_param_table     ; INT 1E - Floppy Parameters (data ptr)
   938 000004CF [8704]                      dw int_dummy            ; INT 1F - Font (stub)
   939                                  
   940                                  ; ============================================================
   941                                  ; BIOS Init — POST entry point
   942                                  ; Sets up IVT from interrupt_table, initializes BDA, boots DOS.
   943                                  ; ============================================================
   944                                  bios_init:
   945 000004D1 FA                          cli
   946 000004D2 FC                          cld
   947                                  
   948                                      ; Set up stack at 0030:0100 (reference uses upper IVT area)
   949                                      ; This is 0x0400 linear, well below kernel at 0x600.
   950 000004D3 B83000                      mov ax, 0x0030
   951 000004D6 8ED0                        mov ss, ax
   952 000004D8 BC0001                      mov sp, 0x0100
   953                                  
   954                                      ; --- Initialize interrupt table ---
   955                                      ; Copy 32 vectors from interrupt_table (like reference BIOS).
   956                                      ; Reference uses movsw+stosw with DS=CS, ES=0. We can't use
   957                                      ; string ops easily, so we use a manual loop.
   958                                      ; First, set DS=0 for IVT writes.
   959 000004DB 31C0                        xor ax, ax
   960 000004DD 8ED8                        mov ds, ax
   961                                  
   962                                      ; Fill ALL 256 IVT entries with int_dummy:F000 first
   963                                      ; (like reference fills remaining with int_dummy after the table)
   964 000004DF 31FF                        xor di, di
   965 000004E1 B90001                      mov cx, 256
   966 000004E4 B800F0                      mov ax, BIOS_SEG
   967                                  .fill_all:
   968 000004E7 C705[8704]                  mov word [di], int_dummy
   969 000004EB 894502                      mov word [di+2], ax        ; segment = F000h
   970 000004EE 83C704                      add di, 4
   971 000004F1 49                          dec cx
   972 000004F2 75F3                        jnz .fill_all
   973                                  
   974                                      ; Now overwrite INT 00-1F from the interrupt_table
   975                                      ; We need to read from CS:interrupt_table. Set up BX as table pointer
   976                                      ; and use DS=CS temporarily to read, then DS=0 to write.
   977 000004F4 BE[9104]                    mov si, interrupt_table
   978 000004F7 31FF                        xor di, di             ; IVT offset 0
   979 000004F9 B92000                      mov cx, 32
   980                                  .ivt_copy:
   981                                      ; Read offset from CS:SI
   982 000004FC 1E                          push ds
   983 000004FD 0E                          push cs
   984 000004FE 1F                          pop ds
   985 000004FF 8B1C                        mov bx, [si]           ; BX = handler offset from table
   986 00000501 1F                          pop ds                 ; DS = 0 again
   987                                      ; Write to IVT
   988 00000502 891D                        mov [di], bx           ; offset
   989 00000504 C7450200F0                  mov word [di+2], BIOS_SEG  ; segment
   990 00000509 83C602                      add si, 2
   991 0000050C 83C704                      add di, 4
   992 0000050F 49                          dec cx
   993 00000510 75EA                        jnz .ivt_copy
   994                                  
   995                                      ; Overwrite INT 20h with int20h_handler
   996 00000512 C7068000[7004]              mov word [0x20*4], int20h_handler
   997 00000518 C706820000F0                mov word [0x20*4+2], BIOS_SEG
   998                                  
   999                                      ; INT 21h: default_handler (kernel installs its own)
  1000 0000051E C7068400[8804]              mov word [0x21*4], default_handler
  1001 00000524 C706860000F0                mov word [0x21*4+2], BIOS_SEG
  1002                                  
  1003                                      ; --- Initialize BDA ---
  1004                                      ; (Reference: kbd_buffer_init + individual field setup)
  1005 0000052A B84000                      mov ax, BDA_SEG
  1006 0000052D 8ED8                        mov ds, ax
  1007                                  
  1008                                      ; Equipment list: floppy present + 80x25 color = 0x0021
  1009 0000052F C70610002100                mov word [equipment_list], 0x0021
  1010                                  
  1011                                      ; Memory size: 640 KiB
  1012 00000535 C70613008002                mov word [memory_size], 640
  1013                                  
  1014                                      ; Keyboard buffer initialization (matches kbd_buffer_init)
  1015 0000053B C7061A001E00                mov word [kbd_buffer_head], kbd_buffer   ; 0x001E
  1016 00000541 C7061C001E00                mov word [kbd_buffer_tail], kbd_buffer   ; 0x001E (empty)
  1017 00000547 C70680001E00                mov word [kbd_buffer_start], kbd_buffer  ; 0x001E
  1018 0000054D B81E00                      mov ax, kbd_buffer
  1019 00000550 83C020                      add ax, 0x20                             ; buffer size = 32 bytes
  1020 00000553 A38200                      mov word [kbd_buffer_end], ax            ; 0x003E
  1021                                  
  1022                                      ; Clear keyboard flags
