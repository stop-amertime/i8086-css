     1                                  ; gossamer-dos.asm — Gossamer BIOS (DOS variant) for CSS-DOS
     2                                  ; Loaded at F000:0000 (linear 0xF0000)
     3                                  ;
     4                                  ; Mirrors the 8088_bios reference layout:
     5                                  ;   - IVT setup via interrupt_table array (32 standard vectors + fill rest)
     6                                  ;   - Full BDA initialization matching IBM PC BIOS
     7                                  ;   - INT handlers follow reference contracts
     8                                  ;
     9                                  ; Backend is memory-mapped (no port I/O):
    10                                  ;   - VGA text buffer at B800:0000
    11                                  ;   - Disk window at D000:0000 (512 bytes, CSS dispatches reads by LBA at 0x004F0)
    12                                  ;   - Keyboard input via polling 0000:0500
    13                                  ;
    14                                  ; DOS kernel (KERNEL.SYS) is pre-loaded at 0060:0000 (linear 0x600)
    15                                  ; by the transpiler. The BIOS init code sets up the IVT and jumps to it.
    16                                  ;
    17                                  ; CONSTRAINTS (CSS transpiler limitations):
    18                                  ; - No 0x0F-prefixed opcodes (near Jcc)
    19                                  ; - Must compile with NASM: [bits 16] [org 0]
    20                                  
    21                                  [bits 16]
    22                                  [org 0]
    23                                  
    24                                  ; ============================================================
    25                                  ; Constants
    26                                  ; ============================================================
    27                                  DISK_SEG    equ 0xD000          ; Disk window (linear 0xD0000, 512 bytes, dispatched by CSS)
    28                                  disk_lba    equ 0x4F0           ; LBA register, linear 0x4F0 via 0x0000:0x04F0 (BDA intra-app area)
    29                                  BDA_SEG     equ 0x0040          ; BIOS Data Area segment
    30                                  BIOS_SEG    equ 0xF000          ; BIOS code segment
    31                                  VGA_SEG     equ 0xB800          ; VGA text mode segment
    32                                  KERNEL_SEG  equ 0x0060          ; DOS kernel load segment
    33                                  SECTOR_SIZE equ 512
    34                                  HALT_ADDR   equ 0x0504          ; Halt flag address (seg 0)
    35                                  
    36                                  ; Disk geometry for a 1.44MB floppy
    37                                  DISK_SPT    equ 18              ; sectors per track
    38                                  DISK_HEADS  equ 2               ; heads
    39                                  DISK_CYLS   equ 80              ; cylinders
    40                                  
    41                                  ; BDA offsets (matching reference 8088_bios exactly)
    42                                  equip_serial        equ 0x00    ; word[4] - serial port addresses
    43                                  equip_parallel      equ 0x08   ; word[3] - parallel port addresses
    44                                  equipment_list      equ 0x10    ; word - equipment list
    45                                  memory_size         equ 0x13    ; word - memory size in KiB
    46                                  kbd_flags_1         equ 0x17    ; byte - keyboard shift flags 1
    47                                  kbd_flags_2         equ 0x18    ; byte - keyboard shift flags 2
    48                                  kbd_alt_keypad      equ 0x19    ; byte - Alt+Numpad work area
    49                                  kbd_buffer_head     equ 0x1A    ; word - keyboard buffer head offset
    50                                  kbd_buffer_tail     equ 0x1C    ; word - keyboard buffer tail offset
    51                                  kbd_buffer          equ 0x1E    ; byte[32] - keyboard buffer
    52                                  fdc_calib_state     equ 0x3E    ; byte - floppy recalibration status
    53                                  fdc_motor_state     equ 0x3F    ; byte - floppy motor status
    54                                  fdc_motor_tout      equ 0x40    ; byte - floppy motor off timeout
    55                                  fdc_last_error      equ 0x41    ; byte - last diskette op status
    56                                  video_mode          equ 0x49    ; byte - active video mode
    57                                  video_columns       equ 0x4A    ; word - text columns
    58                                  video_page_size     equ 0x4C    ; word - video page size in bytes
    59                                  video_page_offt     equ 0x4E    ; word - active video page offset
    60                                  video_cur_pos       equ 0x50    ; byte[16] - cursor pos per page
    61                                  video_cur_shape     equ 0x60    ; word - cursor shape
    62                                  video_page          equ 0x62    ; byte - active video page
    63                                  video_port          equ 0x63    ; word - CRT controller port
    64                                  ticks_lo            equ 0x6C    ; word - timer ticks low
    65                                  ticks_hi            equ 0x6E    ; word - timer ticks high
    66                                  new_day             equ 0x70    ; byte - midnight flag
    67                                  break_flag          equ 0x71    ; byte - Ctrl-Break flag
    68                                  warm_boot           equ 0x72    ; word - warm boot flag (1234h)
    69                                  kbd_buffer_start    equ 0x80    ; word - keyboard buffer start
    70                                  kbd_buffer_end      equ 0x82    ; word - keyboard buffer end
    71                                  video_rows          equ 0x84    ; byte - text rows minus 1
    72                                  video_char_height   equ 0x85    ; word - character height (points)
    73                                  
    74                                  ; ============================================================
    75                                  ; INT 10h — Video Services
    76                                  ; ============================================================
    77                                  int10h_handler:
    78 00000000 1E                          push ds
    79 00000001 06                          push es
    80 00000002 55                          push bp
    81 00000003 80FC0E                      cmp ah, 0x0E
    82 00000006 7403                        je .teletype
    83 00000008 E98800                      jmp .dispatch_other
    84                                  
    85                                  ; --- AH=0Eh: Teletype output ---
    86                                  .teletype:
    87 0000000B 57                          push di
    88 0000000C 53                          push bx
    89 0000000D 51                          push cx
    90 0000000E 52                          push dx
    91 0000000F 50                          push ax                ; save character in AL
    92                                  
    93                                      ; Read cursor from BDA
    94 00000010 BB4000                      mov bx, BDA_SEG
    95 00000013 8EDB                        mov ds, bx
    96 00000015 8A165000                    mov dl, [video_cur_pos]     ; column
    97 00000019 8A365100                    mov dh, [video_cur_pos+1]   ; row
    98                                  
    99 0000001D 58                          pop ax                 ; AX restored (AL = character)
   100 0000001E 50                          push ax                ; save again
   101                                  
   102 0000001F 3C0D                        cmp al, 13
   103 00000021 7444                        je .tty_cr
   104 00000023 3C0A                        cmp al, 10
   105 00000025 7444                        je .tty_lf
   106 00000027 3C08                        cmp al, 8
   107 00000029 744E                        je .tty_bs
   108 0000002B 3C07                        cmp al, 7
   109 0000002D 745B                        je .tty_done
   110                                  
   111                                      ; Compute VGA offset = (row*80+col)*2
   112 0000002F 50                          push ax                ; save char
   113 00000030 52                          push dx                ; save cursor
   114 00000031 88F0                        mov al, dh
   115 00000033 B350                        mov bl, 80
   116 00000035 F6E3                        mul bl                 ; AX = row*80
   117 00000037 30FF                        xor bh, bh
   118 00000039 88D3                        mov bl, dl
   119 0000003B 01D8                        add ax, bx             ; AX = row*80+col
   120 0000003D D1E0                        shl ax, 1              ; AX = (row*80+col)*2
   121 0000003F 89C7                        mov di, ax
   122 00000041 5A                          pop dx                 ; restore cursor
   123 00000042 58                          pop ax                 ; restore char
   124                                  
   125                                      ; Write to VGA
   126 00000043 1E                          push ds
   127 00000044 BB00B8                      mov bx, VGA_SEG
   128 00000047 8EDB                        mov ds, bx
   129 00000049 8805                        mov [di], al           ; character
   130 0000004B C6450107                    mov byte [di+1], 0x07  ; attribute
   131 0000004F 1F                          pop ds
   132                                  
   133                                      ; Advance cursor
   134 00000050 FEC2                        inc dl
   135 00000052 80FA50                      cmp dl, 80
   136 00000055 722B                        jb .tty_save
   137 00000057 30D2                        xor dl, dl
   138 00000059 FEC6                        inc dh
   139 0000005B 80FE19                      cmp dh, 25
   140 0000005E 7222                        jb .tty_save
   141 00000060 FECE                        dec dh
   142 00000062 E80F02                      call scroll_up_one
   143 00000065 EB1B                        jmp short .tty_save
   144                                  
   145                                  .tty_cr:
   146 00000067 30D2                        xor dl, dl
   147 00000069 EB17                        jmp short .tty_save
   148                                  
   149                                  .tty_lf:
   150 0000006B FEC6                        inc dh
   151 0000006D 80FE19                      cmp dh, 25
   152 00000070 7210                        jb .tty_save
   153 00000072 FECE                        dec dh
   154 00000074 E8FD01                      call scroll_up_one
   155 00000077 EB09                        jmp short .tty_save
   156                                  
   157                                  .tty_bs:
   158 00000079 80FA00                      cmp dl, 0
   159 0000007C 7404                        je .tty_save
   160 0000007E FECA                        dec dl
   161 00000080 EB00                        jmp short .tty_save
   162                                  
   163                                  .tty_save:
   164 00000082 88165000                    mov [video_cur_pos], dl
   165 00000086 88365100                    mov [video_cur_pos+1], dh
   166                                  
   167                                  .tty_done:
   168 0000008A 58                          pop ax
   169 0000008B 5A                          pop dx
   170 0000008C 59                          pop cx
   171 0000008D 5B                          pop bx
   172 0000008E 5F                          pop di
   173 0000008F 5D                          pop bp
   174 00000090 07                          pop es
   175 00000091 1F                          pop ds
   176 00000092 CF                          iret
   177                                  
   178                                  ; --- INT 10h dispatch for non-teletype ---
   179                                  .dispatch_other:
   180 00000093 80FC02                      cmp ah, 0x02
   181 00000096 7442                        je .set_cursor
   182 00000098 80FC03                      cmp ah, 0x03
   183 0000009B 744E                        je .get_cursor
   184 0000009D 80FC00                      cmp ah, 0x00
   185 000000A0 7472                        je .set_mode
   186 000000A2 80FC0F                      cmp ah, 0x0F
   187 000000A5 7459                        je .get_mode
   188 000000A7 80FC06                      cmp ah, 0x06
   189 000000AA 7503                        jne .not_scroll_up
   190 000000AC E9B600                      jmp .scroll_up
   191                                  .not_scroll_up:
   192 000000AF 80FC07                      cmp ah, 0x07
   193 000000B2 7503                        jne .not_scroll_down
   194 000000B4 E9E000                      jmp .scroll_down
   195                                  .not_scroll_down:
   196 000000B7 80FC08                      cmp ah, 0x08
   197 000000BA 7503                        jne .not_read_char
   198 000000BC E9F900                      jmp .read_char
   199                                  .not_read_char:
   200 000000BF 80FC09                      cmp ah, 0x09
   201 000000C2 7503                        jne .not_write_char
   202 000000C4 E92301                      jmp .write_char_attr
   203                                  .not_write_char:
   204 000000C7 80FC0A                      cmp ah, 0x0A
   205 000000CA 7503                        jne .not_write_char_only
   206 000000CC E95801                      jmp .write_char_only
   207                                  .not_write_char_only:
   208 000000CF 80FC1A                      cmp ah, 0x1A
   209 000000D2 0F848901                    je .get_display_combo
   210 000000D6 5D                          pop bp
   211 000000D7 07                          pop es
   212 000000D8 1F                          pop ds
   213 000000D9 CF                          iret
   214                                  
   215                                  .set_cursor:
   216 000000DA BB4000                      mov bx, BDA_SEG
   217 000000DD 8EDB                        mov ds, bx
   218 000000DF 88165000                    mov [video_cur_pos], dl
   219 000000E3 88365100                    mov [video_cur_pos+1], dh
   220 000000E7 5D                          pop bp
   221 000000E8 07                          pop es
   222 000000E9 1F                          pop ds
   223 000000EA CF                          iret
   224                                  
   225                                  .get_cursor:
   226 000000EB BB4000                      mov bx, BDA_SEG
   227 000000EE 8EDB                        mov ds, bx
   228 000000F0 8A165000                    mov dl, [video_cur_pos]
   229 000000F4 8A365100                    mov dh, [video_cur_pos+1]
   230 000000F8 8B0E6000                    mov cx, [video_cur_shape]
   231 000000FC 5D                          pop bp
   232 000000FD 07                          pop es
   233 000000FE 1F                          pop ds
   234 000000FF CF                          iret
   235                                  
   236                                  .get_mode:
   237 00000100 BB4000                      mov bx, BDA_SEG
   238 00000103 8EDB                        mov ds, bx
   239 00000105 A04900                      mov al, [video_mode]
   240 00000108 8A264A00                    mov ah, [video_columns]
   241 0000010C 8A3E6200                    mov bh, [video_page]
   242 00000110 5D                          pop bp
   243 00000111 07                          pop es
   244 00000112 1F                          pop ds
   245 00000113 CF                          iret
   246                                  
   247                                  .set_mode:
   248                                      ; Store requested mode in BDA and reset cursor
   249 00000114 57                          push di
   250 00000115 51                          push cx
   251 00000116 B94000                      mov cx, BDA_SEG
   252 00000119 8ED9                        mov ds, cx
   253 0000011B C606500000                  mov byte [video_cur_pos], 0
   254 00000120 C606510000                  mov byte [video_cur_pos+1], 0
   255                                      ; Only store modes we actually support; map anything else to 0x03.
   256 00000125 3C13                        cmp al, 0x13
   257 00000127 7402                        je .set_mode_store
   258 00000129 B003                        mov al, 0x03
   259                                  .set_mode_store:
   260 0000012B A24900                      mov [video_mode], al
   261 0000012E 3C13                        cmp al, 0x13
   262 00000130 7417                        je .set_mode_13h
   263                                      ; --- Text mode: clear 80x25 text buffer at 0xB8000 ---
   264 00000132 B800B8                      mov ax, VGA_SEG
   265 00000135 8ED8                        mov ds, ax
   266 00000137 31FF                        xor di, di
   267 00000139 B9D007                      mov cx, 2000
   268 0000013C B82007                      mov ax, 0x0720
   269                                  .clr_loop:
   270 0000013F 8905                        mov [di], ax
   271 00000141 83C702                      add di, 2
   272 00000144 49                          dec cx
   273 00000145 75F8                        jnz .clr_loop
   274 00000147 EB14                        jmp short .set_mode_done
   275                                  .set_mode_13h:
   276                                      ; --- Mode 13h: clear 320x200 framebuffer at 0xA0000 ---
   277 00000149 B800A0                      mov ax, 0xA000
   278 0000014C 8ED8                        mov ds, ax
   279 0000014E 31FF                        xor di, di
   280 00000150 B9007D                      mov cx, 32000
   281 00000153 31C0                        xor ax, ax
   282                                  .clr13_loop:
   283 00000155 8905                        mov [di], ax
   284 00000157 83C702                      add di, 2
   285 0000015A 49                          dec cx
   286 0000015B 75F8                        jnz .clr13_loop
   287                                  .set_mode_done:
   288 0000015D 59                          pop cx
   289 0000015E 5F                          pop di
   290 0000015F B030                        mov al, 0x30
   291 00000161 5D                          pop bp
   292 00000162 07                          pop es
   293 00000163 1F                          pop ds
   294 00000164 CF                          iret
   295                                  
   296                                  .scroll_up:
   297 00000165 3C00                        cmp al, 0
   298 00000167 751D                        jne .su_lines
   299                                      ; AL=0: Clear window
   300 00000169 57                          push di
   301 0000016A 51                          push cx
   302 0000016B B900B8                      mov cx, VGA_SEG
   303 0000016E 8ED9                        mov ds, cx
   304 00000170 31FF                        xor di, di
   305 00000172 B9D007                      mov cx, 2000
   306 00000175 B82007                      mov ax, 0x0720
   307                                  .su_clr:
   308 00000178 8905                        mov [di], ax
   309 0000017A 83C702                      add di, 2
   310 0000017D 49                          dec cx
   311 0000017E 75F8                        jnz .su_clr
   312 00000180 59                          pop cx
   313 00000181 5F                          pop di
   314 00000182 5D                          pop bp
   315 00000183 07                          pop es
   316 00000184 1F                          pop ds
   317 00000185 CF                          iret
   318                                  .su_lines:
   319 00000186 51                          push cx
   320 00000187 88C1                        mov cl, al
   321 00000189 30ED                        xor ch, ch
   322                                  .su_loop:
   323 0000018B E8E600                      call scroll_up_one
   324 0000018E FEC9                        dec cl
   325 00000190 75F9                        jnz .su_loop
   326 00000192 59                          pop cx
   327 00000193 5D                          pop bp
   328 00000194 07                          pop es
   329 00000195 1F                          pop ds
   330 00000196 CF                          iret
   331                                  
   332                                  .scroll_down:
   333 00000197 3C00                        cmp al, 0
   334 00000199 7519                        jne .sd_ret
   335 0000019B 57                          push di
   336 0000019C 51                          push cx
   337 0000019D B900B8                      mov cx, VGA_SEG
   338 000001A0 8ED9                        mov ds, cx
   339 000001A2 31FF                        xor di, di
   340 000001A4 B9D007                      mov cx, 2000
   341 000001A7 B82007                      mov ax, 0x0720
   342                                  .sd_clr:
   343 000001AA 8905                        mov [di], ax
   344 000001AC 83C702                      add di, 2
   345 000001AF 49                          dec cx
   346 000001B0 75F8                        jnz .sd_clr
   347 000001B2 59                          pop cx
   348 000001B3 5F                          pop di
   349                                  .sd_ret:
   350 000001B4 5D                          pop bp
   351 000001B5 07                          pop es
   352 000001B6 1F                          pop ds
   353 000001B7 CF                          iret
   354                                  
   355                                  .read_char:
   356                                      ; AH=08h: Read char+attr at cursor
   357 000001B8 53                          push bx
   358 000001B9 57                          push di
   359 000001BA BB4000                      mov bx, BDA_SEG
   360 000001BD 8EDB                        mov ds, bx
   361 000001BF A05000                      mov al, [video_cur_pos]     ; col
   362 000001C2 8A265100                    mov ah, [video_cur_pos+1]   ; row
   363 000001C6 52                          push dx
   364 000001C7 30F6                        xor dh, dh
   365 000001C9 88E2                        mov dl, ah
   366 000001CB B450                        mov ah, 80
   367 000001CD 86C2                        xchg al, dl
   368 000001CF F6E4                        mul ah
   369 000001D1 30F6                        xor dh, dh
   370 000001D3 01D0                        add ax, dx
   371 000001D5 D1E0                        shl ax, 1
   372 000001D7 89C7                        mov di, ax
   373 000001D9 5A                          pop dx
   374 000001DA BB00B8                      mov bx, VGA_SEG
   375 000001DD 8EDB                        mov ds, bx
   376 000001DF 8A05                        mov al, [di]           ; character
   377 000001E1 8A6501                      mov ah, [di+1]         ; attribute
   378 000001E4 5F                          pop di
   379 000001E5 5B                          pop bx
   380 000001E6 5D                          pop bp
   381 000001E7 07                          pop es
   382 000001E8 1F                          pop ds
   383 000001E9 CF                          iret
   384                                  
   385                                  .write_char_attr:
   386                                      ; AH=09h: Write char+attr at cursor, CX times
   387                                      ; AL=char, BL=attr, CX=count
   388 000001EA 57                          push di
   389 000001EB 52                          push dx
   390 000001EC 51                          push cx
   391 000001ED 53                          push bx
   392 000001EE BB4000                      mov bx, BDA_SEG
   393 000001F1 8EDB                        mov ds, bx
   394 000001F3 8A165000                    mov dl, [video_cur_pos]
   395 000001F7 8A365100                    mov dh, [video_cur_pos+1]
   396 000001FB 50                          push ax
   397 000001FC 88F0                        mov al, dh
   398 000001FE B350                        mov bl, 80
   399 00000200 F6E3                        mul bl
   400 00000202 30FF                        xor bh, bh
   401 00000204 88D3                        mov bl, dl
   402 00000206 01D8                        add ax, bx
   403 00000208 D1E0                        shl ax, 1
   404 0000020A 89C7                        mov di, ax
   405 0000020C 58                          pop ax
   406 0000020D BB00B8                      mov bx, VGA_SEG
   407 00000210 8EDB                        mov ds, bx
   408 00000212 5B                          pop bx                 ; restore original BX (BL=attr)
   409 00000213 53                          push bx
   410                                  .wca_loop:
   411 00000214 8805                        mov [di], al
   412 00000216 885D01                      mov [di+1], bl
   413 00000219 83C702                      add di, 2
   414 0000021C 49                          dec cx
   415 0000021D 75F5                        jnz .wca_loop
   416 0000021F 5B                          pop bx
   417 00000220 59                          pop cx
   418 00000221 5A                          pop dx
   419 00000222 5F                          pop di
   420 00000223 5D                          pop bp
   421 00000224 07                          pop es
   422 00000225 1F                          pop ds
   423 00000226 CF                          iret
   424                                  
   425                                  .write_char_only:
   426                                      ; AH=0Ah: Write char at cursor, CX times (keep existing attr)
   427                                      ; AL=char, CX=count
   428 00000227 57                          push di
   429 00000228 52                          push dx
   430 00000229 51                          push cx
   431 0000022A 53                          push bx
   432 0000022B BB4000                      mov bx, BDA_SEG
   433 0000022E 8EDB                        mov ds, bx
   434 00000230 8A165000                    mov dl, [video_cur_pos]
   435 00000234 8A365100                    mov dh, [video_cur_pos+1]
   436 00000238 50                          push ax
   437 00000239 88F0                        mov al, dh
   438 0000023B B350                        mov bl, 80
   439 0000023D F6E3                        mul bl
   440 0000023F 30FF                        xor bh, bh
   441 00000241 88D3                        mov bl, dl
   442 00000243 01D8                        add ax, bx
   443 00000245 D1E0                        shl ax, 1
   444 00000247 89C7                        mov di, ax
   445 00000249 58                          pop ax
   446 0000024A BB00B8                      mov bx, VGA_SEG
   447 0000024D 8EDB                        mov ds, bx
   448                                  .wco_loop:
   449 0000024F 8805                        mov [di], al           ; write char only, keep attribute
   450 00000251 83C702                      add di, 2
   451 00000254 49                          dec cx
   452 00000255 75F8                        jnz .wco_loop
   453 00000257 5B                          pop bx
   454 00000258 59                          pop cx
   455 00000259 5A                          pop dx
   456 0000025A 5F                          pop di
   457 0000025B 5D                          pop bp
   458 0000025C 07                          pop es
   459 0000025D 1F                          pop ds
   460 0000025E CF                          iret
   461                                  
   462                                  .get_display_combo:
   463                                      ; AH=1Ah: Get/Set Display Combination Code
   464                                      ; Return VGA color (0x08) — programs use this to detect VGA.
   465 0000025F 80FB00                      cmp bl, 0
   466 00000262 750A                        jne .dcc_set
   467                                      ; BL=00h: Get DCC
   468 00000264 B308                        mov bl, 0x08            ; active display: VGA color
   469 00000266 B700                        mov bh, 0x00            ; inactive: none
   470 00000268 5D                          pop bp
   471 00000269 07                          pop es
   472 0000026A 1F                          pop ds
   473 0000026B B01A                        mov al, 0x1A            ; confirm function supported
   474 0000026D CF                          iret
   475                                  .dcc_set:
   476                                      ; BL!=0: Set DCC — ignore but confirm
   477 0000026E 5D                          pop bp
   478 0000026F 07                          pop es
   479 00000270 1F                          pop ds
   480 00000271 B01A                        mov al, 0x1A
   481 00000273 CF                          iret
   482                                  
   483                                  ; ============================================================
   484                                  ; scroll_up_one — scroll VGA text up by one line
   485                                  ; ============================================================
   486                                  scroll_up_one:
   487 00000274 1E                          push ds
   488 00000275 56                          push si
   489 00000276 57                          push di
   490 00000277 51                          push cx
   491 00000278 50                          push ax
   492 00000279 B800B8                      mov ax, VGA_SEG
   493 0000027C 8ED8                        mov ds, ax
   494 0000027E BEA000                      mov si, 160            ; source = row 1
   495 00000281 31FF                        xor di, di             ; dest = row 0
   496 00000283 B98007                      mov cx, 1920           ; 24 rows * 80 cols
   497                                  .scopy:
   498 00000286 8B04                        mov ax, [si]
   499 00000288 8905                        mov [di], ax
   500 0000028A 83C602                      add si, 2
   501 0000028D 83C702                      add di, 2
   502 00000290 49                          dec cx
   503 00000291 75F3                        jnz .scopy
   504 00000293 B95000                      mov cx, 80
   505 00000296 B82007                      mov ax, 0x0720
   506                                  .sclear:
   507 00000299 8905                        mov [di], ax
   508 0000029B 83C702                      add di, 2
   509 0000029E 49                          dec cx
   510 0000029F 75F8                        jnz .sclear
   511 000002A1 58                          pop ax
   512 000002A2 59                          pop cx
   513 000002A3 5F                          pop di
   514 000002A4 5E                          pop si
   515 000002A5 1F                          pop ds
   516 000002A6 C3                          ret
   517                                  
   518                                  ; ============================================================
   519                                  ; INT 11h — Equipment List (read from BDA, like reference BIOS)
   520                                  ; ============================================================
   521                                  int11h_handler:
   522 000002A7 FB                          sti
   523 000002A8 1E                          push ds
   524 000002A9 B84000                      mov ax, BDA_SEG
   525 000002AC 8ED8                        mov ds, ax
   526 000002AE A11000                      mov ax, [equipment_list]
   527 000002B1 1F                          pop ds
   528 000002B2 CF                          iret
   529                                  
   530                                  ; ============================================================
   531                                  ; INT 12h — Memory Size (read from BDA, like reference BIOS)
   532                                  ; ============================================================
   533                                  int12h_handler:
   534 000002B3 FB                          sti
   535 000002B4 1E                          push ds
   536 000002B5 B84000                      mov ax, BDA_SEG
   537 000002B8 8ED8                        mov ds, ax
   538 000002BA A11300                      mov ax, [memory_size]
   539 000002BD 1F                          pop ds
   540 000002BE CF                          iret
   541                                  
   542                                  ; ============================================================
   543                                  ; INT 13h — Disk Services (memory-resident disk image)
   544                                  ; ============================================================
   545                                  int13h_handler:
   546 000002BF 80FC00                      cmp ah, 0x00
   547 000002C2 7413                        je .disk_reset
   548 000002C4 80FC02                      cmp ah, 0x02
   549 000002C7 742E                        je .disk_read
   550 000002C9 80FC08                      cmp ah, 0x08
   551 000002CC 740D                        je .disk_params
   552 000002CE 80FC15                      cmp ah, 0x15
   553 000002D1 7420                        je .disk_type
   554                                      ; Unknown function — return error
   555 000002D3 B401                        mov ah, 0x01           ; invalid function
   556 000002D5 F9                          stc
   557 000002D6 CF                          iret
   558                                  
   559                                  .disk_reset:
   560 000002D7 30E4                        xor ah, ah
   561 000002D9 F8                          clc
   562 000002DA CF                          iret
   563                                  
   564                                  .disk_params:
   565                                      ; Return drive parameters for 1.44MB floppy
   566 000002DB B400                        mov ah, 0
   567 000002DD B304                        mov bl, 0x04           ; drive type: 1.44MB
   568 000002DF B54F                        mov ch, DISK_CYLS - 1  ; max cylinder (79)
   569 000002E1 B112                        mov cl, DISK_SPT       ; max sector (18)
   570 000002E3 B601                        mov dh, DISK_HEADS - 1 ; max head (1)
   571 000002E5 B201                        mov dl, 1              ; 1 floppy drive
   572                                      ; ES:DI = disk parameter table
   573 000002E7 53                          push bx
   574 000002E8 BB00F0                      mov bx, BIOS_SEG
   575 000002EB 8EC3                        mov es, bx
   576 000002ED BF[D906]                    mov di, disk_param_table
   577 000002F0 5B                          pop bx
   578 000002F1 F8                          clc
   579 000002F2 CF                          iret
   580                                  
   581                                  .disk_type:
   582                                      ; AH=15h: Get disk type — floppy without change detection
   583 000002F3 B401                        mov ah, 0x01
   584 000002F5 F8                          clc
   585 000002F6 CF                          iret
   586                                  
   587                                  .disk_read:
   588                                      ; AH=02h: Read sectors via rom-disk window.
   589                                      ; AL=count, CH=cylinder, CL=sector(1-based), DH=head, DL=drive, ES:BX=dest
   590                                      ;
   591                                      ; Protocol: for each sector, write current LBA word to physical [0x4F0]
   592                                      ; (linear, via segment 0). CSS dispatches reads to 0xD0000..0xD01FF by
   593                                      ; looking up that LBA word, so a REP MOVSW from DS=0xD000 SI=0 produces
   594                                      ; the sector bytes. Then LBA++, DI advances by 512, loop.
   595 000002F7 55                          push bp
   596 000002F8 89E5                        mov bp, sp
   597 000002FA 1E                          push ds
   598 000002FB 56                          push si
   599 000002FC 57                          push di
   600 000002FD 50                          push ax
   601 000002FE 52                          push dx
   602 000002FF 51                          push cx
   603                                  
   604                                      ; Reload to get dx/cx values
   605 00000300 59                          pop cx
   606 00000301 5A                          pop dx
   607 00000302 52                          push dx
   608 00000303 51                          push cx
   609                                  
   610                                      ; Compute LBA = (CH * 2 + DH) * 18 + (CL - 1)
   611 00000304 88E8                        mov al, ch
   612 00000306 30E4                        xor ah, ah
   613 00000308 D1E0                        shl ax, 1              ; AX = cyl * 2
   614 0000030A 89C6                        mov si, ax
   615 0000030C 30E4                        xor ah, ah
   616 0000030E 88F0                        mov al, dh
   617 00000310 01F0                        add ax, si             ; AX = cyl*2 + head
   618 00000312 BE1200                      mov si, DISK_SPT
   619 00000315 52                          push dx
   620 00000316 F7E6                        mul si                 ; AX = (cyl*2+head) * 18
   621 00000318 5A                          pop dx
   622 00000319 89C6                        mov si, ax
   623 0000031B 30ED                        xor ch, ch
   624 0000031D FEC9                        dec cl                 ; sector is 1-based
   625 0000031F 01CE                        add si, cx             ; SI = LBA (starting)
   626                                  
   627                                      ; Reclaim original count (AL) from stack
   628 00000321 59                          pop cx                 ; cx (saved)
   629 00000322 5A                          pop dx                 ; dx (saved)
   630 00000323 58                          pop ax                 ; ax (saved) — AL = sector count
   631 00000324 30E4                        xor ah, ah
   632 00000326 89C1                        mov cx, ax             ; CX = sector count
   633 00000328 51                          push cx                ; preserve original count for return (AL)
   634                                  
   635                                      ; Destination offset = BX (segment already in ES)
   636 00000329 89DF                        mov di, bx
   637                                  
   638                                      ; SI currently = starting LBA. We'll keep LBA in BX across the loop
   639                                      ; because SI needs to be 0 for MOVSW from the disk window.
   640 0000032B 89F3                        mov bx, si
   641                                  
   642                                  .read_sector_loop:
   643                                      ; Write BX (LBA) to linear [0x4F0] as a word via segment 0.
   644 0000032D 1E                          push ds
   645 0000032E 50                          push ax
   646 0000032F 31C0                        xor ax, ax
   647 00000331 8ED8                        mov ds, ax
   648 00000333 891EF004                    mov [disk_lba], bx     ; word write: low at 0x4F0, high at 0x4F1
   649 00000337 58                          pop ax
   650 00000338 1F                          pop ds
   651                                  
   652                                      ; Copy 256 words from DS=DISK_SEG:SI=0 to ES:DI
   653 00000339 51                          push cx                ; save outer sector count
   654 0000033A 1E                          push ds
   655 0000033B BE00D0                      mov si, DISK_SEG
   656 0000033E 8EDE                        mov ds, si
   657 00000340 31F6                        xor si, si
   658 00000342 B90001                      mov cx, 256
   659 00000345 FC                          cld
   660 00000346 F3A5                        rep movsw
   661 00000348 1F                          pop ds
   662 00000349 59                          pop cx                 ; restore sector count
   663                                  
   664                                      ; Next sector: LBA++, DI already advanced by 512 by REP MOVSW
   665 0000034A 43                          inc bx
   666 0000034B 49                          dec cx
   667 0000034C 75DF                        jnz .read_sector_loop
   668                                  
   669                                      ; Success
   670 0000034E 58                          pop ax                 ; AL = sectors read (original count)
   671 0000034F 30E4                        xor ah, ah
   672 00000351 F8                          clc
   673 00000352 5F                          pop di
   674 00000353 5E                          pop si
   675 00000354 1F                          pop ds
   676 00000355 5D                          pop bp
   677 00000356 CF                          iret
   678                                  
   679                                  ; ============================================================
   680                                  ; INT 16h — Keyboard Services (matches reference BIOS contracts)
   681                                  ; ============================================================
   682                                  int16h_handler:
   683 00000357 FB                          sti
   684 00000358 53                          push bx
   685 00000359 1E                          push ds
   686 0000035A BB4000                      mov bx, BDA_SEG
   687 0000035D 8EDB                        mov ds, bx
   688 0000035F 80FC00                      cmp ah, 0x00
   689 00000362 741C                        je .read_key
   690 00000364 80FC01                      cmp ah, 0x01
   691 00000367 7437                        je .check_key
   692 00000369 80FC02                      cmp ah, 0x02
   693 0000036C 7454                        je .shift_flags
   694 0000036E 80FC10                      cmp ah, 0x10
   695 00000371 740D                        je .read_key           ; enhanced = same for us
   696 00000373 80FC11                      cmp ah, 0x11
   697 00000376 7428                        je .check_key          ; enhanced = same for us
   698 00000378 80FC12                      cmp ah, 0x12
   699 0000037B 744B                        je .ext_shift_flags
   700                                      ; Unknown function
   701 0000037D 1F                          pop ds
   702 0000037E 5B                          pop bx
   703 0000037F CF                          iret
   704                                  
   705                                  .read_key:
   706                                      ; AH=00h/10h: Block until a key is in the BDA ring buffer, then pop it.
   707                                      ; DS is already BDA_SEG from handler entry.
   708                                  .key_wait:
   709 00000380 8B1E1A00                    mov bx, [kbd_buffer_head]
   710 00000384 3B1E1C00                    cmp bx, [kbd_buffer_tail]
   711 00000388 74F6                        je .key_wait                ; buffer empty — spin
   712 0000038A 8B07                        mov ax, [bx]                ; read (scancode<<8 | ascii) word
   713 0000038C 83C302                      add bx, 2
   714 0000038F 3B1E8200                    cmp bx, [kbd_buffer_end]    ; wrap around ring buffer
   715 00000393 7204                        jb .rk_nowrap
   716 00000395 8B1E8000                    mov bx, [kbd_buffer_start]
   717                                  .rk_nowrap:
   718 00000399 891E1A00                    mov [kbd_buffer_head], bx   ; advance head (consumes the entry)
   719 0000039D 1F                          pop ds
   720 0000039E 5B                          pop bx
   721 0000039F CF                          iret                        ; AX = key word
   722                                  
   723                                  .check_key:
   724                                      ; AH=01h/11h: Non-destructive peek. Set ZF if buffer empty, clear if key.
   725                                      ; DS is already BDA_SEG from handler entry.
   726 000003A0 8B1E1A00                    mov bx, [kbd_buffer_head]
   727 000003A4 3B1E1C00                    cmp bx, [kbd_buffer_tail]
   728 000003A8 740D                        je .ck_empty
   729 000003AA 8B07                        mov ax, [bx]                ; peek at next key (don't consume)
   730 000003AC 1F                          pop ds
   731 000003AD 5B                          pop bx
   732 000003AE 55                          push bp
   733 000003AF 89E5                        mov bp, sp
   734 000003B1 836606BF                    and word [bp+6], 0xFFBF     ; clear ZF — key available
   735 000003B5 5D                          pop bp
   736 000003B6 CF                          iret
   737                                  .ck_empty:
   738 000003B7 1F                          pop ds
   739 000003B8 5B                          pop bx
   740 000003B9 55                          push bp
   741 000003BA 89E5                        mov bp, sp
   742 000003BC 834E0640                    or word [bp+6], 0x0040      ; set ZF — no key
   743 000003C0 5D                          pop bp
   744 000003C1 CF                          iret
   745                                  
   746                                  .shift_flags:
   747                                      ; AH=02h: Return shift flags from BDA
   748 000003C2 A01700                      mov al, [kbd_flags_1]
   749 000003C5 1F                          pop ds
   750 000003C6 5B                          pop bx
   751 000003C7 CF                          iret
   752                                  
   753                                  .ext_shift_flags:
   754                                      ; AH=12h: Return extended shift flags
   755 000003C8 A01700                      mov al, [kbd_flags_1]
   756 000003CB 8A261800                    mov ah, [kbd_flags_2]
   757 000003CF 1F                          pop ds
   758 000003D0 5B                          pop bx
   759 000003D1 CF                          iret
   760                                  
   761                                  ; ============================================================
   762                                  ; INT 1Ah — Timer Services (matches reference BIOS contract)
   763                                  ; ============================================================
   764                                  int1ah_handler:
   765 000003D2 FB                          sti
   766 000003D3 53                          push bx
   767 000003D4 1E                          push ds
   768 000003D5 BB4000                      mov bx, BDA_SEG
   769 000003D8 8EDB                        mov ds, bx
   770 000003DA 80FC00                      cmp ah, 0x00
   771 000003DD 7408                        je .timer_read
   772 000003DF 80FC01                      cmp ah, 0x01
   773 000003E2 741F                        je .timer_set
   774                                      ; Unknown function
   775 000003E4 1F                          pop ds
   776 000003E5 5B                          pop bx
   777 000003E6 CF                          iret
   778                                  
   779                                  .timer_read:
   780                                      ; AH=00h: Read tick count
   781                                      ; Returns: CX=high, DX=low, AL=midnight flag
   782                                      ; Reference: reads ticks, clears midnight flag via XOR
   783 000003E7 8B166C00                    mov dx, [ticks_lo]
   784 000003EB 8B0E6E00                    mov cx, [ticks_hi]
   785 000003EF A07000                      mov al, [new_day]
   786 000003F2 30067000                    xor byte [new_day], al  ; clear midnight flag (reference method)
   787                                      ; Auto-increment workaround since we have no timer IRQ
   788 000003F6 83066C0001                  add word [ticks_lo], 1
   789 000003FB 83166E0000                  adc word [ticks_hi], 0
   790 00000400 1F                          pop ds
   791 00000401 5B                          pop bx
   792 00000402 CF                          iret
   793                                  
   794                                  .timer_set:
   795                                      ; AH=01h: Set tick count
   796 00000403 89166C00                    mov [ticks_lo], dx
   797 00000407 890E6E00                    mov [ticks_hi], cx
   798 0000040B C606700000                  mov byte [new_day], 0
   799 00000410 1F                          pop ds
   800 00000411 5B                          pop bx
   801 00000412 CF                          iret
   802                                  
   803                                  ; ============================================================
   804                                  ; INT 08h — Timer Tick (IRQ0)
   805                                  ; Increments BDA tick count, checks for midnight, calls INT 1Ch.
   806                                  ; We don't have a real PIT, so this won't fire automatically,
   807                                  ; but having the handler means any code that triggers INT 08h
   808                                  ; will work correctly.
   809                                  ; ============================================================
   810                                  int08h_handler:
   811 00000413 50                          push ax
   812 00000414 52                          push dx
   813 00000415 1E                          push ds
   814 00000416 B84000                      mov ax, BDA_SEG
   815 00000419 8ED8                        mov ds, ax
   816                                      ; Increment tick counter
   817 0000041B FF066C00                    inc word [ticks_lo]
   818 0000041F 7504                        jnz .no_overflow
   819 00000421 FF066E00                    inc word [ticks_hi]
   820                                  .no_overflow:
   821                                      ; Check for midnight rollover (1573042 = 0x18:0x00B2 ticks/day)
   822 00000425 833E6E0018                  cmp word [ticks_hi], 0x18
   823 0000042A 7519                        jnz .no_midnight
   824 0000042C 813E6C00B200                cmp word [ticks_lo], 0x00B2
   825 00000432 7511                        jnz .no_midnight
   826 00000434 C7066E000000                mov word [ticks_hi], 0
   827 0000043A C7066C000000                mov word [ticks_lo], 0
   828 00000440 C606700001                  mov byte [new_day], 1
   829                                  .no_midnight:
   830 00000445 CD1C                        int 0x1C               ; User timer tick hook
   831 00000447 1F                          pop ds
   832 00000448 5A                          pop dx
   833 00000449 58                          pop ax
   834 0000044A CF                          iret
   835                                  
   836                                  ; ============================================================
   837                                  ; INT 15h — Miscellaneous System Services (matches reference)
   838                                  ; ============================================================
   839                                  int15h_handler:
   840 0000044B FB                          sti
   841 0000044C 80FC4F                      cmp ah, 0x4F
   842 0000044F 741F                        je .kbd_intercept
   843 00000451 80FCC0                      cmp ah, 0xC0
   844 00000454 7429                        je .sys_config
   845 00000456 80FC88                      cmp ah, 0x88
   846 00000459 7419                        je .ext_mem_size
   847                                      ; AH=90h/91h: OS hooks — return success
   848 0000045B 80FC90                      cmp ah, 0x90
   849 0000045E 7411                        je .os_hook
   850 00000460 80FC91                      cmp ah, 0x91
   851 00000463 740C                        je .os_hook
   852                                      ; Unknown function — CF set, AH=86h (like reference)
   853 00000465 B486                        mov ah, 0x86
   854 00000467 55                          push bp
   855 00000468 89E5                        mov bp, sp
   856 0000046A 804E0601                    or byte [bp+6], 0x01   ; set CF in stacked FLAGS
   857 0000046E 5D                          pop bp
   858 0000046F CF                          iret
   859                                  
   860                                  .kbd_intercept:
   861                                      ; AH=4Fh: Keyboard intercept — just IRET (pass through)
   862 00000470 CF                          iret
   863                                  
   864                                  .os_hook:
   865                                      ; AH=90h/91h: Device busy/interrupt complete — AH=0, IRET
   866 00000471 B400                        mov ah, 0x00
   867 00000473 CF                          iret
   868                                  
   869                                  .ext_mem_size:
   870                                      ; AH=88h: Extended memory size (above 1MB) — none
   871 00000474 31C0                        xor ax, ax
   872 00000476 55                          push bp
   873 00000477 89E5                        mov bp, sp
   874 00000479 806606FE                    and byte [bp+6], 0xFE  ; clear CF
   875 0000047D 5D                          pop bp
   876 0000047E CF                          iret
   877                                  
   878                                  .sys_config:
   879                                      ; AH=C0h: Get system configuration table
   880 0000047F B400                        mov ah, 0x00
   881 00000481 BB00F0                      mov bx, BIOS_SEG
   882 00000484 8EC3                        mov es, bx
   883 00000486 BB[CF06]                    mov bx, config_table
   884 00000489 55                          push bp
   885 0000048A 89E5                        mov bp, sp
   886 0000048C 806606FE                    and byte [bp+6], 0xFE  ; clear CF
   887 00000490 5D                          pop bp
   888 00000491 CF                          iret
   889                                  
   890                                  ; ============================================================
   891                                  ; INT 19h — Bootstrap (halt in our system)
   892                                  ; ============================================================
   893                                  int19h_handler:
   894 00000492 1E                          push ds
   895 00000493 31C0                        xor ax, ax
   896 00000495 8ED8                        mov ds, ax
   897 00000497 C606040501                  mov byte [HALT_ADDR], 1
   898 0000049C 1F                          pop ds
   899 0000049D EBF3                        jmp int19h_handler
   900                                  
   901                                  ; ============================================================
   902                                  ; INT 20h — Program Terminate (halt)
   903                                  ; ============================================================
   904                                  int20h_handler:
   905 0000049F 1E                          push ds
   906 000004A0 31C0                        xor ax, ax
   907 000004A2 8ED8                        mov ds, ax
   908 000004A4 C606040501                  mov byte [HALT_ADDR], 1
   909 000004A9 1F                          pop ds
   910 000004AA EBF3                        jmp int20h_handler
   911                                  
   912                                  ; ============================================================
   913                                  ; INT 01h — Single-step trap handler
   914                                  ; Clears TF from stacked FLAGS so execution resumes normally.
   915                                  ; ============================================================
   916                                  int01h_handler:
   917 000004AC 55                          push bp
   918 000004AD 89E5                        mov bp, sp
   919 000004AF 816606FFFE                  and word [bp+6], 0xFEFF    ; clear TF (bit 8) in stacked FLAGS
   920 000004B4 5D                          pop bp
   921 000004B5 CF                          iret
   922                                  
   923                                  ; ============================================================
   924                                  ; int_dummy — Dummy interrupt handler (IRET only)
   925                                  ; Matches reference BIOS int_dummy at FF53h.
   926                                  ; ============================================================
   927                                  int_dummy:
   928 000004B6 CF                          iret
   929                                  
   930                                  ; ============================================================
   931                                  ; default_handler — For unimplemented INTs
   932                                  ; Returns with CF set to signal "not supported".
   933                                  ; ============================================================
   934                                  default_handler:
   935 000004B7 55                          push bp
   936 000004B8 89E5                        mov bp, sp
   937 000004BA 834E0601                    or word [bp+6], 0x0001     ; set CF in stacked FLAGS
   938 000004BE 5D                          pop bp
   939 000004BF CF                          iret
   940                                  
   941                                  ; ============================================================
   942                                  ; Interrupt vector table — offsets only (segment always F000h)
   943                                  ; Matches reference 8088_bios interrupt_table layout exactly.
   944                                  ; 32 entries: INT 00h through INT 1Fh.
   945                                  ; ============================================================
   946                                  interrupt_table:
   947 000004C0 [B604]                      dw int_dummy            ; INT 00 - Divide by zero
   948 000004C2 [AC04]                      dw int01h_handler       ; INT 01 - Single step (clears TF)
   949 000004C4 [B604]                      dw int_dummy            ; INT 02 - NMI (no-op for us)
   950 000004C6 [B604]                      dw int_dummy            ; INT 03 - Breakpoint
   951 000004C8 [B604]                      dw int_dummy            ; INT 04 - Overflow (INTO)
   952 000004CA [B604]                      dw int_dummy            ; INT 05 - Print Screen (stub)
   953 000004CC [B604]                      dw int_dummy            ; INT 06 - Invalid opcode
   954 000004CE [B604]                      dw int_dummy            ; INT 07 - Coprocessor N/A
   955 000004D0 [1304]                      dw int08h_handler       ; INT 08 - IRQ0 Timer
   956 000004D2 [B604]                      dw int_dummy            ; INT 09 - IRQ1 Keyboard (no hw kbd)
   957 000004D4 [B604]                      dw int_dummy            ; INT 0A - IRQ2
   958 000004D6 [B604]                      dw int_dummy            ; INT 0B - IRQ3
   959 000004D8 [B604]                      dw int_dummy            ; INT 0C - IRQ4
   960 000004DA [B604]                      dw int_dummy            ; INT 0D - IRQ5
   961 000004DC [B604]                      dw int_dummy            ; INT 0E - IRQ6 Floppy
   962 000004DE [B604]                      dw int_dummy            ; INT 0F - IRQ7
   963 000004E0 [0000]                      dw int10h_handler       ; INT 10 - Video Services
   964 000004E2 [A702]                      dw int11h_handler       ; INT 11 - Equipment List
   965 000004E4 [B302]                      dw int12h_handler       ; INT 12 - Memory Size
   966 000004E6 [BF02]                      dw int13h_handler       ; INT 13 - Disk Services
   967 000004E8 [B704]                      dw default_handler      ; INT 14 - Serial (stub)
   968 000004EA [4B04]                      dw int15h_handler       ; INT 15 - Misc System Services
   969 000004EC [5703]                      dw int16h_handler       ; INT 16 - Keyboard Services
   970 000004EE [B704]                      dw default_handler      ; INT 17 - Printer (stub)
   971 000004F0 [B604]                      dw int_dummy            ; INT 18 - ROM BASIC (stub)
   972 000004F2 [9204]                      dw int19h_handler       ; INT 19 - Bootstrap
   973 000004F4 [D203]                      dw int1ah_handler       ; INT 1A - Timer Services
   974 000004F6 [B604]                      dw int_dummy            ; INT 1B - Keyboard Break
   975 000004F8 [B604]                      dw int_dummy            ; INT 1C - User Timer Tick (IRET hook)
   976 000004FA [B604]                      dw int_dummy            ; INT 1D - Video Parameters (stub)
   977 000004FC [D906]                      dw disk_param_table     ; INT 1E - Floppy Parameters (data ptr)
   978 000004FE [B604]                      dw int_dummy            ; INT 1F - Font (stub)
   979                                  
   980                                  ; ============================================================
   981                                  ; BIOS Init — POST entry point
   982                                  ; Sets up IVT from interrupt_table, initializes BDA, boots DOS.
   983                                  ; ============================================================
   984                                  bios_init:
   985 00000500 FA                          cli
   986 00000501 FC                          cld
   987                                  
   988                                      ; Set up stack at 0030:0100 (reference uses upper IVT area)
   989                                      ; This is 0x0400 linear, well below kernel at 0x600.
   990 00000502 B83000                      mov ax, 0x0030
   991 00000505 8ED0                        mov ss, ax
   992 00000507 BC0001                      mov sp, 0x0100
   993                                  
   994                                      ; --- Initialize interrupt table ---
   995                                      ; Copy 32 vectors from interrupt_table (like reference BIOS).
   996                                      ; Reference uses movsw+stosw with DS=CS, ES=0. We can't use
   997                                      ; string ops easily, so we use a manual loop.
   998                                      ; First, set DS=0 for IVT writes.
   999 0000050A 31C0                        xor ax, ax
  1000 0000050C 8ED8                        mov ds, ax
  1001                                  
  1002                                      ; Fill ALL 256 IVT entries with int_dummy:F000 first
  1003                                      ; (like reference fills remaining with int_dummy after the table)
  1004 0000050E 31FF                        xor di, di
  1005 00000510 B90001                      mov cx, 256
  1006 00000513 B800F0                      mov ax, BIOS_SEG
  1007                                  .fill_all:
  1008 00000516 C705[B604]                  mov word [di], int_dummy
  1009 0000051A 894502                      mov word [di+2], ax        ; segment = F000h
  1010 0000051D 83C704                      add di, 4
