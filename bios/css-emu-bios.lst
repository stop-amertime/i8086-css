  1026 00000530 1F                          pop ds                 ; DS = 0 again
  1027                                      ; Write to IVT
  1028 00000531 891D                        mov [di], bx           ; offset
  1029 00000533 C7450200F0                  mov word [di+2], BIOS_SEG  ; segment
  1030 00000538 83C602                      add si, 2
  1031 0000053B 83C704                      add di, 4
  1032 0000053E 49                          dec cx
  1033 0000053F 75EA                        jnz .ivt_copy
  1034                                  
