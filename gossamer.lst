     1                                  ; bios.asm — Minimal BIOS/DOS stub for i8086-css
     2                                  ; Loaded at F000:0000 (linear 0xF0000)
     3                                  ;
     4                                  ; CONSTRAINTS:
     5                                  ; - No 0x0F-prefixed opcodes (near Jcc) — CSS emulator doesn't support them
     6                                  ; - No segment override prefixes (0x26 ES:, 0x2E CS:, etc.) — treated as no-ops
     7                                  ; - All memory access uses DS segment (the default)
     8                                  ; - For VGA access: set DS=0xB800, use [DI] addressing
     9                                  
    10                                  [bits 16]
    11                                  [org 0]
    12                                  
    13                                  ; ============================================================
    14                                  ; INT 10h — Video Services  (offset 0)
    15                                  ; ============================================================
    16                                  int10h_handler:
    17 00000000 80FC0E                      cmp ah, 0x0E
    18 00000003 7578                        jne .dispatch_other
    19                                      ; Fall through to teletype (most common)
    20                                  
    21                                  ; --- AH=0Eh: Teletype output ---
    22                                  ; AL = character to display
    23                                  .teletype:
    24 00000005 1E                          push ds
    25 00000006 57                          push di
    26 00000007 53                          push bx
    27 00000008 51                          push cx
    28 00000009 52                          push dx
    29 0000000A 50                          push ax                ; save character in AL
    30                                  
    31                                      ; Read cursor from BDA (DS=0x0040)
    32 0000000B BB4000                      mov bx, 0x0040
    33 0000000E 8EDB                        mov ds, bx
    34 00000010 8A165000                    mov dl, [0x0050]       ; column
    35 00000014 8A365100                    mov dh, [0x0051]       ; row
    36                                  
    37                                      ; Character is still in saved AX on stack; pop to get it back
    38 00000018 58                          pop ax                 ; AX restored (AL = character)
    39 00000019 50                          push ax                ; save again
    40                                  
    41 0000001A 3C0D                        cmp al, 13
    42 0000001C 7440                        je .tty_cr
    43 0000001E 3C0A                        cmp al, 10
    44 00000020 7440                        je .tty_lf
    45 00000022 3C07                        cmp al, 7
    46 00000024 7450                        je .tty_done
    47                                  
    48                                      ; Compute VGA offset = (row*80+col)*2
    49 00000026 50                          push ax                ; save char
    50 00000027 52                          push dx                ; save cursor
    51 00000028 88F0                        mov al, dh
    52 0000002A B350                        mov bl, 80
    53 0000002C F6E3                        mul bl                 ; AX = row*80
    54 0000002E 30FF                        xor bh, bh
    55 00000030 88D3                        mov bl, dl
    56 00000032 01D8                        add ax, bx             ; AX = row*80+col
    57 00000034 D1E0                        shl ax, 1              ; AX = (row*80+col)*2
    58 00000036 89C7                        mov di, ax
    59 00000038 5A                          pop dx                 ; restore cursor
    60 00000039 58                          pop ax                 ; restore char
    61                                  
    62                                      ; Switch DS to VGA segment and write
    63 0000003A 1E                          push ds                ; save BDA segment
    64 0000003B BB00B8                      mov bx, 0xB800
    65 0000003E 8EDB                        mov ds, bx
    66 00000040 8805                        mov [di], al           ; write character (DS:DI = B800:offset)
    67 00000042 C6450107                    mov byte [di+1], 0x07  ; write attribute
    68 00000046 1F                          pop ds                 ; restore BDA segment
    69                                  
    70                                      ; Advance cursor
    71 00000047 FEC2                        inc dl                 ; col++
    72 00000049 80FA50                      cmp dl, 80
    73 0000004C 7220                        jb .tty_save
    74 0000004E 30D2                        xor dl, dl             ; col = 0
    75 00000050 FEC6                        inc dh                 ; row++
    76 00000052 80FE19                      cmp dh, 25
    77 00000055 7217                        jb .tty_save
    78 00000057 FECE                        dec dh                 ; row = 24
    79 00000059 E8C600                      call scroll_up_one
    80 0000005C EB10                        jmp short .tty_save
    81                                  
    82                                  .tty_cr:
    83 0000005E 30D2                        xor dl, dl
    84 00000060 EB0C                        jmp short .tty_save
    85                                  
    86                                  .tty_lf:
    87 00000062 FEC6                        inc dh
    88 00000064 80FE19                      cmp dh, 25
    89 00000067 7205                        jb .tty_save
    90 00000069 FECE                        dec dh
    91 0000006B E8B400                      call scroll_up_one
    92                                  
    93                                  .tty_save:
    94                                      ; Write cursor back to BDA (DS already = 0x0040)
    95 0000006E 88165000                    mov [0x0050], dl
    96 00000072 88365100                    mov [0x0051], dh
    97                                  
    98                                  .tty_done:
    99 00000076 58                          pop ax                 ; restore original AX
   100 00000077 5A                          pop dx
   101 00000078 59                          pop cx
   102 00000079 5B                          pop bx
   103 0000007A 5F                          pop di
   104 0000007B 1F                          pop ds
   105 0000007C CF                          iret
   106                                  
   107                                  ; --- INT 10h dispatch for non-teletype ---
   108                                  .dispatch_other:
   109 0000007D 80FC02                      cmp ah, 0x02
   110 00000080 7415                        je .set_cursor
   111 00000082 80FC03                      cmp ah, 0x03
   112 00000085 7422                        je .get_cursor
   113 00000087 80FC00                      cmp ah, 0x00
   114 0000008A 7439                        je .set_mode
   115 0000008C 80FC06                      cmp ah, 0x06
   116 0000008F 7463                        je .scroll_up
   117 00000091 80FC0F                      cmp ah, 0x0F
   118 00000094 7428                        je .get_mode
   119 00000096 CF                          iret
   120                                  
   121                                  .set_cursor:
   122 00000097 1E                          push ds
   123 00000098 53                          push bx
   124 00000099 BB4000                      mov bx, 0x0040
   125 0000009C 8EDB                        mov ds, bx
   126 0000009E 88165000                    mov [0x0050], dl
   127 000000A2 88365100                    mov [0x0051], dh
   128 000000A6 5B                          pop bx
   129 000000A7 1F                          pop ds
   130 000000A8 CF                          iret
   131                                  
   132                                  .get_cursor:
   133 000000A9 1E                          push ds
   134 000000AA 53                          push bx
   135 000000AB BB4000                      mov bx, 0x0040
   136 000000AE 8EDB                        mov ds, bx
   137 000000B0 8A165000                    mov dl, [0x0050]
   138 000000B4 8A365100                    mov dh, [0x0051]
   139 000000B8 B90706                      mov cx, 0x0607
   140 000000BB 5B                          pop bx
   141 000000BC 1F                          pop ds
   142 000000BD CF                          iret
   143                                  
   144                                  .get_mode:
   145 000000BE B003                        mov al, 0x03
   146 000000C0 B450                        mov ah, 80
   147 000000C2 B700                        mov bh, 0
   148 000000C4 CF                          iret
   149                                  
   150                                  .set_mode:
   151 000000C5 1E                          push ds
   152 000000C6 57                          push di
   153 000000C7 51                          push cx
   154 000000C8 50                          push ax
   155                                      ; Clear cursor
   156 000000C9 B84000                      mov ax, 0x0040
   157 000000CC 8ED8                        mov ds, ax
   158 000000CE C606500000                  mov byte [0x0050], 0
   159 000000D3 C606510000                  mov byte [0x0051], 0
   160                                      ; Clear screen: DS=VGA, fill with spaces
   161 000000D8 B800B8                      mov ax, 0xB800
   162 000000DB 8ED8                        mov ds, ax
   163 000000DD 31FF                        xor di, di
   164 000000DF B9D007                      mov cx, 2000
   165 000000E2 B82007                      mov ax, 0x0720
   166                                  .clr_loop:
   167 000000E5 8905                        mov [di], ax           ; DS:DI = B800:offset
   168 000000E7 83C702                      add di, 2
   169 000000EA 49                          dec cx
   170 000000EB 75F8                        jnz .clr_loop
   171 000000ED 58                          pop ax
   172 000000EE B030                        mov al, 0x30
   173 000000F0 59                          pop cx
   174 000000F1 5F                          pop di
   175 000000F2 1F                          pop ds
   176 000000F3 CF                          iret
   177                                  
   178                                  .scroll_up:
   179 000000F4 3C00                        cmp al, 0
   180 000000F6 751C                        jne .su_lines
   181                                      ; Clear entire screen
   182 000000F8 1E                          push ds
   183 000000F9 57                          push di
   184 000000FA 51                          push cx
   185 000000FB B900B8                      mov cx, 0xB800
   186 000000FE 8ED9                        mov ds, cx
   187 00000100 31FF                        xor di, di
   188 00000102 B9D007                      mov cx, 2000
   189 00000105 B82007                      mov ax, 0x0720
   190                                  .su_clr:
   191 00000108 8905                        mov [di], ax
   192 0000010A 83C702                      add di, 2
   193 0000010D 49                          dec cx
   194 0000010E 75F8                        jnz .su_clr
   195 00000110 59                          pop cx
   196 00000111 5F                          pop di
   197 00000112 1F                          pop ds
   198 00000113 CF                          iret
   199                                  .su_lines:
   200 00000114 51                          push cx
   201 00000115 88C1                        mov cl, al
   202 00000117 30ED                        xor ch, ch
   203                                  .su_loop:
   204 00000119 E80600                      call scroll_up_one
   205 0000011C FEC9                        dec cl
   206 0000011E 75F9                        jnz .su_loop
   207 00000120 59                          pop cx
   208 00000121 CF                          iret
   209                                  
   210                                  ; ============================================================
   211                                  ; scroll_up_one — all VGA access via DS=0xB800
   212                                  ; ============================================================
   213                                  scroll_up_one:
   214 00000122 1E                          push ds
   215 00000123 56                          push si
   216 00000124 57                          push di
   217 00000125 51                          push cx
   218 00000126 50                          push ax
   219 00000127 B800B8                      mov ax, 0xB800
   220 0000012A 8ED8                        mov ds, ax
   221                                      ; Copy rows 1-24 up to rows 0-23
   222 0000012C BEA000                      mov si, 160            ; source = start of row 1
   223 0000012F 31FF                        xor di, di             ; dest = start of row 0
   224 00000131 B98007                      mov cx, 1920           ; 24 rows * 80 cols = 1920 words
   225                                  .scopy:
   226 00000134 8B04                        mov ax, [si]           ; read char+attr from source
   227 00000136 8905                        mov [di], ax           ; write to dest
   228 00000138 83C602                      add si, 2
   229 0000013B 83C702                      add di, 2
   230 0000013E 49                          dec cx
   231 0000013F 75F3                        jnz .scopy
   232                                      ; Clear last row
   233 00000141 B95000                      mov cx, 80
   234 00000144 B82007                      mov ax, 0x0720
   235                                  .sclear:
   236 00000147 8905                        mov [di], ax
   237 00000149 83C702                      add di, 2
   238 0000014C 49                          dec cx
   239 0000014D 75F8                        jnz .sclear
   240 0000014F 58                          pop ax
   241 00000150 59                          pop cx
   242 00000151 5F                          pop di
   243 00000152 5E                          pop si
   244 00000153 1F                          pop ds
   245 00000154 C3                          ret
   246                                  
   247                                  ; ============================================================
   248                                  ; INT 16h — Keyboard
   249                                  ; ============================================================
   250                                  int16h_handler:
   251 00000155 80FC00                      cmp ah, 0x00
   252 00000158 7408                        je .read_key
   253 0000015A 80FC01                      cmp ah, 0x01
   254 0000015D 7413                        je .check_key
   255 0000015F 30C0                        xor al, al
   256 00000161 CF                          iret
   257                                  
   258                                  .read_key:
   259 00000162 1E                          push ds
   260 00000163 53                          push bx
   261 00000164 31DB                        xor bx, bx
   262 00000166 8EDB                        mov ds, bx
   263                                  .key_wait:
   264 00000168 A10005                      mov ax, [0x0500]
   265 0000016B 85C0                        test ax, ax
   266 0000016D 74F9                        jz .key_wait
   267 0000016F 5B                          pop bx
   268 00000170 1F                          pop ds
   269 00000171 CF                          iret
   270                                  
   271                                  .check_key:
   272 00000172 1E                          push ds
   273 00000173 53                          push bx
   274 00000174 31DB                        xor bx, bx
   275 00000176 8EDB                        mov ds, bx
   276 00000178 A10005                      mov ax, [0x0500]
   277 0000017B 5B                          pop bx
   278 0000017C 1F                          pop ds
   279 0000017D 85C0                        test ax, ax
   280 0000017F 55                          push bp
   281 00000180 89E5                        mov bp, sp
   282 00000182 7406                        jz .ck_none
   283 00000184 836606BF                    and word [bp+6], 0xFFBF
   284 00000188 EB04                        jmp short .ck_ret
   285                                  .ck_none:
   286 0000018A 834E0640                    or word [bp+6], 0x0040
   287                                  .ck_ret:
   288 0000018E 5D                          pop bp
   289 0000018F CF                          iret
   290                                  
   291                                  ; ============================================================
   292                                  ; INT 1Ah — Timer
   293                                  ; ============================================================
   294                                  int1ah_handler:
   295 00000190 80FC00                      cmp ah, 0x00
   296 00000193 7511                        jne .timer_ret
   297 00000195 1E                          push ds
   298 00000196 53                          push bx
   299 00000197 31DB                        xor bx, bx
   300 00000199 8EDB                        mov ds, bx
   301 0000019B 8B160205                    mov dx, [0x0502]
   302 0000019F 31C9                        xor cx, cx
   303 000001A1 30C0                        xor al, al
   304 000001A3 5B                          pop bx
   305 000001A4 1F                          pop ds
   306 000001A5 CF                          iret
   307                                  .timer_ret:
   308 000001A6 31C0                        xor ax, ax
   309 000001A8 CF                          iret
   310                                  
   311                                  ; ============================================================
   312                                  ; INT 21h — DOS
   313                                  ; ============================================================
   314                                  int21h_handler:
   315 000001A9 80FC02                      cmp ah, 0x02
   316 000001AC 7433                        je .write_char
   317 000001AE 80FC06                      cmp ah, 0x06
   318 000001B1 7437                        je .direct_io
   319 000001B3 80FC09                      cmp ah, 0x09
   320 000001B6 7443                        je .write_string
   321 000001B8 80FC01                      cmp ah, 0x01
   322 000001BB 7454                        je .read_echo
   323 000001BD 80FC07                      cmp ah, 0x07
   324 000001C0 745A                        je .read_noecho
   325 000001C2 80FC08                      cmp ah, 0x08
   326 000001C5 7455                        je .read_noecho
   327 000001C7 80FC4C                      cmp ah, 0x4C
   328 000001CA 7455                        je .exit
   329 000001CC 80FC0E                      cmp ah, 0x0E
   330 000001CF 745D                        je .select_disk
   331 000001D1 80FC19                      cmp ah, 0x19
   332 000001D4 745B                        je .get_disk
   333 000001D6 80FC30                      cmp ah, 0x30
   334 000001D9 7459                        je .get_version
   335 000001DB 80FC2C                      cmp ah, 0x2C
   336 000001DE 7458                        je .get_time_dos
   337 000001E0 CF                          iret
   338                                  
   339                                  .write_char:
   340 000001E1 50                          push ax
   341 000001E2 88D0                        mov al, dl
   342 000001E4 B40E                        mov ah, 0x0E
   343 000001E6 CD10                        int 0x10
   344 000001E8 58                          pop ax
   345 000001E9 CF                          iret
   346                                  
   347                                  .direct_io:
   348 000001EA 80FAFF                      cmp dl, 0xFF
   349 000001ED 7409                        je .dio_read
   350 000001EF 50                          push ax
   351 000001F0 88D0                        mov al, dl
   352 000001F2 B40E                        mov ah, 0x0E
   353 000001F4 CD10                        int 0x10
   354 000001F6 58                          pop ax
   355 000001F7 CF                          iret
   356                                  .dio_read:
   357 000001F8 30C0                        xor al, al
   358 000001FA CF                          iret
   359                                  
   360                                  .write_string:
   361 000001FB 56                          push si
   362 000001FC 50                          push ax
   363 000001FD 89D6                        mov si, dx
   364                                  .ws_loop:
   365 000001FF 8A04                        mov al, [si]
   366 00000201 3C24                        cmp al, '$'
   367 00000203 7409                        je .ws_end
   368 00000205 56                          push si
   369 00000206 B40E                        mov ah, 0x0E
   370 00000208 CD10                        int 0x10
   371 0000020A 5E                          pop si
   372 0000020B 46                          inc si
   373 0000020C EBF1                        jmp short .ws_loop
   374                                  .ws_end:
   375 0000020E 58                          pop ax
   376 0000020F 5E                          pop si
   377 00000210 CF                          iret
   378                                  
   379                                  .read_echo:
   380 00000211 B400                        mov ah, 0x00
   381 00000213 CD16                        int 0x16
   382 00000215 50                          push ax
   383 00000216 B40E                        mov ah, 0x0E
   384 00000218 CD10                        int 0x10
   385 0000021A 58                          pop ax
   386 0000021B CF                          iret
   387                                  
   388                                  .read_noecho:
   389 0000021C B400                        mov ah, 0x00
   390 0000021E CD16                        int 0x16
   391 00000220 CF                          iret
   392                                  
   393                                  .exit:
   394                                      ; Signal halt: write 1 to halt flag at DS:0x2110
   395 00000221 1E                          push ds
   396 00000222 31C0                        xor ax, ax
   397 00000224 8ED8                        mov ds, ax
   398 00000226 C606102101                  mov byte [0x2110], 1
   399 0000022B 1F                          pop ds
   400 0000022C EBF3                        jmp .exit
   401                                  
   402                                  .select_disk:
   403 0000022E B001                        mov al, 1
   404 00000230 CF                          iret
   405                                  
   406                                  .get_disk:
   407 00000231 30C0                        xor al, al
   408 00000233 CF                          iret
   409                                  
   410                                  .get_version:
   411 00000234 B80500                      mov ax, 0x0005
   412 00000237 CF                          iret
   413                                  
   414                                  .get_time_dos:
   415 00000238 31C9                        xor cx, cx
   416 0000023A 31D2                        xor dx, dx
   417 0000023C CF                          iret
   418                                  
   419                                  ; ============================================================
   420                                  ; INT 20h — Halt
   421                                  ; ============================================================
   422                                  int20h_handler:
   423                                      ; Signal halt: write 1 to halt flag at DS:0x2110
   424 0000023D 1E                          push ds
   425 0000023E 31C0                        xor ax, ax
   426 00000240 8ED8                        mov ds, ax
   427 00000242 C606102101                  mov byte [0x2110], 1
   428 00000247 1F                          pop ds
   429 00000248 EBF3                        jmp int20h_handler
   430                                  
   431                                  bios_end:
