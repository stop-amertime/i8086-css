   416 00000211 52                          push dx
   417 00000212 51                          push cx
   418 00000213 53                          push bx
   419 00000214 BB4000                      mov bx, BDA_SEG
   420 00000217 8EDB                        mov ds, bx
   421 00000219 8A165000                    mov dl, [video_cur_pos]
