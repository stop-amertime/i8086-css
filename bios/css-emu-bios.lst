  1134                                      ; --- Jump to DOS kernel ---
  1135                                      ; KERNEL.SYS is pre-loaded at 0060:0000 by the transpiler.
  1136                                      ; Kernel expects BL = boot drive (0x00 = A:)
  1137 0000064B 31C0                        xor ax, ax
  1138 0000064D 8ED8                        mov ds, ax
  1139 0000064F B300                        mov bl, 0x00
