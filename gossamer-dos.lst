  1168                                  ;       |||||`-- EBDA allocated
  1169                                  ;       ||||`-- wait for event supported
  1170                                  ;       |||`-- INT 15h/4Fh called on INT 09h
  1171                                  ;       ||`-- RTC installed
  1172                                  ;       |`-- 2nd PIC installed
  1173                                  ;       `-- DMA ch3 used by HDD
  1174 000006A6 00                          db 0x00                ; byte 6: feature byte 2
  1175 000006A7 00                          db 0x00                ; byte 7: feature byte 3
  1176 000006A8 00                          db 0x00                ; byte 8: feature byte 4
  1177 000006A9 00                          db 0x00                ; byte 9: feature byte 5
