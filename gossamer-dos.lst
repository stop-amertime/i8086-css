  1026                                      ; Video mode and parameters
  1027 00000561 C606490003                  mov byte [video_mode], 0x03             ; mode 3 = 80x25 text
  1028 00000566 C7064A005000                mov word [video_columns], 80            ; 80 columns
  1029 0000056C C7064C000010                mov word [video_page_size], 0x1000      ; 4096 bytes per page
  1030 00000572 C7064E000000                mov word [video_page_offt], 0x0000      ; page 0 offset
  1031 00000578 C70650000000                mov word [video_cur_pos], 0x0000        ; cursor at (0,0)
  1032 0000057E C70652000000                mov word [video_cur_pos+2], 0x0000      ; page 1 cursor
  1033 00000584 C70654000000                mov word [video_cur_pos+4], 0x0000      ; page 2 cursor
  1034 0000058A C70656000000                mov word [video_cur_pos+6], 0x0000      ; page 3 cursor
  1035 00000590 C70660000706                mov word [video_cur_shape], 0x0607      ; cursor shape start=6 end=7
  1036 00000596 C606620000                  mov byte [video_page], 0x00             ; active page 0
  1037 0000059B C7066300D403                mov word [video_port], 0x03D4           ; CRT controller port (color)
  1038 000005A1 C606840018                  mov byte [video_rows], 24               ; rows minus 1
  1039 000005A6 C70685001000                mov word [video_char_height], 16        ; character height
