  1189                                  ; System configuration table (returned by INT 15h AH=C0h)
  1190                                  ; Matches reference 8088_bios config_table layout.
  1191                                  ; ============================================================
  1192                                  config_table:
  1193 000006CC 0800                        dw .size               ; bytes 0-1: table size
  1194                                  .bytes:
  1195 000006CE FE                          db 0xFE                ; byte 2: model byte (XT)
  1196 000006CF 00                          db 0x00                ; byte 3: submodel
  1197 000006D0 00                          db 0x00                ; byte 4: BIOS revision
  1198 000006D1 00                          db 0x00                ; byte 5: feature byte 1 (no special hw)
  1199                                  ;       |||||||`-- dual bus
  1200                                  ;       ||||||`-- Micro Channel
  1201                                  ;       |||||`-- EBDA allocated
  1202                                  ;       ||||`-- wait for event supported
  1203                                  ;       |||`-- INT 15h/4Fh called on INT 09h
  1204                                  ;       ||`-- RTC installed
  1205                                  ;       |`-- 2nd PIC installed
  1206                                  ;       `-- DMA ch3 used by HDD
  1207 000006D2 00                          db 0x00                ; byte 6: feature byte 2
  1208 000006D3 00                          db 0x00                ; byte 7: feature byte 3
  1209 000006D4 00                          db 0x00                ; byte 8: feature byte 4
  1210 000006D5 00                          db 0x00                ; byte 9: feature byte 5
  1211                                  .size equ $ - .bytes
