  1088                                      ; --- BIOS splash screen ---
  1089                                      ; Write directly to VGA memory at B800:0000
  1090 00000603 B800B8                      mov ax, VGA_SEG
  1091 00000606 8ED8                        mov ds, ax
  1092                                  
  1093                                      ; Clear screen
  1094 00000608 31FF                        xor di, di
  1095 0000060A B9D007                      mov cx, 2000
  1096 0000060D B82007                      mov ax, 0x0720
  1097                                  .splash_clr:
  1098 00000610 8905                        mov [di], ax
  1099 00000612 83C702                      add di, 2
  1100 00000615 49                          dec cx
  1101 00000616 75F8                        jnz .splash_clr
  1102                                  
  1103                                      ; Write "Gossamer BIOS v1.0" at row 1, col 30 (offset = (1*80+30)*2 = 220)
  1104 00000618 BFDC00                      mov di, 220
  1105 0000061B B40F                        mov ah, 0x0F           ; white on black
  1106 0000061D BE[8606]                    mov si, splash_title
  1107 00000620 E83000                      call .write_splash_str
  1108                                  
  1109                                      ; "640K conventional memory" at row 3, col 28 (offset = (3*80+28)*2 = 536)
  1110 00000623 BF1802                      mov di, 536
  1111 00000626 BE[9906]                    mov si, splash_mem
  1112 00000629 E82700                      call .write_splash_str
  1113                                  
  1114                                      ; Update cursor position in BDA to row 5 (below splash)
  1115 0000062C B84000                      mov ax, BDA_SEG
  1116 0000062F 8ED8                        mov ds, ax
  1117 00000631 C606500000                  mov byte [video_cur_pos], 0     ; col
  1118 00000636 C606510005                  mov byte [video_cur_pos+1], 5   ; row
  1119                                  
  1120                                      ; --- Boot status messages via INT 10h ---
  1121 0000063B FB                          sti
  1122 0000063C BE[B206]                    mov si, msg_ivt
  1123 0000063F E82B00                      call bios_print
  1124 00000642 BE[BB06]                    mov si, msg_boot
  1125 00000645 E82500                      call bios_print
  1126                                  
  1127                                      ; --- Jump to DOS kernel ---
  1128                                      ; KERNEL.SYS is pre-loaded at 0060:0000 by the transpiler.
  1129                                      ; Kernel expects BL = boot drive (0x00 = A:)
  1130 00000648 31C0                        xor ax, ax
  1131 0000064A 8ED8                        mov ds, ax
  1132 0000064C B300                        mov bl, 0x00
  1133 0000064E EA00006000                  jmp KERNEL_SEG:0x0000
  1134                                  
  1135                                  ; --- Write null-terminated string to VGA at DS:DI ---
  1136                                  ; AH = attribute byte (preserved). DS=VGA_SEG on entry.
  1137                                  ; SI points into BIOS ROM (CS segment). Swaps DS to read.
  1138                                  .write_splash_str:
  1139 00000653 53                          push bx
  1140 00000654 8CDB                        mov bx, ds             ; save VGA segment in BX
  1141                                  .wss_loop:
  1142                                      ; Read byte from CS:SI
  1143 00000656 0E                          push cs
  1144 00000657 1F                          pop ds
  1145 00000658 8A04                        mov al, [si]
  1146 0000065A 8EDB                        mov ds, bx             ; restore DS = VGA segment
  1147 0000065C 84C0                        test al, al
  1148 0000065E 740B                        jz .wss_done
  1149 00000660 8805                        mov [di], al
  1150 00000662 886501                      mov [di+1], ah
  1151 00000665 83C702                      add di, 2
  1152 00000668 46                          inc si
  1153 00000669 EBEB                        jmp short .wss_loop
  1154                                  .wss_done:
  1155 0000066B 5B                          pop bx
  1156 0000066C C3                          ret
  1157                                  
  1158                                  ; --- BIOS print: print null-terminated string at CS:SI via INT 10h ---
  1159                                  bios_print:
  1160 0000066D 50                          push ax
  1161 0000066E 53                          push bx
  1162                                  .bp_loop:
  1163 0000066F 1E                          push ds
  1164 00000670 0E                          push cs
  1165 00000671 1F                          pop ds
  1166 00000672 8A04                        mov al, [si]
  1167 00000674 1F                          pop ds
  1168 00000675 84C0                        test al, al
  1169 00000677 740A                        jz .bp_done
  1170 00000679 B40E                        mov ah, 0x0E
  1171 0000067B BB0700                      mov bx, 0x0007
  1172 0000067E CD10                        int 0x10
  1173 00000680 46                          inc si
  1174 00000681 EBEC                        jmp short .bp_loop
  1175                                  .bp_done:
  1176 00000683 5B                          pop bx
  1177 00000684 58                          pop ax
  1178 00000685 C3                          ret
