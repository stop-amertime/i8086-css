     1                                  ; gossamer.asm — Gossamer BIOS for CSS-DOS
     2                                  ; Loaded at F000:0000 (linear 0xF0000)
     3                                  ;
     4                                  ; CONSTRAINTS:
     5                                  ; - No 0x0F-prefixed opcodes (near Jcc) — CSS emulator doesn't support them
     6                                  ; - No segment override prefixes (0x26 ES:, 0x2E CS:, etc.) — treated as no-ops
     7                                  ; - All memory access uses DS segment (the default)
     8                                  ; - For VGA access: set DS=0xB800, use [DI] addressing
     9                                  
    10                                  [bits 16]
    11                                  [org 0]
    12                                  
    13                                  ; ============================================================
    14                                  ; INT 10h — Video Services  (offset 0)
    15                                  ; ============================================================
    16                                  int10h_handler:
    17 00000000 80FC0E                      cmp ah, 0x0E
    18 00000003 7578                        jne .dispatch_other
    19                                      ; Fall through to teletype (most common)
    20                                  
    21                                  ; --- AH=0Eh: Teletype output ---
    22                                  ; AL = character to display
    23                                  .teletype:
    24 00000005 1E                          push ds
    25 00000006 57                          push di
    26 00000007 53                          push bx
    27 00000008 51                          push cx
    28 00000009 52                          push dx
    29 0000000A 50                          push ax                ; save character in AL
    30                                  
    31                                      ; Read cursor from BDA (DS=0x0040)
    32 0000000B BB4000                      mov bx, 0x0040
    33 0000000E 8EDB                        mov ds, bx
    34 00000010 8A165000                    mov dl, [0x0050]       ; column
    35 00000014 8A365100                    mov dh, [0x0051]       ; row
    36                                  
    37                                      ; Character is still in saved AX on stack; pop to get it back
    38 00000018 58                          pop ax                 ; AX restored (AL = character)
    39 00000019 50                          push ax                ; save again
    40                                  
    41 0000001A 3C0D                        cmp al, 13
    42 0000001C 7440                        je .tty_cr
    43 0000001E 3C0A                        cmp al, 10
    44 00000020 7440                        je .tty_lf
    45 00000022 3C07                        cmp al, 7
    46 00000024 7450                        je .tty_done
    47                                  
    48                                      ; Compute VGA offset = (row*80+col)*2
    49 00000026 50                          push ax                ; save char
    50 00000027 52                          push dx                ; save cursor
    51 00000028 88F0                        mov al, dh
    52 0000002A B350                        mov bl, 80
    53 0000002C F6E3                        mul bl                 ; AX = row*80
    54 0000002E 30FF                        xor bh, bh
    55 00000030 88D3                        mov bl, dl
    56 00000032 01D8                        add ax, bx             ; AX = row*80+col
    57 00000034 D1E0                        shl ax, 1              ; AX = (row*80+col)*2
    58 00000036 89C7                        mov di, ax
    59 00000038 5A                          pop dx                 ; restore cursor
    60 00000039 58                          pop ax                 ; restore char
    61                                  
    62                                      ; Switch DS to VGA segment and write
    63 0000003A 1E                          push ds                ; save BDA segment
    64 0000003B BB00B8                      mov bx, 0xB800
    65 0000003E 8EDB                        mov ds, bx
    66 00000040 8805                        mov [di], al           ; write character (DS:DI = B800:offset)
    67 00000042 C6450107                    mov byte [di+1], 0x07  ; write attribute
    68 00000046 1F                          pop ds                 ; restore BDA segment
    69                                  
    70                                      ; Advance cursor
    71 00000047 FEC2                        inc dl                 ; col++
    72 00000049 80FA50                      cmp dl, 80
    73 0000004C 7220                        jb .tty_save
    74 0000004E 30D2                        xor dl, dl             ; col = 0
    75 00000050 FEC6                        inc dh                 ; row++
    76 00000052 80FE19                      cmp dh, 25
    77 00000055 7217                        jb .tty_save
    78 00000057 FECE                        dec dh                 ; row = 24
    79 00000059 E8FB00                      call scroll_up_one
    80 0000005C EB10                        jmp short .tty_save
    81                                  
    82                                  .tty_cr:
    83 0000005E 30D2                        xor dl, dl
    84 00000060 EB0C                        jmp short .tty_save
    85                                  
    86                                  .tty_lf:
    87 00000062 FEC6                        inc dh
    88 00000064 80FE19                      cmp dh, 25
    89 00000067 7205                        jb .tty_save
    90 00000069 FECE                        dec dh
    91 0000006B E8E900                      call scroll_up_one
    92                                  
    93                                  .tty_save:
    94                                      ; Write cursor back to BDA (DS already = 0x0040)
    95 0000006E 88165000                    mov [0x0050], dl
    96 00000072 88365100                    mov [0x0051], dh
    97                                  
    98                                  .tty_done:
    99 00000076 58                          pop ax                 ; restore original AX
   100 00000077 5A                          pop dx
   101 00000078 59                          pop cx
   102 00000079 5B                          pop bx
   103 0000007A 5F                          pop di
   104 0000007B 1F                          pop ds
   105 0000007C CF                          iret
   106                                  
   107                                  ; --- INT 10h dispatch for non-teletype ---
   108                                  .dispatch_other:
   109 0000007D 80FC02                      cmp ah, 0x02
   110 00000080 7417                        je .set_cursor
   111 00000082 80FC03                      cmp ah, 0x03
   112 00000085 7424                        je .get_cursor
   113 00000087 80FC00                      cmp ah, 0x00
   114 0000008A 7449                        je .set_mode
   115 0000008C 80FC06                      cmp ah, 0x06
   116 0000008F 0F849600                    je .scroll_up
   117 00000093 80FC0F                      cmp ah, 0x0F
   118 00000096 7428                        je .get_mode
   119 00000098 CF                          iret
   120                                  
   121                                  .set_cursor:
   122 00000099 1E                          push ds
   123 0000009A 53                          push bx
   124 0000009B BB4000                      mov bx, 0x0040
   125 0000009E 8EDB                        mov ds, bx
   126 000000A0 88165000                    mov [0x0050], dl
   127 000000A4 88365100                    mov [0x0051], dh
   128 000000A8 5B                          pop bx
   129 000000A9 1F                          pop ds
   130 000000AA CF                          iret
   131                                  
   132                                  .get_cursor:
   133 000000AB 1E                          push ds
   134 000000AC 53                          push bx
   135 000000AD BB4000                      mov bx, 0x0040
   136 000000B0 8EDB                        mov ds, bx
   137 000000B2 8A165000                    mov dl, [0x0050]
   138 000000B6 8A365100                    mov dh, [0x0051]
   139 000000BA B90706                      mov cx, 0x0607
   140 000000BD 5B                          pop bx
   141 000000BE 1F                          pop ds
   142 000000BF CF                          iret
   143                                  
   144                                  .get_mode:
   145 000000C0 1E                          push ds
   146 000000C1 53                          push bx
   147 000000C2 BB4000                      mov bx, 0x0040
   148 000000C5 8EDB                        mov ds, bx
   149 000000C7 A04900                      mov al, [0x0049]        ; video_mode from BDA
   150 000000CA 8A264A00                    mov ah, [0x004A]        ; video_columns (byte) from BDA
   151 000000CE 8A3E6200                    mov bh, [0x0062]        ; active video page from BDA
   152 000000D2 5B                          pop bx
   153 000000D3 1F                          pop ds
   154 000000D4 CF                          iret
   155                                  
   156                                  .set_mode:
   157 000000D5 1E                          push ds
   158 000000D6 57                          push di
   159 000000D7 51                          push cx
   160 000000D8 50                          push ax
   161                                      ; Clear cursor and store mode in BDA
   162 000000D9 B84000                      mov ax, 0x0040
   163 000000DC 8ED8                        mov ds, ax
   164 000000DE C606500000                  mov byte [0x0050], 0
   165 000000E3 C606510000                  mov byte [0x0051], 0
   166                                      ; Branch on requested mode: AL=0x13 → Mode 13h (320x200x256),
   167                                      ; everything else treated as text mode (80x25).
   168 000000E8 58                          pop ax                 ; AL = original mode byte
   169 000000E9 50                          push ax                ; save it again for the final pop
   170                                      ; Only store modes we support; map anything else to 0x03.
   171 000000EA 3C13                        cmp al, 0x13
   172 000000EC 7402                        je .store_mode
   173 000000EE B003                        mov al, 0x03
   174                                  .store_mode:
   175 000000F0 A24900                      mov [0x0049], al       ; store video_mode in BDA
   176 000000F3 3C13                        cmp al, 0x13
   177 000000F5 7417                        je .set_mode_13h
   178                                      ; --- Text mode clear: 2000 words of space+attr at 0xB8000 ---
   179 000000F7 B800B8                      mov ax, 0xB800
   180 000000FA 8ED8                        mov ds, ax
   181 000000FC 31FF                        xor di, di
   182 000000FE B9D007                      mov cx, 2000
   183 00000101 B82007                      mov ax, 0x0720
   184                                  .clr_loop:
   185 00000104 8905                        mov [di], ax           ; DS:DI = B800:offset
   186 00000106 83C702                      add di, 2
   187 00000109 49                          dec cx
   188 0000010A 75F8                        jnz .clr_loop
   189 0000010C EB14                        jmp short .set_mode_done
   190                                  .set_mode_13h:
   191                                      ; --- Mode 13h clear: 64000 bytes of 0 at 0xA0000 ---
   192                                      ; Write as 32000 words for speed (still single-byte opcodes).
   193 0000010E B800A0                      mov ax, 0xA000
   194 00000111 8ED8                        mov ds, ax
   195 00000113 31FF                        xor di, di
   196 00000115 B9007D                      mov cx, 32000
   197 00000118 31C0                        xor ax, ax
   198                                  .clr13_loop:
   199 0000011A 8905                        mov [di], ax           ; DS:DI = A000:offset, word write
   200 0000011C 83C702                      add di, 2
   201 0000011F 49                          dec cx
   202 00000120 75F8                        jnz .clr13_loop
   203                                  .set_mode_done:
   204 00000122 58                          pop ax
   205 00000123 B030                        mov al, 0x30
   206 00000125 59                          pop cx
   207 00000126 5F                          pop di
   208 00000127 1F                          pop ds
   209 00000128 CF                          iret
   210                                  
   211                                  .scroll_up:
   212 00000129 3C00                        cmp al, 0
   213 0000012B 751C                        jne .su_lines
   214                                      ; Clear entire screen
   215 0000012D 1E                          push ds
   216 0000012E 57                          push di
   217 0000012F 51                          push cx
   218 00000130 B900B8                      mov cx, 0xB800
   219 00000133 8ED9                        mov ds, cx
   220 00000135 31FF                        xor di, di
   221 00000137 B9D007                      mov cx, 2000
   222 0000013A B82007                      mov ax, 0x0720
   223                                  .su_clr:
   224 0000013D 8905                        mov [di], ax
   225 0000013F 83C702                      add di, 2
   226 00000142 49                          dec cx
   227 00000143 75F8                        jnz .su_clr
   228 00000145 59                          pop cx
   229 00000146 5F                          pop di
   230 00000147 1F                          pop ds
   231 00000148 CF                          iret
   232                                  .su_lines:
   233 00000149 51                          push cx
   234 0000014A 88C1                        mov cl, al
   235 0000014C 30ED                        xor ch, ch
   236                                  .su_loop:
   237 0000014E E80600                      call scroll_up_one
   238 00000151 FEC9                        dec cl
   239 00000153 75F9                        jnz .su_loop
   240 00000155 59                          pop cx
   241 00000156 CF                          iret
   242                                  
   243                                  ; ============================================================
   244                                  ; scroll_up_one — all VGA access via DS=0xB800
   245                                  ; ============================================================
   246                                  scroll_up_one:
   247 00000157 1E                          push ds
   248 00000158 56                          push si
   249 00000159 57                          push di
   250 0000015A 51                          push cx
   251 0000015B 50                          push ax
   252 0000015C B800B8                      mov ax, 0xB800
   253 0000015F 8ED8                        mov ds, ax
   254                                      ; Copy rows 1-24 up to rows 0-23
   255 00000161 BEA000                      mov si, 160            ; source = start of row 1
   256 00000164 31FF                        xor di, di             ; dest = start of row 0
   257 00000166 B98007                      mov cx, 1920           ; 24 rows * 80 cols = 1920 words
   258                                  .scopy:
   259 00000169 8B04                        mov ax, [si]           ; read char+attr from source
   260 0000016B 8905                        mov [di], ax           ; write to dest
   261 0000016D 83C602                      add si, 2
   262 00000170 83C702                      add di, 2
   263 00000173 49                          dec cx
   264 00000174 75F3                        jnz .scopy
   265                                      ; Clear last row
   266 00000176 B95000                      mov cx, 80
   267 00000179 B82007                      mov ax, 0x0720
   268                                  .sclear:
   269 0000017C 8905                        mov [di], ax
   270 0000017E 83C702                      add di, 2
   271 00000181 49                          dec cx
   272 00000182 75F8                        jnz .sclear
   273 00000184 58                          pop ax
   274 00000185 59                          pop cx
   275 00000186 5F                          pop di
   276 00000187 5E                          pop si
   277 00000188 1F                          pop ds
   278 00000189 C3                          ret
   279                                  
   280                                  ; ============================================================
   281                                  ; INT 16h — Keyboard
   282                                  ; ============================================================
   283                                  int16h_handler:
   284 0000018A 80FC00                      cmp ah, 0x00
   285 0000018D 7408                        je .read_key
   286 0000018F 80FC01                      cmp ah, 0x01
   287 00000192 7413                        je .check_key
   288 00000194 30C0                        xor al, al
   289 00000196 CF                          iret
   290                                  
   291                                  .read_key:
   292 00000197 1E                          push ds
   293 00000198 53                          push bx
   294 00000199 31DB                        xor bx, bx
   295 0000019B 8EDB                        mov ds, bx
   296                                  .key_wait:
   297 0000019D A10005                      mov ax, [0x0500]
   298 000001A0 85C0                        test ax, ax
   299 000001A2 74F9                        jz .key_wait
   300 000001A4 5B                          pop bx
   301 000001A5 1F                          pop ds
   302 000001A6 CF                          iret
   303                                  
   304                                  .check_key:
   305 000001A7 1E                          push ds
   306 000001A8 53                          push bx
   307 000001A9 31DB                        xor bx, bx
   308 000001AB 8EDB                        mov ds, bx
   309 000001AD A10005                      mov ax, [0x0500]
   310 000001B0 5B                          pop bx
   311 000001B1 1F                          pop ds
   312 000001B2 85C0                        test ax, ax
   313 000001B4 55                          push bp
   314 000001B5 89E5                        mov bp, sp
   315 000001B7 7406                        jz .ck_none
   316 000001B9 836606BF                    and word [bp+6], 0xFFBF
   317 000001BD EB04                        jmp short .ck_ret
   318                                  .ck_none:
   319 000001BF 834E0640                    or word [bp+6], 0x0040
   320                                  .ck_ret:
   321 000001C3 5D                          pop bp
   322 000001C4 CF                          iret
   323                                  
   324                                  ; ============================================================
   325                                  ; INT 1Ah — Timer
   326                                  ; ============================================================
   327                                  int1ah_handler:
   328 000001C5 80FC00                      cmp ah, 0x00
   329 000001C8 7511                        jne .timer_ret
   330 000001CA 1E                          push ds
   331 000001CB 53                          push bx
   332 000001CC 31DB                        xor bx, bx
   333 000001CE 8EDB                        mov ds, bx
   334 000001D0 8B160205                    mov dx, [0x0502]
   335 000001D4 31C9                        xor cx, cx
   336 000001D6 30C0                        xor al, al
   337 000001D8 5B                          pop bx
   338 000001D9 1F                          pop ds
   339 000001DA CF                          iret
   340                                  .timer_ret:
   341 000001DB 31C0                        xor ax, ax
   342 000001DD CF                          iret
   343                                  
   344                                  ; ============================================================
   345                                  ; INT 21h — DOS
   346                                  ; ============================================================
   347                                  int21h_handler:
   348 000001DE 80FC02                      cmp ah, 0x02
   349 000001E1 7433                        je .write_char
   350 000001E3 80FC06                      cmp ah, 0x06
   351 000001E6 7437                        je .direct_io
   352 000001E8 80FC09                      cmp ah, 0x09
   353 000001EB 7443                        je .write_string
   354 000001ED 80FC01                      cmp ah, 0x01
   355 000001F0 7454                        je .read_echo
   356 000001F2 80FC07                      cmp ah, 0x07
   357 000001F5 745A                        je .read_noecho
   358 000001F7 80FC08                      cmp ah, 0x08
   359 000001FA 7455                        je .read_noecho
   360 000001FC 80FC4C                      cmp ah, 0x4C
   361 000001FF 7455                        je .exit
   362 00000201 80FC0E                      cmp ah, 0x0E
   363 00000204 745D                        je .select_disk
   364 00000206 80FC19                      cmp ah, 0x19
   365 00000209 745B                        je .get_disk
   366 0000020B 80FC30                      cmp ah, 0x30
   367 0000020E 7459                        je .get_version
   368 00000210 80FC2C                      cmp ah, 0x2C
   369 00000213 7458                        je .get_time_dos
   370 00000215 CF                          iret
   371                                  
   372                                  .write_char:
   373 00000216 50                          push ax
   374 00000217 88D0                        mov al, dl
   375 00000219 B40E                        mov ah, 0x0E
   376 0000021B CD10                        int 0x10
   377 0000021D 58                          pop ax
   378 0000021E CF                          iret
   379                                  
   380                                  .direct_io:
   381 0000021F 80FAFF                      cmp dl, 0xFF
   382 00000222 7409                        je .dio_read
   383 00000224 50                          push ax
   384 00000225 88D0                        mov al, dl
   385 00000227 B40E                        mov ah, 0x0E
   386 00000229 CD10                        int 0x10
   387 0000022B 58                          pop ax
   388 0000022C CF                          iret
   389                                  .dio_read:
   390 0000022D 30C0                        xor al, al
   391 0000022F CF                          iret
   392                                  
   393                                  .write_string:
   394 00000230 56                          push si
   395 00000231 50                          push ax
   396 00000232 89D6                        mov si, dx
   397                                  .ws_loop:
   398 00000234 8A04                        mov al, [si]
   399 00000236 3C24                        cmp al, '$'
   400 00000238 7409                        je .ws_end
   401 0000023A 56                          push si
   402 0000023B B40E                        mov ah, 0x0E
   403 0000023D CD10                        int 0x10
   404 0000023F 5E                          pop si
   405 00000240 46                          inc si
   406 00000241 EBF1                        jmp short .ws_loop
   407                                  .ws_end:
   408 00000243 58                          pop ax
   409 00000244 5E                          pop si
   410 00000245 CF                          iret
   411                                  
   412                                  .read_echo:
   413 00000246 B400                        mov ah, 0x00
   414 00000248 CD16                        int 0x16
   415 0000024A 50                          push ax
   416 0000024B B40E                        mov ah, 0x0E
   417 0000024D CD10                        int 0x10
   418 0000024F 58                          pop ax
   419 00000250 CF                          iret
   420                                  
   421                                  .read_noecho:
   422 00000251 B400                        mov ah, 0x00
   423 00000253 CD16                        int 0x16
   424 00000255 CF                          iret
   425                                  
   426                                  .exit:
   427                                      ; Signal halt: write 1 to halt flag at DS:0x2110
   428 00000256 1E                          push ds
   429 00000257 31C0                        xor ax, ax
   430 00000259 8ED8                        mov ds, ax
   431 0000025B C606102101                  mov byte [0x2110], 1
   432 00000260 1F                          pop ds
   433 00000261 EBF3                        jmp .exit
   434                                  
   435                                  .select_disk:
   436 00000263 B001                        mov al, 1
   437 00000265 CF                          iret
   438                                  
   439                                  .get_disk:
   440 00000266 30C0                        xor al, al
   441 00000268 CF                          iret
   442                                  
   443                                  .get_version:
   444 00000269 B80500                      mov ax, 0x0005
   445 0000026C CF                          iret
   446                                  
   447                                  .get_time_dos:
   448 0000026D 31C9                        xor cx, cx
   449 0000026F 31D2                        xor dx, dx
   450 00000271 CF                          iret
   451                                  
   452                                  ; ============================================================
   453                                  ; INT 20h — Halt
   454                                  ; ============================================================
   455                                  int20h_handler:
   456                                      ; Signal halt: write 1 to halt flag at DS:0x2110
   457 00000272 1E                          push ds
   458 00000273 31C0                        xor ax, ax
   459 00000275 8ED8                        mov ds, ax
   460 00000277 C606102101                  mov byte [0x2110], 1
   461 0000027C 1F                          pop ds
   462 0000027D EBF3                        jmp int20h_handler
   463                                  
   464                                  bios_end:
