  1166                                  bios_print:
  1167 00000670 50                          push ax
  1168 00000671 53                          push bx
  1169                                  .bp_loop:
  1170 00000672 1E                          push ds
  1171 00000673 0E                          push cs
  1172 00000674 1F                          pop ds
  1173 00000675 8A04                        mov al, [si]
  1174 00000677 1F                          pop ds
  1175 00000678 84C0                        test al, al
  1176 0000067A 740A                        jz .bp_done
  1177 0000067C B40E                        mov ah, 0x0E
