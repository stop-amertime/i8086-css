  1055                                      ; --- BIOS splash screen ---
  1056                                      ; Write directly to VGA memory at B800:0000
  1057 000005D7 B800B8                      mov ax, VGA_SEG
  1058 000005DA 8ED8                        mov ds, ax
  1059                                  
  1060                                      ; Clear screen
  1061 000005DC 31FF                        xor di, di
  1062 000005DE B9D007                      mov cx, 2000
  1063 000005E1 B82007                      mov ax, 0x0720
  1064                                  .splash_clr:
  1065 000005E4 8905                        mov [di], ax
  1066 000005E6 83C702                      add di, 2
  1067 000005E9 49                          dec cx
  1068 000005EA 75F8                        jnz .splash_clr
  1069                                  
  1070                                      ; Write "Gossamer BIOS v1.0" at row 1, col 30 (offset = (1*80+30)*2 = 220)
  1071 000005EC BFDC00                      mov di, 220
  1072 000005EF B40F                        mov ah, 0x0F           ; white on black
  1073 000005F1 BE[5A06]                    mov si, splash_title
  1074 000005F4 E83000                      call .write_splash_str
  1075                                  
  1076                                      ; "640K conventional memory" at row 3, col 28 (offset = (3*80+28)*2 = 536)
  1077 000005F7 BF1802                      mov di, 536
  1078 000005FA BE[6D06]                    mov si, splash_mem
  1079 000005FD E82700                      call .write_splash_str
  1080                                  
  1081                                      ; Update cursor position in BDA to row 5 (below splash)
  1082 00000600 B84000                      mov ax, BDA_SEG
  1083 00000603 8ED8                        mov ds, ax
  1084 00000605 C606500000                  mov byte [video_cur_pos], 0     ; col
  1085 0000060A C606510005                  mov byte [video_cur_pos+1], 5   ; row
  1086                                  
  1087                                      ; --- Boot status messages via INT 10h ---
  1088 0000060F FB                          sti
  1089 00000610 BE[8606]                    mov si, msg_ivt
  1090 00000613 E82B00                      call bios_print
  1091 00000616 BE[8F06]                    mov si, msg_boot
  1092 00000619 E82500                      call bios_print
  1093                                  
  1094                                      ; --- Jump to DOS kernel ---
  1095                                      ; KERNEL.SYS is pre-loaded at 0060:0000 by the transpiler.
  1096                                      ; Kernel expects BL = boot drive (0x00 = A:)
  1097 0000061C 31C0                        xor ax, ax
  1098 0000061E 8ED8                        mov ds, ax
  1099 00000620 B300                        mov bl, 0x00
  1100 00000622 EA00006000                  jmp KERNEL_SEG:0x0000
  1101                                  
  1102                                  ; --- Write null-terminated string to VGA at DS:DI ---
  1103                                  ; AH = attribute byte (preserved). DS=VGA_SEG on entry.
  1104                                  ; SI points into BIOS ROM (CS segment). Swaps DS to read.
  1105                                  .write_splash_str:
  1106 00000627 53                          push bx
  1107 00000628 8CDB                        mov bx, ds             ; save VGA segment in BX
  1108                                  .wss_loop:
  1109                                      ; Read byte from CS:SI
  1110 0000062A 0E                          push cs
  1111 0000062B 1F                          pop ds
  1112 0000062C 8A04                        mov al, [si]
  1113 0000062E 8EDB                        mov ds, bx             ; restore DS = VGA segment
  1114 00000630 84C0                        test al, al
  1115 00000632 740B                        jz .wss_done
  1116 00000634 8805                        mov [di], al
  1117 00000636 886501                      mov [di+1], ah
  1118 00000639 83C702                      add di, 2
  1119 0000063C 46                          inc si
  1120 0000063D EBEB                        jmp short .wss_loop
  1121                                  .wss_done:
  1122 0000063F 5B                          pop bx
  1123 00000640 C3                          ret
  1124                                  
  1125                                  ; --- BIOS print: print null-terminated string at CS:SI via INT 10h ---
  1126                                  bios_print:
  1127 00000641 50                          push ax
  1128 00000642 53                          push bx
  1129                                  .bp_loop:
  1130 00000643 1E                          push ds
  1131 00000644 0E                          push cs
  1132 00000645 1F                          pop ds
  1133 00000646 8A04                        mov al, [si]
  1134 00000648 1F                          pop ds
  1135 00000649 84C0                        test al, al
  1136 0000064B 740A                        jz .bp_done
  1137 0000064D B40E                        mov ah, 0x0E
  1138 0000064F BB0700                      mov bx, 0x0007
  1139 00000652 CD10                        int 0x10
  1140 00000654 46                          inc si
  1141 00000655 EBEC                        jmp short .bp_loop
  1142                                  .bp_done:
  1143 00000657 5B                          pop bx
  1144 00000658 58                          pop ax
  1145 00000659 C3                          ret
