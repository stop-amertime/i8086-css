   437 0000023A 83C702                      add di, 2
   438 0000023D 49                          dec cx
   439 0000023E 75F8                        jnz .wco_loop
   440 00000240 5B                          pop bx
   441 00000241 59                          pop cx
   442 00000242 5A                          pop dx
   443 00000243 5F                          pop di
   444 00000244 5D                          pop bp
   445 00000245 07                          pop es
   446 00000246 1F                          pop ds
   447 00000247 CF                          iret
