     1                                  ; gossamer-dos.asm — Gossamer BIOS (DOS variant) for CSS-DOS
     2                                  ; Loaded at F000:0000 (linear 0xF0000)
     3                                  ;
     4                                  ; Mirrors the 8088_bios reference layout:
     5                                  ;   - IVT setup via interrupt_table array (32 standard vectors + fill rest)
     6                                  ;   - Full BDA initialization matching IBM PC BIOS
     7                                  ;   - INT handlers follow reference contracts
     8                                  ;
     9                                  ; Backend is memory-mapped (no port I/O):
    10                                  ;   - VGA text buffer at B800:0000
    11                                  ;   - Disk image at D000:0000
    12                                  ;   - Keyboard input via polling 0000:0500
    13                                  ;
    14                                  ; DOS kernel (KERNEL.SYS) is pre-loaded at 0060:0000 (linear 0x600)
    15                                  ; by the transpiler. The BIOS init code sets up the IVT and jumps to it.
    16                                  ;
    17                                  ; CONSTRAINTS (CSS transpiler limitations):
    18                                  ; - No 0x0F-prefixed opcodes (near Jcc)
    19                                  ; - Must compile with NASM: [bits 16] [org 0]
    20                                  
    21                                  [bits 16]
    22                                  [org 0]
    23                                  
    24                                  ; ============================================================
    25                                  ; Constants
    26                                  ; ============================================================
    27                                  DISK_SEG    equ 0xD000          ; Disk image loaded here (linear 0xD0000)
    28                                  BDA_SEG     equ 0x0040          ; BIOS Data Area segment
    29                                  BIOS_SEG    equ 0xF000          ; BIOS code segment
    30                                  VGA_SEG     equ 0xB800          ; VGA text mode segment
    31                                  KERNEL_SEG  equ 0x0060          ; DOS kernel load segment
    32                                  SECTOR_SIZE equ 512
    33                                  HALT_ADDR   equ 0x0504          ; Halt flag address (seg 0)
    34                                  
    35                                  ; Disk geometry for a 1.44MB floppy
    36                                  DISK_SPT    equ 18              ; sectors per track
    37                                  DISK_HEADS  equ 2               ; heads
    38                                  DISK_CYLS   equ 80              ; cylinders
    39                                  
    40                                  ; BDA offsets (matching reference 8088_bios exactly)
    41                                  equip_serial        equ 0x00    ; word[4] - serial port addresses
    42                                  equip_parallel      equ 0x08   ; word[3] - parallel port addresses
    43                                  equipment_list      equ 0x10    ; word - equipment list
    44                                  memory_size         equ 0x13    ; word - memory size in KiB
    45                                  kbd_flags_1         equ 0x17    ; byte - keyboard shift flags 1
    46                                  kbd_flags_2         equ 0x18    ; byte - keyboard shift flags 2
    47                                  kbd_alt_keypad      equ 0x19    ; byte - Alt+Numpad work area
    48                                  kbd_buffer_head     equ 0x1A    ; word - keyboard buffer head offset
    49                                  kbd_buffer_tail     equ 0x1C    ; word - keyboard buffer tail offset
    50                                  kbd_buffer          equ 0x1E    ; byte[32] - keyboard buffer
    51                                  fdc_calib_state     equ 0x3E    ; byte - floppy recalibration status
    52                                  fdc_motor_state     equ 0x3F    ; byte - floppy motor status
    53                                  fdc_motor_tout      equ 0x40    ; byte - floppy motor off timeout
    54                                  fdc_last_error      equ 0x41    ; byte - last diskette op status
    55                                  video_mode          equ 0x49    ; byte - active video mode
    56                                  video_columns       equ 0x4A    ; word - text columns
    57                                  video_page_size     equ 0x4C    ; word - video page size in bytes
    58                                  video_page_offt     equ 0x4E    ; word - active video page offset
    59                                  video_cur_pos       equ 0x50    ; byte[16] - cursor pos per page
    60                                  video_cur_shape     equ 0x60    ; word - cursor shape
    61                                  video_page          equ 0x62    ; byte - active video page
    62                                  video_port          equ 0x63    ; word - CRT controller port
    63                                  ticks_lo            equ 0x6C    ; word - timer ticks low
    64                                  ticks_hi            equ 0x6E    ; word - timer ticks high
    65                                  new_day             equ 0x70    ; byte - midnight flag
    66                                  break_flag          equ 0x71    ; byte - Ctrl-Break flag
    67                                  warm_boot           equ 0x72    ; word - warm boot flag (1234h)
    68                                  kbd_buffer_start    equ 0x80    ; word - keyboard buffer start
    69                                  kbd_buffer_end      equ 0x82    ; word - keyboard buffer end
    70                                  video_rows          equ 0x84    ; byte - text rows minus 1
    71                                  video_char_height   equ 0x85    ; word - character height (points)
    72                                  
    73                                  ; ============================================================
    74                                  ; INT 10h — Video Services
    75                                  ; ============================================================
    76                                  int10h_handler:
    77 00000000 1E                          push ds
    78 00000001 06                          push es
    79 00000002 55                          push bp
    80 00000003 80FC0E                      cmp ah, 0x0E
    81 00000006 7403                        je .teletype
    82 00000008 E98800                      jmp .dispatch_other
    83                                  
    84                                  ; --- AH=0Eh: Teletype output ---
    85                                  .teletype:
    86 0000000B 57                          push di
    87 0000000C 53                          push bx
    88 0000000D 51                          push cx
    89 0000000E 52                          push dx
    90 0000000F 50                          push ax                ; save character in AL
    91                                  
    92                                      ; Read cursor from BDA
    93 00000010 BB4000                      mov bx, BDA_SEG
    94 00000013 8EDB                        mov ds, bx
    95 00000015 8A165000                    mov dl, [video_cur_pos]     ; column
    96 00000019 8A365100                    mov dh, [video_cur_pos+1]   ; row
    97                                  
    98 0000001D 58                          pop ax                 ; AX restored (AL = character)
    99 0000001E 50                          push ax                ; save again
   100                                  
   101 0000001F 3C0D                        cmp al, 13
   102 00000021 7444                        je .tty_cr
   103 00000023 3C0A                        cmp al, 10
   104 00000025 7444                        je .tty_lf
   105 00000027 3C08                        cmp al, 8
   106 00000029 744E                        je .tty_bs
   107 0000002B 3C07                        cmp al, 7
   108 0000002D 745B                        je .tty_done
   109                                  
   110                                      ; Compute VGA offset = (row*80+col)*2
   111 0000002F 50                          push ax                ; save char
   112 00000030 52                          push dx                ; save cursor
   113 00000031 88F0                        mov al, dh
   114 00000033 B350                        mov bl, 80
   115 00000035 F6E3                        mul bl                 ; AX = row*80
   116 00000037 30FF                        xor bh, bh
   117 00000039 88D3                        mov bl, dl
   118 0000003B 01D8                        add ax, bx             ; AX = row*80+col
   119 0000003D D1E0                        shl ax, 1              ; AX = (row*80+col)*2
   120 0000003F 89C7                        mov di, ax
   121 00000041 5A                          pop dx                 ; restore cursor
   122 00000042 58                          pop ax                 ; restore char
   123                                  
   124                                      ; Write to VGA
   125 00000043 1E                          push ds
   126 00000044 BB00B8                      mov bx, VGA_SEG
   127 00000047 8EDB                        mov ds, bx
   128 00000049 8805                        mov [di], al           ; character
   129 0000004B C6450107                    mov byte [di+1], 0x07  ; attribute
   130 0000004F 1F                          pop ds
   131                                  
   132                                      ; Advance cursor
   133 00000050 FEC2                        inc dl
   134 00000052 80FA50                      cmp dl, 80
   135 00000055 722B                        jb .tty_save
   136 00000057 30D2                        xor dl, dl
   137 00000059 FEC6                        inc dh
   138 0000005B 80FE19                      cmp dh, 25
   139 0000005E 7222                        jb .tty_save
   140 00000060 FECE                        dec dh
   141 00000062 E8E301                      call scroll_up_one
   142 00000065 EB1B                        jmp short .tty_save
   143                                  
   144                                  .tty_cr:
   145 00000067 30D2                        xor dl, dl
   146 00000069 EB17                        jmp short .tty_save
   147                                  
   148                                  .tty_lf:
   149 0000006B FEC6                        inc dh
   150 0000006D 80FE19                      cmp dh, 25
   151 00000070 7210                        jb .tty_save
   152 00000072 FECE                        dec dh
   153 00000074 E8D101                      call scroll_up_one
   154 00000077 EB09                        jmp short .tty_save
   155                                  
   156                                  .tty_bs:
   157 00000079 80FA00                      cmp dl, 0
   158 0000007C 7404                        je .tty_save
   159 0000007E FECA                        dec dl
   160 00000080 EB00                        jmp short .tty_save
   161                                  
   162                                  .tty_save:
   163 00000082 88165000                    mov [video_cur_pos], dl
   164 00000086 88365100                    mov [video_cur_pos+1], dh
   165                                  
   166                                  .tty_done:
   167 0000008A 58                          pop ax
   168 0000008B 5A                          pop dx
   169 0000008C 59                          pop cx
   170 0000008D 5B                          pop bx
   171 0000008E 5F                          pop di
   172 0000008F 5D                          pop bp
   173 00000090 07                          pop es
   174 00000091 1F                          pop ds
   175 00000092 CF                          iret
   176                                  
   177                                  ; --- INT 10h dispatch for non-teletype ---
   178                                  .dispatch_other:
   179 00000093 80FC02                      cmp ah, 0x02
   180 00000096 743B                        je .set_cursor
   181 00000098 80FC03                      cmp ah, 0x03
   182 0000009B 7447                        je .get_cursor
   183 0000009D 80FC00                      cmp ah, 0x00
   184 000000A0 7477                        je .set_mode
   185 000000A2 80FC0F                      cmp ah, 0x0F
   186 000000A5 7452                        je .get_mode
   187 000000A7 80FC06                      cmp ah, 0x06
   188 000000AA 7503                        jne .not_scroll_up
   189 000000AC E99F00                      jmp .scroll_up
   190                                  .not_scroll_up:
   191 000000AF 80FC07                      cmp ah, 0x07
   192 000000B2 7503                        jne .not_scroll_down
   193 000000B4 E9C900                      jmp .scroll_down
   194                                  .not_scroll_down:
   195 000000B7 80FC08                      cmp ah, 0x08
   196 000000BA 7503                        jne .not_read_char
   197 000000BC E9E200                      jmp .read_char
   198                                  .not_read_char:
   199 000000BF 80FC09                      cmp ah, 0x09
   200 000000C2 7503                        jne .not_write_char
   201 000000C4 E90C01                      jmp .write_char_attr
   202                                  .not_write_char:
   203 000000C7 80FC0A                      cmp ah, 0x0A
   204 000000CA 7503                        jne .not_write_char_only
   205 000000CC E94101                      jmp .write_char_only
   206                                  .not_write_char_only:
   207 000000CF 5D                          pop bp
   208 000000D0 07                          pop es
   209 000000D1 1F                          pop ds
   210 000000D2 CF                          iret
   211                                  
   212                                  .set_cursor:
   213 000000D3 BB4000                      mov bx, BDA_SEG
   214 000000D6 8EDB                        mov ds, bx
   215 000000D8 88165000                    mov [video_cur_pos], dl
   216 000000DC 88365100                    mov [video_cur_pos+1], dh
   217 000000E0 5D                          pop bp
   218 000000E1 07                          pop es
   219 000000E2 1F                          pop ds
   220 000000E3 CF                          iret
   221                                  
   222                                  .get_cursor:
   223 000000E4 BB4000                      mov bx, BDA_SEG
   224 000000E7 8EDB                        mov ds, bx
   225 000000E9 8A165000                    mov dl, [video_cur_pos]
   226 000000ED 8A365100                    mov dh, [video_cur_pos+1]
   227 000000F1 8B0E6000                    mov cx, [video_cur_shape]
   228 000000F5 5D                          pop bp
   229 000000F6 07                          pop es
   230 000000F7 1F                          pop ds
   231 000000F8 CF                          iret
   232                                  
   233                                  .get_mode:
   234 000000F9 53                          push bx
   235 000000FA BB4000                      mov bx, BDA_SEG
   236 000000FD 8EDB                        mov ds, bx
   237 000000FF A04900                      mov al, [video_mode]
   238 00000102 8A264A00                    mov ah, [video_columns]
   239 00000106 8A3E6200                    mov bh, [video_page]
   240                                      ; BH is return value, but we pushed original BX
   241                                      ; Need to fix this: pop old BX but keep BH
   242 0000010A 88FB                        mov bl, bh              ; save page in BL
   243 0000010C 5B                          pop bx                  ; restore original BX
   244 0000010D 88DF                        mov bh, bl              ; but no, that clobbers... let's just not push BX
   245                                      ; Actually simpler approach: just return hardcoded for mode 3
   246 0000010F 5D                          pop bp
   247 00000110 07                          pop es
   248 00000111 1F                          pop ds
   249 00000112 B003                        mov al, 0x03
   250 00000114 B450                        mov ah, 80
   251 00000116 B700                        mov bh, 0
   252 00000118 CF                          iret
   253                                  
   254                                  .set_mode:
   255 00000119 57                          push di
   256 0000011A 51                          push cx
   257 0000011B 50                          push ax
   258 0000011C B84000                      mov ax, BDA_SEG
   259 0000011F 8ED8                        mov ds, ax
   260 00000121 C606500000                  mov byte [video_cur_pos], 0
   261 00000126 C606510000                  mov byte [video_cur_pos+1], 0
   262 0000012B C606490003                  mov byte [video_mode], 0x03
   263                                      ; Clear screen
   264 00000130 B800B8                      mov ax, VGA_SEG
   265 00000133 8ED8                        mov ds, ax
   266 00000135 31FF                        xor di, di
   267 00000137 B9D007                      mov cx, 2000
   268 0000013A B82007                      mov ax, 0x0720
   269                                  .clr_loop:
   270 0000013D 8905                        mov [di], ax
   271 0000013F 83C702                      add di, 2
   272 00000142 49                          dec cx
   273 00000143 75F8                        jnz .clr_loop
   274 00000145 58                          pop ax
   275 00000146 B030                        mov al, 0x30           ; return prior mode info
   276 00000148 59                          pop cx
   277 00000149 5F                          pop di
   278 0000014A 5D                          pop bp
   279 0000014B 07                          pop es
   280 0000014C 1F                          pop ds
   281 0000014D CF                          iret
   282                                  
   283                                  .scroll_up:
   284 0000014E 3C00                        cmp al, 0
   285 00000150 751D                        jne .su_lines
   286                                      ; AL=0: Clear window
   287 00000152 57                          push di
   288 00000153 51                          push cx
   289 00000154 B900B8                      mov cx, VGA_SEG
   290 00000157 8ED9                        mov ds, cx
   291 00000159 31FF                        xor di, di
   292 0000015B B9D007                      mov cx, 2000
   293 0000015E B82007                      mov ax, 0x0720
   294                                  .su_clr:
   295 00000161 8905                        mov [di], ax
   296 00000163 83C702                      add di, 2
   297 00000166 49                          dec cx
   298 00000167 75F8                        jnz .su_clr
   299 00000169 59                          pop cx
   300 0000016A 5F                          pop di
   301 0000016B 5D                          pop bp
   302 0000016C 07                          pop es
   303 0000016D 1F                          pop ds
   304 0000016E CF                          iret
   305                                  .su_lines:
   306 0000016F 51                          push cx
   307 00000170 88C1                        mov cl, al
   308 00000172 30ED                        xor ch, ch
   309                                  .su_loop:
   310 00000174 E8D100                      call scroll_up_one
   311 00000177 FEC9                        dec cl
   312 00000179 75F9                        jnz .su_loop
   313 0000017B 59                          pop cx
   314 0000017C 5D                          pop bp
   315 0000017D 07                          pop es
   316 0000017E 1F                          pop ds
   317 0000017F CF                          iret
   318                                  
   319                                  .scroll_down:
   320 00000180 3C00                        cmp al, 0
   321 00000182 7519                        jne .sd_ret
   322 00000184 57                          push di
   323 00000185 51                          push cx
   324 00000186 B900B8                      mov cx, VGA_SEG
   325 00000189 8ED9                        mov ds, cx
   326 0000018B 31FF                        xor di, di
   327 0000018D B9D007                      mov cx, 2000
   328 00000190 B82007                      mov ax, 0x0720
   329                                  .sd_clr:
   330 00000193 8905                        mov [di], ax
   331 00000195 83C702                      add di, 2
   332 00000198 49                          dec cx
   333 00000199 75F8                        jnz .sd_clr
   334 0000019B 59                          pop cx
   335 0000019C 5F                          pop di
   336                                  .sd_ret:
   337 0000019D 5D                          pop bp
   338 0000019E 07                          pop es
   339 0000019F 1F                          pop ds
   340 000001A0 CF                          iret
   341                                  
   342                                  .read_char:
   343                                      ; AH=08h: Read char+attr at cursor
   344 000001A1 53                          push bx
   345 000001A2 57                          push di
   346 000001A3 BB4000                      mov bx, BDA_SEG
   347 000001A6 8EDB                        mov ds, bx
   348 000001A8 A05000                      mov al, [video_cur_pos]     ; col
   349 000001AB 8A265100                    mov ah, [video_cur_pos+1]   ; row
   350 000001AF 52                          push dx
   351 000001B0 30F6                        xor dh, dh
   352 000001B2 88E2                        mov dl, ah
   353 000001B4 B450                        mov ah, 80
   354 000001B6 86C2                        xchg al, dl
   355 000001B8 F6E4                        mul ah
   356 000001BA 30F6                        xor dh, dh
   357 000001BC 01D0                        add ax, dx
   358 000001BE D1E0                        shl ax, 1
   359 000001C0 89C7                        mov di, ax
   360 000001C2 5A                          pop dx
   361 000001C3 BB00B8                      mov bx, VGA_SEG
   362 000001C6 8EDB                        mov ds, bx
   363 000001C8 8A05                        mov al, [di]           ; character
   364 000001CA 8A6501                      mov ah, [di+1]         ; attribute
   365 000001CD 5F                          pop di
   366 000001CE 5B                          pop bx
   367 000001CF 5D                          pop bp
   368 000001D0 07                          pop es
   369 000001D1 1F                          pop ds
   370 000001D2 CF                          iret
   371                                  
   372                                  .write_char_attr:
   373                                      ; AH=09h: Write char+attr at cursor, CX times
   374                                      ; AL=char, BL=attr, CX=count
   375 000001D3 57                          push di
   376 000001D4 52                          push dx
   377 000001D5 51                          push cx
   378 000001D6 53                          push bx
   379 000001D7 BB4000                      mov bx, BDA_SEG
   380 000001DA 8EDB                        mov ds, bx
   381 000001DC 8A165000                    mov dl, [video_cur_pos]
   382 000001E0 8A365100                    mov dh, [video_cur_pos+1]
   383 000001E4 50                          push ax
   384 000001E5 88F0                        mov al, dh
   385 000001E7 B350                        mov bl, 80
   386 000001E9 F6E3                        mul bl
   387 000001EB 30FF                        xor bh, bh
   388 000001ED 88D3                        mov bl, dl
   389 000001EF 01D8                        add ax, bx
   390 000001F1 D1E0                        shl ax, 1
   391 000001F3 89C7                        mov di, ax
   392 000001F5 58                          pop ax
   393 000001F6 BB00B8                      mov bx, VGA_SEG
   394 000001F9 8EDB                        mov ds, bx
   395 000001FB 5B                          pop bx                 ; restore original BX (BL=attr)
   396 000001FC 53                          push bx
   397                                  .wca_loop:
   398 000001FD 8805                        mov [di], al
   399 000001FF 885D01                      mov [di+1], bl
   400 00000202 83C702                      add di, 2
   401 00000205 49                          dec cx
   402 00000206 75F5                        jnz .wca_loop
   403 00000208 5B                          pop bx
   404 00000209 59                          pop cx
   405 0000020A 5A                          pop dx
   406 0000020B 5F                          pop di
   407 0000020C 5D                          pop bp
   408 0000020D 07                          pop es
   409 0000020E 1F                          pop ds
   410 0000020F CF                          iret
