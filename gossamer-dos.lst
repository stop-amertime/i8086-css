     1                                  ; gossamer-dos.asm — Gossamer BIOS (DOS variant) for CSS-DOS
     2                                  ; Loaded at F000:0000 (linear 0xF0000)
     3                                  ;
     4                                  ; Mirrors the 8088_bios reference layout:
     5                                  ;   - IVT setup via interrupt_table array (32 standard vectors + fill rest)
     6                                  ;   - Full BDA initialization matching IBM PC BIOS
     7                                  ;   - INT handlers follow reference contracts
     8                                  ;
     9                                  ; Backend is memory-mapped (no port I/O):
    10                                  ;   - VGA text buffer at B800:0000
    11                                  ;   - Disk image at D000:0000
    12                                  ;   - Keyboard input via polling 0000:0500
    13                                  ;
    14                                  ; DOS kernel (KERNEL.SYS) is pre-loaded at 0060:0000 (linear 0x600)
    15                                  ; by the transpiler. The BIOS init code sets up the IVT and jumps to it.
    16                                  ;
    17                                  ; CONSTRAINTS (CSS transpiler limitations):
    18                                  ; - No 0x0F-prefixed opcodes (near Jcc)
    19                                  ; - Must compile with NASM: [bits 16] [org 0]
    20                                  
    21                                  [bits 16]
    22                                  [org 0]
    23                                  
    24                                  ; ============================================================
    25                                  ; Constants
    26                                  ; ============================================================
    27                                  DISK_SEG    equ 0xD000          ; Disk image loaded here (linear 0xD0000)
    28                                  BDA_SEG     equ 0x0040          ; BIOS Data Area segment
    29                                  BIOS_SEG    equ 0xF000          ; BIOS code segment
    30                                  VGA_SEG     equ 0xB800          ; VGA text mode segment
    31                                  KERNEL_SEG  equ 0x0060          ; DOS kernel load segment
    32                                  SECTOR_SIZE equ 512
    33                                  HALT_ADDR   equ 0x0504          ; Halt flag address (seg 0)
    34                                  
    35                                  ; Disk geometry for a 1.44MB floppy
    36                                  DISK_SPT    equ 18              ; sectors per track
    37                                  DISK_HEADS  equ 2               ; heads
    38                                  DISK_CYLS   equ 80              ; cylinders
    39                                  
    40                                  ; BDA offsets (matching reference 8088_bios exactly)
    41                                  equip_serial        equ 0x00    ; word[4] - serial port addresses
    42                                  equip_parallel      equ 0x08   ; word[3] - parallel port addresses
    43                                  equipment_list      equ 0x10    ; word - equipment list
    44                                  memory_size         equ 0x13    ; word - memory size in KiB
    45                                  kbd_flags_1         equ 0x17    ; byte - keyboard shift flags 1
    46                                  kbd_flags_2         equ 0x18    ; byte - keyboard shift flags 2
    47                                  kbd_alt_keypad      equ 0x19    ; byte - Alt+Numpad work area
    48                                  kbd_buffer_head     equ 0x1A    ; word - keyboard buffer head offset
    49                                  kbd_buffer_tail     equ 0x1C    ; word - keyboard buffer tail offset
    50                                  kbd_buffer          equ 0x1E    ; byte[32] - keyboard buffer
    51                                  fdc_calib_state     equ 0x3E    ; byte - floppy recalibration status
    52                                  fdc_motor_state     equ 0x3F    ; byte - floppy motor status
    53                                  fdc_motor_tout      equ 0x40    ; byte - floppy motor off timeout
    54                                  fdc_last_error      equ 0x41    ; byte - last diskette op status
    55                                  video_mode          equ 0x49    ; byte - active video mode
    56                                  video_columns       equ 0x4A    ; word - text columns
    57                                  video_page_size     equ 0x4C    ; word - video page size in bytes
    58                                  video_page_offt     equ 0x4E    ; word - active video page offset
    59                                  video_cur_pos       equ 0x50    ; byte[16] - cursor pos per page
    60                                  video_cur_shape     equ 0x60    ; word - cursor shape
    61                                  video_page          equ 0x62    ; byte - active video page
    62                                  video_port          equ 0x63    ; word - CRT controller port
    63                                  ticks_lo            equ 0x6C    ; word - timer ticks low
    64                                  ticks_hi            equ 0x6E    ; word - timer ticks high
    65                                  new_day             equ 0x70    ; byte - midnight flag
    66                                  break_flag          equ 0x71    ; byte - Ctrl-Break flag
    67                                  warm_boot           equ 0x72    ; word - warm boot flag (1234h)
    68                                  kbd_buffer_start    equ 0x80    ; word - keyboard buffer start
    69                                  kbd_buffer_end      equ 0x82    ; word - keyboard buffer end
    70                                  video_rows          equ 0x84    ; byte - text rows minus 1
    71                                  video_char_height   equ 0x85    ; word - character height (points)
    72                                  
    73                                  ; ============================================================
    74                                  ; INT 10h — Video Services
    75                                  ; ============================================================
    76                                  int10h_handler:
    77 00000000 1E                          push ds
    78 00000001 06                          push es
    79 00000002 55                          push bp
    80 00000003 80FC0E                      cmp ah, 0x0E
    81 00000006 7403                        je .teletype
    82 00000008 E98800                      jmp .dispatch_other
    83                                  
    84                                  ; --- AH=0Eh: Teletype output ---
    85                                  .teletype:
    86 0000000B 57                          push di
    87 0000000C 53                          push bx
    88 0000000D 51                          push cx
    89 0000000E 52                          push dx
    90 0000000F 50                          push ax                ; save character in AL
    91                                  
    92                                      ; Read cursor from BDA
    93 00000010 BB4000                      mov bx, BDA_SEG
    94 00000013 8EDB                        mov ds, bx
    95 00000015 8A165000                    mov dl, [video_cur_pos]     ; column
    96 00000019 8A365100                    mov dh, [video_cur_pos+1]   ; row
    97                                  
    98 0000001D 58                          pop ax                 ; AX restored (AL = character)
    99 0000001E 50                          push ax                ; save again
   100                                  
   101 0000001F 3C0D                        cmp al, 13
   102 00000021 7444                        je .tty_cr
   103 00000023 3C0A                        cmp al, 10
   104 00000025 7444                        je .tty_lf
   105 00000027 3C08                        cmp al, 8
   106 00000029 744E                        je .tty_bs
   107 0000002B 3C07                        cmp al, 7
   108 0000002D 745B                        je .tty_done
   109                                  
   110                                      ; Compute VGA offset = (row*80+col)*2
   111 0000002F 50                          push ax                ; save char
   112 00000030 52                          push dx                ; save cursor
   113 00000031 88F0                        mov al, dh
   114 00000033 B350                        mov bl, 80
   115 00000035 F6E3                        mul bl                 ; AX = row*80
   116 00000037 30FF                        xor bh, bh
   117 00000039 88D3                        mov bl, dl
   118 0000003B 01D8                        add ax, bx             ; AX = row*80+col
   119 0000003D D1E0                        shl ax, 1              ; AX = (row*80+col)*2
   120 0000003F 89C7                        mov di, ax
   121 00000041 5A                          pop dx                 ; restore cursor
   122 00000042 58                          pop ax                 ; restore char
   123                                  
   124                                      ; Write to VGA
   125 00000043 1E                          push ds
   126 00000044 BB00B8                      mov bx, VGA_SEG
   127 00000047 8EDB                        mov ds, bx
   128 00000049 8805                        mov [di], al           ; character
   129 0000004B C6450107                    mov byte [di+1], 0x07  ; attribute
   130 0000004F 1F                          pop ds
   131                                  
   132                                      ; Advance cursor
   133 00000050 FEC2                        inc dl
   134 00000052 80FA50                      cmp dl, 80
   135 00000055 722B                        jb .tty_save
   136 00000057 30D2                        xor dl, dl
   137 00000059 FEC6                        inc dh
   138 0000005B 80FE19                      cmp dh, 25
   139 0000005E 7222                        jb .tty_save
   140 00000060 FECE                        dec dh
   141 00000062 E80F02                      call scroll_up_one
   142 00000065 EB1B                        jmp short .tty_save
   143                                  
   144                                  .tty_cr:
   145 00000067 30D2                        xor dl, dl
   146 00000069 EB17                        jmp short .tty_save
   147                                  
   148                                  .tty_lf:
   149 0000006B FEC6                        inc dh
   150 0000006D 80FE19                      cmp dh, 25
   151 00000070 7210                        jb .tty_save
   152 00000072 FECE                        dec dh
   153 00000074 E8FD01                      call scroll_up_one
   154 00000077 EB09                        jmp short .tty_save
   155                                  
   156                                  .tty_bs:
   157 00000079 80FA00                      cmp dl, 0
   158 0000007C 7404                        je .tty_save
   159 0000007E FECA                        dec dl
   160 00000080 EB00                        jmp short .tty_save
   161                                  
   162                                  .tty_save:
   163 00000082 88165000                    mov [video_cur_pos], dl
   164 00000086 88365100                    mov [video_cur_pos+1], dh
   165                                  
   166                                  .tty_done:
   167 0000008A 58                          pop ax
   168 0000008B 5A                          pop dx
   169 0000008C 59                          pop cx
   170 0000008D 5B                          pop bx
   171 0000008E 5F                          pop di
   172 0000008F 5D                          pop bp
   173 00000090 07                          pop es
   174 00000091 1F                          pop ds
   175 00000092 CF                          iret
   176                                  
   177                                  ; --- INT 10h dispatch for non-teletype ---
   178                                  .dispatch_other:
   179 00000093 80FC02                      cmp ah, 0x02
   180 00000096 7442                        je .set_cursor
   181 00000098 80FC03                      cmp ah, 0x03
   182 0000009B 744E                        je .get_cursor
   183 0000009D 80FC00                      cmp ah, 0x00
   184 000000A0 7472                        je .set_mode
   185 000000A2 80FC0F                      cmp ah, 0x0F
   186 000000A5 7459                        je .get_mode
   187 000000A7 80FC06                      cmp ah, 0x06
   188 000000AA 7503                        jne .not_scroll_up
   189 000000AC E9B600                      jmp .scroll_up
   190                                  .not_scroll_up:
   191 000000AF 80FC07                      cmp ah, 0x07
   192 000000B2 7503                        jne .not_scroll_down
   193 000000B4 E9E000                      jmp .scroll_down
   194                                  .not_scroll_down:
   195 000000B7 80FC08                      cmp ah, 0x08
   196 000000BA 7503                        jne .not_read_char
   197 000000BC E9F900                      jmp .read_char
   198                                  .not_read_char:
   199 000000BF 80FC09                      cmp ah, 0x09
   200 000000C2 7503                        jne .not_write_char
   201 000000C4 E92301                      jmp .write_char_attr
   202                                  .not_write_char:
   203 000000C7 80FC0A                      cmp ah, 0x0A
   204 000000CA 7503                        jne .not_write_char_only
   205 000000CC E95801                      jmp .write_char_only
   206                                  .not_write_char_only:
   207 000000CF 80FC1A                      cmp ah, 0x1A
   208 000000D2 0F848901                    je .get_display_combo
   209 000000D6 5D                          pop bp
   210 000000D7 07                          pop es
   211 000000D8 1F                          pop ds
   212 000000D9 CF                          iret
   213                                  
   214                                  .set_cursor:
   215 000000DA BB4000                      mov bx, BDA_SEG
   216 000000DD 8EDB                        mov ds, bx
   217 000000DF 88165000                    mov [video_cur_pos], dl
   218 000000E3 88365100                    mov [video_cur_pos+1], dh
   219 000000E7 5D                          pop bp
   220 000000E8 07                          pop es
   221 000000E9 1F                          pop ds
   222 000000EA CF                          iret
   223                                  
   224                                  .get_cursor:
   225 000000EB BB4000                      mov bx, BDA_SEG
   226 000000EE 8EDB                        mov ds, bx
   227 000000F0 8A165000                    mov dl, [video_cur_pos]
   228 000000F4 8A365100                    mov dh, [video_cur_pos+1]
   229 000000F8 8B0E6000                    mov cx, [video_cur_shape]
   230 000000FC 5D                          pop bp
   231 000000FD 07                          pop es
   232 000000FE 1F                          pop ds
   233 000000FF CF                          iret
   234                                  
   235                                  .get_mode:
   236 00000100 BB4000                      mov bx, BDA_SEG
   237 00000103 8EDB                        mov ds, bx
   238 00000105 A04900                      mov al, [video_mode]
   239 00000108 8A264A00                    mov ah, [video_columns]
   240 0000010C 8A3E6200                    mov bh, [video_page]
   241 00000110 5D                          pop bp
   242 00000111 07                          pop es
   243 00000112 1F                          pop ds
   244 00000113 CF                          iret
   245                                  
   246                                  .set_mode:
   247                                      ; Store requested mode in BDA and reset cursor
   248 00000114 57                          push di
   249 00000115 51                          push cx
   250 00000116 B94000                      mov cx, BDA_SEG
   251 00000119 8ED9                        mov ds, cx
   252 0000011B C606500000                  mov byte [video_cur_pos], 0
   253 00000120 C606510000                  mov byte [video_cur_pos+1], 0
   254                                      ; Only store modes we actually support; map anything else to 0x03.
   255 00000125 3C13                        cmp al, 0x13
   256 00000127 7402                        je .set_mode_store
   257 00000129 B003                        mov al, 0x03
   258                                  .set_mode_store:
   259 0000012B A24900                      mov [video_mode], al
   260 0000012E 3C13                        cmp al, 0x13
   261 00000130 7417                        je .set_mode_13h
   262                                      ; --- Text mode: clear 80x25 text buffer at 0xB8000 ---
   263 00000132 B800B8                      mov ax, VGA_SEG
   264 00000135 8ED8                        mov ds, ax
   265 00000137 31FF                        xor di, di
   266 00000139 B9D007                      mov cx, 2000
   267 0000013C B82007                      mov ax, 0x0720
   268                                  .clr_loop:
   269 0000013F 8905                        mov [di], ax
   270 00000141 83C702                      add di, 2
   271 00000144 49                          dec cx
   272 00000145 75F8                        jnz .clr_loop
   273 00000147 EB14                        jmp short .set_mode_done
   274                                  .set_mode_13h:
   275                                      ; --- Mode 13h: clear 320x200 framebuffer at 0xA0000 ---
   276 00000149 B800A0                      mov ax, 0xA000
   277 0000014C 8ED8                        mov ds, ax
   278 0000014E 31FF                        xor di, di
   279 00000150 B9007D                      mov cx, 32000
   280 00000153 31C0                        xor ax, ax
   281                                  .clr13_loop:
   282 00000155 8905                        mov [di], ax
   283 00000157 83C702                      add di, 2
   284 0000015A 49                          dec cx
   285 0000015B 75F8                        jnz .clr13_loop
   286                                  .set_mode_done:
   287 0000015D 59                          pop cx
   288 0000015E 5F                          pop di
   289 0000015F B030                        mov al, 0x30
   290 00000161 5D                          pop bp
   291 00000162 07                          pop es
   292 00000163 1F                          pop ds
   293 00000164 CF                          iret
   294                                  
   295                                  .scroll_up:
   296 00000165 3C00                        cmp al, 0
   297 00000167 751D                        jne .su_lines
   298                                      ; AL=0: Clear window
   299 00000169 57                          push di
   300 0000016A 51                          push cx
   301 0000016B B900B8                      mov cx, VGA_SEG
   302 0000016E 8ED9                        mov ds, cx
   303 00000170 31FF                        xor di, di
   304 00000172 B9D007                      mov cx, 2000
   305 00000175 B82007                      mov ax, 0x0720
   306                                  .su_clr:
   307 00000178 8905                        mov [di], ax
   308 0000017A 83C702                      add di, 2
   309 0000017D 49                          dec cx
   310 0000017E 75F8                        jnz .su_clr
   311 00000180 59                          pop cx
   312 00000181 5F                          pop di
   313 00000182 5D                          pop bp
   314 00000183 07                          pop es
   315 00000184 1F                          pop ds
   316 00000185 CF                          iret
   317                                  .su_lines:
   318 00000186 51                          push cx
   319 00000187 88C1                        mov cl, al
   320 00000189 30ED                        xor ch, ch
   321                                  .su_loop:
   322 0000018B E8E600                      call scroll_up_one
   323 0000018E FEC9                        dec cl
   324 00000190 75F9                        jnz .su_loop
   325 00000192 59                          pop cx
   326 00000193 5D                          pop bp
   327 00000194 07                          pop es
   328 00000195 1F                          pop ds
   329 00000196 CF                          iret
   330                                  
   331                                  .scroll_down:
   332 00000197 3C00                        cmp al, 0
   333 00000199 7519                        jne .sd_ret
   334 0000019B 57                          push di
   335 0000019C 51                          push cx
   336 0000019D B900B8                      mov cx, VGA_SEG
   337 000001A0 8ED9                        mov ds, cx
   338 000001A2 31FF                        xor di, di
   339 000001A4 B9D007                      mov cx, 2000
   340 000001A7 B82007                      mov ax, 0x0720
   341                                  .sd_clr:
   342 000001AA 8905                        mov [di], ax
   343 000001AC 83C702                      add di, 2
   344 000001AF 49                          dec cx
   345 000001B0 75F8                        jnz .sd_clr
   346 000001B2 59                          pop cx
   347 000001B3 5F                          pop di
   348                                  .sd_ret:
   349 000001B4 5D                          pop bp
   350 000001B5 07                          pop es
   351 000001B6 1F                          pop ds
   352 000001B7 CF                          iret
   353                                  
   354                                  .read_char:
   355                                      ; AH=08h: Read char+attr at cursor
   356 000001B8 53                          push bx
   357 000001B9 57                          push di
   358 000001BA BB4000                      mov bx, BDA_SEG
   359 000001BD 8EDB                        mov ds, bx
   360 000001BF A05000                      mov al, [video_cur_pos]     ; col
   361 000001C2 8A265100                    mov ah, [video_cur_pos+1]   ; row
   362 000001C6 52                          push dx
   363 000001C7 30F6                        xor dh, dh
   364 000001C9 88E2                        mov dl, ah
   365 000001CB B450                        mov ah, 80
   366 000001CD 86C2                        xchg al, dl
   367 000001CF F6E4                        mul ah
   368 000001D1 30F6                        xor dh, dh
   369 000001D3 01D0                        add ax, dx
   370 000001D5 D1E0                        shl ax, 1
   371 000001D7 89C7                        mov di, ax
   372 000001D9 5A                          pop dx
   373 000001DA BB00B8                      mov bx, VGA_SEG
   374 000001DD 8EDB                        mov ds, bx
   375 000001DF 8A05                        mov al, [di]           ; character
   376 000001E1 8A6501                      mov ah, [di+1]         ; attribute
   377 000001E4 5F                          pop di
   378 000001E5 5B                          pop bx
   379 000001E6 5D                          pop bp
   380 000001E7 07                          pop es
   381 000001E8 1F                          pop ds
   382 000001E9 CF                          iret
   383                                  
   384                                  .write_char_attr:
   385                                      ; AH=09h: Write char+attr at cursor, CX times
   386                                      ; AL=char, BL=attr, CX=count
   387 000001EA 57                          push di
   388 000001EB 52                          push dx
   389 000001EC 51                          push cx
   390 000001ED 53                          push bx
   391 000001EE BB4000                      mov bx, BDA_SEG
   392 000001F1 8EDB                        mov ds, bx
   393 000001F3 8A165000                    mov dl, [video_cur_pos]
   394 000001F7 8A365100                    mov dh, [video_cur_pos+1]
   395 000001FB 50                          push ax
   396 000001FC 88F0                        mov al, dh
   397 000001FE B350                        mov bl, 80
   398 00000200 F6E3                        mul bl
   399 00000202 30FF                        xor bh, bh
   400 00000204 88D3                        mov bl, dl
   401 00000206 01D8                        add ax, bx
   402 00000208 D1E0                        shl ax, 1
   403 0000020A 89C7                        mov di, ax
   404 0000020C 58                          pop ax
   405 0000020D BB00B8                      mov bx, VGA_SEG
   406 00000210 8EDB                        mov ds, bx
   407 00000212 5B                          pop bx                 ; restore original BX (BL=attr)
   408 00000213 53                          push bx
   409                                  .wca_loop:
   410 00000214 8805                        mov [di], al
   411 00000216 885D01                      mov [di+1], bl
   412 00000219 83C702                      add di, 2
   413 0000021C 49                          dec cx
   414 0000021D 75F5                        jnz .wca_loop
   415 0000021F 5B                          pop bx
   416 00000220 59                          pop cx
   417 00000221 5A                          pop dx
   418 00000222 5F                          pop di
   419 00000223 5D                          pop bp
   420 00000224 07                          pop es
   421 00000225 1F                          pop ds
   422 00000226 CF                          iret
   423                                  
   424                                  .write_char_only:
   425                                      ; AH=0Ah: Write char at cursor, CX times (keep existing attr)
   426                                      ; AL=char, CX=count
   427 00000227 57                          push di
   428 00000228 52                          push dx
   429 00000229 51                          push cx
   430 0000022A 53                          push bx
   431 0000022B BB4000                      mov bx, BDA_SEG
   432 0000022E 8EDB                        mov ds, bx
   433 00000230 8A165000                    mov dl, [video_cur_pos]
   434 00000234 8A365100                    mov dh, [video_cur_pos+1]
   435 00000238 50                          push ax
   436 00000239 88F0                        mov al, dh
   437 0000023B B350                        mov bl, 80
   438 0000023D F6E3                        mul bl
   439 0000023F 30FF                        xor bh, bh
   440 00000241 88D3                        mov bl, dl
   441 00000243 01D8                        add ax, bx
   442 00000245 D1E0                        shl ax, 1
   443 00000247 89C7                        mov di, ax
   444 00000249 58                          pop ax
   445 0000024A BB00B8                      mov bx, VGA_SEG
   446 0000024D 8EDB                        mov ds, bx
   447                                  .wco_loop:
   448 0000024F 8805                        mov [di], al           ; write char only, keep attribute
   449 00000251 83C702                      add di, 2
   450 00000254 49                          dec cx
   451 00000255 75F8                        jnz .wco_loop
   452 00000257 5B                          pop bx
   453 00000258 59                          pop cx
   454 00000259 5A                          pop dx
   455 0000025A 5F                          pop di
   456 0000025B 5D                          pop bp
   457 0000025C 07                          pop es
   458 0000025D 1F                          pop ds
   459 0000025E CF                          iret
   460                                  
   461                                  .get_display_combo:
   462                                      ; AH=1Ah: Get/Set Display Combination Code
   463                                      ; Return VGA color (0x08) — programs use this to detect VGA.
   464 0000025F 80FB00                      cmp bl, 0
   465 00000262 750A                        jne .dcc_set
   466                                      ; BL=00h: Get DCC
   467 00000264 B308                        mov bl, 0x08            ; active display: VGA color
   468 00000266 B700                        mov bh, 0x00            ; inactive: none
   469 00000268 5D                          pop bp
   470 00000269 07                          pop es
   471 0000026A 1F                          pop ds
   472 0000026B B01A                        mov al, 0x1A            ; confirm function supported
   473 0000026D CF                          iret
   474                                  .dcc_set:
   475                                      ; BL!=0: Set DCC — ignore but confirm
   476 0000026E 5D                          pop bp
   477 0000026F 07                          pop es
   478 00000270 1F                          pop ds
   479 00000271 B01A                        mov al, 0x1A
   480 00000273 CF                          iret
   481                                  
   482                                  ; ============================================================
   483                                  ; scroll_up_one — scroll VGA text up by one line
   484                                  ; ============================================================
   485                                  scroll_up_one:
   486 00000274 1E                          push ds
   487 00000275 56                          push si
   488 00000276 57                          push di
   489 00000277 51                          push cx
   490 00000278 50                          push ax
   491 00000279 B800B8                      mov ax, VGA_SEG
   492 0000027C 8ED8                        mov ds, ax
   493 0000027E BEA000                      mov si, 160            ; source = row 1
   494 00000281 31FF                        xor di, di             ; dest = row 0
   495 00000283 B98007                      mov cx, 1920           ; 24 rows * 80 cols
   496                                  .scopy:
   497 00000286 8B04                        mov ax, [si]
   498 00000288 8905                        mov [di], ax
   499 0000028A 83C602                      add si, 2
   500 0000028D 83C702                      add di, 2
   501 00000290 49                          dec cx
   502 00000291 75F3                        jnz .scopy
   503 00000293 B95000                      mov cx, 80
   504 00000296 B82007                      mov ax, 0x0720
   505                                  .sclear:
   506 00000299 8905                        mov [di], ax
   507 0000029B 83C702                      add di, 2
   508 0000029E 49                          dec cx
   509 0000029F 75F8                        jnz .sclear
   510 000002A1 58                          pop ax
   511 000002A2 59                          pop cx
   512 000002A3 5F                          pop di
   513 000002A4 5E                          pop si
   514 000002A5 1F                          pop ds
   515 000002A6 C3                          ret
   516                                  
   517                                  ; ============================================================
   518                                  ; INT 11h — Equipment List (read from BDA, like reference BIOS)
   519                                  ; ============================================================
   520                                  int11h_handler:
   521 000002A7 FB                          sti
   522 000002A8 1E                          push ds
   523 000002A9 B84000                      mov ax, BDA_SEG
   524 000002AC 8ED8                        mov ds, ax
   525 000002AE A11000                      mov ax, [equipment_list]
   526 000002B1 1F                          pop ds
   527 000002B2 CF                          iret
   528                                  
   529                                  ; ============================================================
   530                                  ; INT 12h — Memory Size (read from BDA, like reference BIOS)
   531                                  ; ============================================================
   532                                  int12h_handler:
   533 000002B3 FB                          sti
   534 000002B4 1E                          push ds
   535 000002B5 B84000                      mov ax, BDA_SEG
   536 000002B8 8ED8                        mov ds, ax
   537 000002BA A11300                      mov ax, [memory_size]
   538 000002BD 1F                          pop ds
   539 000002BE CF                          iret
   540                                  
   541                                  ; ============================================================
   542                                  ; INT 13h — Disk Services (memory-resident disk image)
   543                                  ; ============================================================
   544                                  int13h_handler:
   545 000002BF 80FC00                      cmp ah, 0x00
   546 000002C2 7413                        je .disk_reset
   547 000002C4 80FC02                      cmp ah, 0x02
   548 000002C7 742E                        je .disk_read
   549 000002C9 80FC08                      cmp ah, 0x08
   550 000002CC 740D                        je .disk_params
   551 000002CE 80FC15                      cmp ah, 0x15
   552 000002D1 7420                        je .disk_type
   553                                      ; Unknown function — return error
   554 000002D3 B401                        mov ah, 0x01           ; invalid function
   555 000002D5 F9                          stc
   556 000002D6 CF                          iret
   557                                  
   558                                  .disk_reset:
   559 000002D7 30E4                        xor ah, ah
   560 000002D9 F8                          clc
   561 000002DA CF                          iret
   562                                  
   563                                  .disk_params:
   564                                      ; Return drive parameters for 1.44MB floppy
   565 000002DB B400                        mov ah, 0
   566 000002DD B304                        mov bl, 0x04           ; drive type: 1.44MB
   567 000002DF B54F                        mov ch, DISK_CYLS - 1  ; max cylinder (79)
   568 000002E1 B112                        mov cl, DISK_SPT       ; max sector (18)
   569 000002E3 B601                        mov dh, DISK_HEADS - 1 ; max head (1)
   570 000002E5 B201                        mov dl, 1              ; 1 floppy drive
   571                                      ; ES:DI = disk parameter table
   572 000002E7 53                          push bx
   573 000002E8 BB00F0                      mov bx, BIOS_SEG
   574 000002EB 8EC3                        mov es, bx
   575 000002ED BF[D606]                    mov di, disk_param_table
   576 000002F0 5B                          pop bx
   577 000002F1 F8                          clc
   578 000002F2 CF                          iret
   579                                  
   580                                  .disk_type:
   581                                      ; AH=15h: Get disk type — floppy without change detection
   582 000002F3 B401                        mov ah, 0x01
   583 000002F5 F8                          clc
   584 000002F6 CF                          iret
   585                                  
   586                                  .disk_read:
   587                                      ; AH=02h: Read sectors
   588                                      ; AL=count, CH=cylinder, CL=sector(1-based), DH=head, DL=drive, ES:BX=dest
   589 000002F7 55                          push bp
   590 000002F8 89E5                        mov bp, sp
   591 000002FA 1E                          push ds
   592 000002FB 56                          push si
   593 000002FC 57                          push di
   594 000002FD 50                          push ax
   595 000002FE 52                          push dx
   596 000002FF 51                          push cx
   597                                  
   598                                      ; Reload from stack since we need all values
   599 00000300 59                          pop cx
   600 00000301 5A                          pop dx
   601 00000302 52                          push dx
   602 00000303 51                          push cx
   603                                  
   604                                      ; Compute LBA = (CH * 2 + DH) * 18 + (CL - 1)
   605 00000304 88E8                        mov al, ch
   606 00000306 30E4                        xor ah, ah
   607 00000308 D1E0                        shl ax, 1              ; AX = cyl * 2
   608 0000030A 89C6                        mov si, ax
   609 0000030C 30E4                        xor ah, ah
   610 0000030E 88F0                        mov al, dh
   611 00000310 01F0                        add ax, si             ; AX = cyl*2 + head
   612 00000312 BE1200                      mov si, DISK_SPT
   613 00000315 52                          push dx
   614 00000316 F7E6                        mul si                 ; AX = (cyl*2+head) * 18
   615 00000318 5A                          pop dx
   616 00000319 89C6                        mov si, ax
   617 0000031B 30ED                        xor ch, ch
   618 0000031D FEC9                        dec cl                 ; sector is 1-based
   619 0000031F 01CE                        add si, cx             ; SI = LBA
   620                                  
   621                                      ; Source segment = DISK_SEG + LBA * 32
   622 00000321 89F0                        mov ax, si
   623 00000323 B105                        mov cl, 5
   624 00000325 D3E0                        shl ax, cl
   625 00000327 0500D0                      add ax, DISK_SEG
   626 0000032A 8ED8                        mov ds, ax
   627 0000032C 31F6                        xor si, si
   628                                  
   629                                      ; Destination = ES:BX
   630 0000032E 89DF                        mov di, bx
   631                                  
   632                                      ; Count
   633 00000330 59                          pop cx
   634 00000331 5A                          pop dx
   635 00000332 58                          pop ax
   636 00000333 30E4                        xor ah, ah
   637 00000335 89C1                        mov cx, ax
   638 00000337 51                          push cx
   639                                  
   640                                      ; Copy CX sectors * 512 bytes
   641                                  .read_sector_loop:
   642 00000338 51                          push cx
   643 00000339 B90001                      mov cx, 256
   644                                  .read_word_loop:
   645 0000033C 8B04                        mov ax, [si]
   646 0000033E 1E                          push ds
   647 0000033F 53                          push bx
   648 00000340 8CC3                        mov bx, es
   649 00000342 8EDB                        mov ds, bx
   650 00000344 8905                        mov [di], ax
   651 00000346 5B                          pop bx
   652 00000347 1F                          pop ds
   653 00000348 83C602                      add si, 2
   654 0000034B 83C702                      add di, 2
   655 0000034E 49                          dec cx
   656 0000034F 75EB                        jnz .read_word_loop
   657 00000351 59                          pop cx
   658 00000352 49                          dec cx
   659 00000353 75E3                        jnz .read_sector_loop
   660                                  
   661                                      ; Success
   662 00000355 58                          pop ax                 ; AL = sectors read
   663 00000356 30E4                        xor ah, ah
   664 00000358 F8                          clc
   665 00000359 5F                          pop di
   666 0000035A 5E                          pop si
   667 0000035B 1F                          pop ds
   668 0000035C 5D                          pop bp
   669 0000035D CF                          iret
   670                                  
   671                                  ; ============================================================
   672                                  ; INT 16h — Keyboard Services (matches reference BIOS contracts)
   673                                  ; ============================================================
   674                                  int16h_handler:
   675 0000035E FB                          sti
   676 0000035F 53                          push bx
   677 00000360 1E                          push ds
   678 00000361 BB4000                      mov bx, BDA_SEG
   679 00000364 8EDB                        mov ds, bx
   680 00000366 80FC00                      cmp ah, 0x00
   681 00000369 741C                        je .read_key
   682 0000036B 80FC01                      cmp ah, 0x01
   683 0000036E 742F                        je .check_key
   684 00000370 80FC02                      cmp ah, 0x02
   685 00000373 744A                        je .shift_flags
   686 00000375 80FC10                      cmp ah, 0x10
   687 00000378 740D                        je .read_key           ; enhanced = same for us
   688 0000037A 80FC11                      cmp ah, 0x11
   689 0000037D 7420                        je .check_key          ; enhanced = same for us
   690 0000037F 80FC12                      cmp ah, 0x12
   691 00000382 7441                        je .ext_shift_flags
   692                                      ; Unknown function
   693 00000384 1F                          pop ds
   694 00000385 5B                          pop bx
   695 00000386 CF                          iret
   696                                  
   697                                  .read_key:
   698                                      ; Busy-wait on keyboard buffer at 0000:0500
   699 00000387 1F                          pop ds
   700 00000388 5B                          pop bx
   701 00000389 1E                          push ds
   702 0000038A 53                          push bx
   703 0000038B 31DB                        xor bx, bx
   704 0000038D 8EDB                        mov ds, bx
   705                                  .key_wait:
   706 0000038F A10005                      mov ax, [0x0500]
   707 00000392 85C0                        test ax, ax
   708 00000394 74F9                        jz .key_wait
   709 00000396 C70600050000                mov word [0x0500], 0
   710 0000039C 5B                          pop bx
   711 0000039D 1F                          pop ds
   712 0000039E CF                          iret
   713                                  
   714                                  .check_key:
   715                                      ; Check if key is available (non-destructive)
   716 0000039F 1F                          pop ds
   717 000003A0 5B                          pop bx
   718 000003A1 1E                          push ds
   719 000003A2 53                          push bx
   720 000003A3 31DB                        xor bx, bx
   721 000003A5 8EDB                        mov ds, bx
   722 000003A7 A10005                      mov ax, [0x0500]
   723 000003AA 5B                          pop bx
   724 000003AB 1F                          pop ds
   725 000003AC 85C0                        test ax, ax
   726 000003AE 55                          push bp
   727 000003AF 89E5                        mov bp, sp
   728 000003B1 7406                        jz .ck_none
   729                                      ; Key available: clear ZF
   730 000003B3 836606BF                    and word [bp+6], 0xFFBF
   731 000003B7 EB04                        jmp short .ck_ret
   732                                  .ck_none:
   733                                      ; No key: set ZF
   734 000003B9 834E0640                    or word [bp+6], 0x0040
   735                                  .ck_ret:
   736 000003BD 5D                          pop bp
   737 000003BE CF                          iret
   738                                  
   739                                  .shift_flags:
   740                                      ; AH=02h: Return shift flags from BDA
   741 000003BF A01700                      mov al, [kbd_flags_1]
   742 000003C2 1F                          pop ds
   743 000003C3 5B                          pop bx
   744 000003C4 CF                          iret
   745                                  
   746                                  .ext_shift_flags:
   747                                      ; AH=12h: Return extended shift flags
   748 000003C5 A01700                      mov al, [kbd_flags_1]
   749 000003C8 8A261800                    mov ah, [kbd_flags_2]
   750 000003CC 1F                          pop ds
   751 000003CD 5B                          pop bx
   752 000003CE CF                          iret
   753                                  
   754                                  ; ============================================================
   755                                  ; INT 1Ah — Timer Services (matches reference BIOS contract)
   756                                  ; ============================================================
   757                                  int1ah_handler:
   758 000003CF FB                          sti
   759 000003D0 53                          push bx
   760 000003D1 1E                          push ds
   761 000003D2 BB4000                      mov bx, BDA_SEG
   762 000003D5 8EDB                        mov ds, bx
   763 000003D7 80FC00                      cmp ah, 0x00
   764 000003DA 7408                        je .timer_read
   765 000003DC 80FC01                      cmp ah, 0x01
   766 000003DF 741F                        je .timer_set
   767                                      ; Unknown function
   768 000003E1 1F                          pop ds
   769 000003E2 5B                          pop bx
   770 000003E3 CF                          iret
   771                                  
   772                                  .timer_read:
   773                                      ; AH=00h: Read tick count
   774                                      ; Returns: CX=high, DX=low, AL=midnight flag
   775                                      ; Reference: reads ticks, clears midnight flag via XOR
   776 000003E4 8B166C00                    mov dx, [ticks_lo]
   777 000003E8 8B0E6E00                    mov cx, [ticks_hi]
   778 000003EC A07000                      mov al, [new_day]
   779 000003EF 30067000                    xor byte [new_day], al  ; clear midnight flag (reference method)
   780                                      ; Auto-increment workaround since we have no timer IRQ
   781 000003F3 83066C0001                  add word [ticks_lo], 1
   782 000003F8 83166E0000                  adc word [ticks_hi], 0
   783 000003FD 1F                          pop ds
   784 000003FE 5B                          pop bx
   785 000003FF CF                          iret
   786                                  
   787                                  .timer_set:
   788                                      ; AH=01h: Set tick count
   789 00000400 89166C00                    mov [ticks_lo], dx
   790 00000404 890E6E00                    mov [ticks_hi], cx
   791 00000408 C606700000                  mov byte [new_day], 0
   792 0000040D 1F                          pop ds
   793 0000040E 5B                          pop bx
   794 0000040F CF                          iret
   795                                  
   796                                  ; ============================================================
   797                                  ; INT 08h — Timer Tick (IRQ0)
   798                                  ; Increments BDA tick count, checks for midnight, calls INT 1Ch.
   799                                  ; We don't have a real PIT, so this won't fire automatically,
   800                                  ; but having the handler means any code that triggers INT 08h
   801                                  ; will work correctly.
   802                                  ; ============================================================
   803                                  int08h_handler:
   804 00000410 50                          push ax
   805 00000411 52                          push dx
   806 00000412 1E                          push ds
   807 00000413 B84000                      mov ax, BDA_SEG
   808 00000416 8ED8                        mov ds, ax
   809                                      ; Increment tick counter
   810 00000418 FF066C00                    inc word [ticks_lo]
   811 0000041C 7504                        jnz .no_overflow
   812 0000041E FF066E00                    inc word [ticks_hi]
   813                                  .no_overflow:
   814                                      ; Check for midnight rollover (1573042 = 0x18:0x00B2 ticks/day)
   815 00000422 833E6E0018                  cmp word [ticks_hi], 0x18
   816 00000427 7519                        jnz .no_midnight
   817 00000429 813E6C00B200                cmp word [ticks_lo], 0x00B2
   818 0000042F 7511                        jnz .no_midnight
   819 00000431 C7066E000000                mov word [ticks_hi], 0
   820 00000437 C7066C000000                mov word [ticks_lo], 0
   821 0000043D C606700001                  mov byte [new_day], 1
   822                                  .no_midnight:
   823 00000442 CD1C                        int 0x1C               ; User timer tick hook
   824 00000444 1F                          pop ds
   825 00000445 5A                          pop dx
   826 00000446 58                          pop ax
   827 00000447 CF                          iret
   828                                  
   829                                  ; ============================================================
   830                                  ; INT 15h — Miscellaneous System Services (matches reference)
   831                                  ; ============================================================
   832                                  int15h_handler:
   833 00000448 FB                          sti
   834 00000449 80FC4F                      cmp ah, 0x4F
   835 0000044C 741F                        je .kbd_intercept
   836 0000044E 80FCC0                      cmp ah, 0xC0
   837 00000451 7429                        je .sys_config
   838 00000453 80FC88                      cmp ah, 0x88
   839 00000456 7419                        je .ext_mem_size
   840                                      ; AH=90h/91h: OS hooks — return success
   841 00000458 80FC90                      cmp ah, 0x90
   842 0000045B 7411                        je .os_hook
   843 0000045D 80FC91                      cmp ah, 0x91
   844 00000460 740C                        je .os_hook
   845                                      ; Unknown function — CF set, AH=86h (like reference)
   846 00000462 B486                        mov ah, 0x86
   847 00000464 55                          push bp
   848 00000465 89E5                        mov bp, sp
   849 00000467 804E0601                    or byte [bp+6], 0x01   ; set CF in stacked FLAGS
   850 0000046B 5D                          pop bp
   851 0000046C CF                          iret
   852                                  
   853                                  .kbd_intercept:
   854                                      ; AH=4Fh: Keyboard intercept — just IRET (pass through)
   855 0000046D CF                          iret
   856                                  
   857                                  .os_hook:
   858                                      ; AH=90h/91h: Device busy/interrupt complete — AH=0, IRET
   859 0000046E B400                        mov ah, 0x00
   860 00000470 CF                          iret
   861                                  
   862                                  .ext_mem_size:
   863                                      ; AH=88h: Extended memory size (above 1MB) — none
   864 00000471 31C0                        xor ax, ax
   865 00000473 55                          push bp
   866 00000474 89E5                        mov bp, sp
   867 00000476 806606FE                    and byte [bp+6], 0xFE  ; clear CF
   868 0000047A 5D                          pop bp
   869 0000047B CF                          iret
   870                                  
   871                                  .sys_config:
   872                                      ; AH=C0h: Get system configuration table
   873 0000047C B400                        mov ah, 0x00
   874 0000047E BB00F0                      mov bx, BIOS_SEG
   875 00000481 8EC3                        mov es, bx
   876 00000483 BB[CC06]                    mov bx, config_table
   877 00000486 55                          push bp
   878 00000487 89E5                        mov bp, sp
   879 00000489 806606FE                    and byte [bp+6], 0xFE  ; clear CF
   880 0000048D 5D                          pop bp
   881 0000048E CF                          iret
   882                                  
   883                                  ; ============================================================
   884                                  ; INT 19h — Bootstrap (halt in our system)
   885                                  ; ============================================================
   886                                  int19h_handler:
   887 0000048F 1E                          push ds
   888 00000490 31C0                        xor ax, ax
   889 00000492 8ED8                        mov ds, ax
   890 00000494 C606040501                  mov byte [HALT_ADDR], 1
   891 00000499 1F                          pop ds
   892 0000049A EBF3                        jmp int19h_handler
   893                                  
   894                                  ; ============================================================
   895                                  ; INT 20h — Program Terminate (halt)
   896                                  ; ============================================================
   897                                  int20h_handler:
   898 0000049C 1E                          push ds
   899 0000049D 31C0                        xor ax, ax
   900 0000049F 8ED8                        mov ds, ax
   901 000004A1 C606040501                  mov byte [HALT_ADDR], 1
   902 000004A6 1F                          pop ds
   903 000004A7 EBF3                        jmp int20h_handler
   904                                  
   905                                  ; ============================================================
   906                                  ; INT 01h — Single-step trap handler
   907                                  ; Clears TF from stacked FLAGS so execution resumes normally.
   908                                  ; ============================================================
   909                                  int01h_handler:
   910 000004A9 55                          push bp
   911 000004AA 89E5                        mov bp, sp
   912 000004AC 816606FFFE                  and word [bp+6], 0xFEFF    ; clear TF (bit 8) in stacked FLAGS
   913 000004B1 5D                          pop bp
   914 000004B2 CF                          iret
   915                                  
   916                                  ; ============================================================
   917                                  ; int_dummy — Dummy interrupt handler (IRET only)
   918                                  ; Matches reference BIOS int_dummy at FF53h.
   919                                  ; ============================================================
   920                                  int_dummy:
   921 000004B3 CF                          iret
   922                                  
   923                                  ; ============================================================
   924                                  ; default_handler — For unimplemented INTs
   925                                  ; Returns with CF set to signal "not supported".
   926                                  ; ============================================================
   927                                  default_handler:
   928 000004B4 55                          push bp
   929 000004B5 89E5                        mov bp, sp
   930 000004B7 834E0601                    or word [bp+6], 0x0001     ; set CF in stacked FLAGS
   931 000004BB 5D                          pop bp
   932 000004BC CF                          iret
   933                                  
   934                                  ; ============================================================
   935                                  ; Interrupt vector table — offsets only (segment always F000h)
   936                                  ; Matches reference 8088_bios interrupt_table layout exactly.
   937                                  ; 32 entries: INT 00h through INT 1Fh.
   938                                  ; ============================================================
   939                                  interrupt_table:
   940 000004BD [B304]                      dw int_dummy            ; INT 00 - Divide by zero
   941 000004BF [A904]                      dw int01h_handler       ; INT 01 - Single step (clears TF)
   942 000004C1 [B304]                      dw int_dummy            ; INT 02 - NMI (no-op for us)
   943 000004C3 [B304]                      dw int_dummy            ; INT 03 - Breakpoint
   944 000004C5 [B304]                      dw int_dummy            ; INT 04 - Overflow (INTO)
   945 000004C7 [B304]                      dw int_dummy            ; INT 05 - Print Screen (stub)
   946 000004C9 [B304]                      dw int_dummy            ; INT 06 - Invalid opcode
   947 000004CB [B304]                      dw int_dummy            ; INT 07 - Coprocessor N/A
   948 000004CD [1004]                      dw int08h_handler       ; INT 08 - IRQ0 Timer
   949 000004CF [B304]                      dw int_dummy            ; INT 09 - IRQ1 Keyboard (no hw kbd)
   950 000004D1 [B304]                      dw int_dummy            ; INT 0A - IRQ2
   951 000004D3 [B304]                      dw int_dummy            ; INT 0B - IRQ3
   952 000004D5 [B304]                      dw int_dummy            ; INT 0C - IRQ4
   953 000004D7 [B304]                      dw int_dummy            ; INT 0D - IRQ5
   954 000004D9 [B304]                      dw int_dummy            ; INT 0E - IRQ6 Floppy
   955 000004DB [B304]                      dw int_dummy            ; INT 0F - IRQ7
   956 000004DD [0000]                      dw int10h_handler       ; INT 10 - Video Services
   957 000004DF [A702]                      dw int11h_handler       ; INT 11 - Equipment List
   958 000004E1 [B302]                      dw int12h_handler       ; INT 12 - Memory Size
   959 000004E3 [BF02]                      dw int13h_handler       ; INT 13 - Disk Services
   960 000004E5 [B404]                      dw default_handler      ; INT 14 - Serial (stub)
   961 000004E7 [4804]                      dw int15h_handler       ; INT 15 - Misc System Services
   962 000004E9 [5E03]                      dw int16h_handler       ; INT 16 - Keyboard Services
   963 000004EB [B404]                      dw default_handler      ; INT 17 - Printer (stub)
   964 000004ED [B304]                      dw int_dummy            ; INT 18 - ROM BASIC (stub)
   965 000004EF [8F04]                      dw int19h_handler       ; INT 19 - Bootstrap
   966 000004F1 [CF03]                      dw int1ah_handler       ; INT 1A - Timer Services
   967 000004F3 [B304]                      dw int_dummy            ; INT 1B - Keyboard Break
   968 000004F5 [B304]                      dw int_dummy            ; INT 1C - User Timer Tick (IRET hook)
   969 000004F7 [B304]                      dw int_dummy            ; INT 1D - Video Parameters (stub)
   970 000004F9 [D606]                      dw disk_param_table     ; INT 1E - Floppy Parameters (data ptr)
   971 000004FB [B304]                      dw int_dummy            ; INT 1F - Font (stub)
   972                                  
   973                                  ; ============================================================
   974                                  ; BIOS Init — POST entry point
   975                                  ; Sets up IVT from interrupt_table, initializes BDA, boots DOS.
   976                                  ; ============================================================
   977                                  bios_init:
   978 000004FD FA                          cli
   979 000004FE FC                          cld
   980                                  
   981                                      ; Set up stack at 0030:0100 (reference uses upper IVT area)
   982                                      ; This is 0x0400 linear, well below kernel at 0x600.
   983 000004FF B83000                      mov ax, 0x0030
   984 00000502 8ED0                        mov ss, ax
   985 00000504 BC0001                      mov sp, 0x0100
   986                                  
   987                                      ; --- Initialize interrupt table ---
   988                                      ; Copy 32 vectors from interrupt_table (like reference BIOS).
   989                                      ; Reference uses movsw+stosw with DS=CS, ES=0. We can't use
   990                                      ; string ops easily, so we use a manual loop.
   991                                      ; First, set DS=0 for IVT writes.
   992 00000507 31C0                        xor ax, ax
   993 00000509 8ED8                        mov ds, ax
   994                                  
   995                                      ; Fill ALL 256 IVT entries with int_dummy:F000 first
   996                                      ; (like reference fills remaining with int_dummy after the table)
   997 0000050B 31FF                        xor di, di
   998 0000050D B90001                      mov cx, 256
   999 00000510 B800F0                      mov ax, BIOS_SEG
  1000                                  .fill_all:
  1001 00000513 C705[B304]                  mov word [di], int_dummy
  1002 00000517 894502                      mov word [di+2], ax        ; segment = F000h
  1003 0000051A 83C704                      add di, 4
  1004 0000051D 49                          dec cx
  1005 0000051E 75F3                        jnz .fill_all
  1006                                  
  1007                                      ; Now overwrite INT 00-1F from the interrupt_table
  1008                                      ; We need to read from CS:interrupt_table. Set up BX as table pointer
  1009                                      ; and use DS=CS temporarily to read, then DS=0 to write.
  1010 00000520 BE[BD04]                    mov si, interrupt_table
  1011 00000523 31FF                        xor di, di             ; IVT offset 0
  1012 00000525 B92000                      mov cx, 32
  1013                                  .ivt_copy:
  1014                                      ; Read offset from CS:SI
  1015 00000528 1E                          push ds
  1016 00000529 0E                          push cs
  1017 0000052A 1F                          pop ds
  1018 0000052B 8B1C                        mov bx, [si]           ; BX = handler offset from table
  1019 0000052D 1F                          pop ds                 ; DS = 0 again
  1020                                      ; Write to IVT
  1021 0000052E 891D                        mov [di], bx           ; offset
  1022 00000530 C7450200F0                  mov word [di+2], BIOS_SEG  ; segment
  1023 00000535 83C602                      add si, 2
  1024 00000538 83C704                      add di, 4
  1025 0000053B 49                          dec cx
  1026 0000053C 75EA                        jnz .ivt_copy
  1027                                  
  1028                                      ; Overwrite INT 20h with int20h_handler
  1029 0000053E C7068000[9C04]              mov word [0x20*4], int20h_handler
  1030 00000544 C706820000F0                mov word [0x20*4+2], BIOS_SEG
  1031                                  
  1032                                      ; INT 21h: default_handler (kernel installs its own)
  1033 0000054A C7068400[B404]              mov word [0x21*4], default_handler
  1034 00000550 C706860000F0                mov word [0x21*4+2], BIOS_SEG
  1035                                  
  1036                                      ; --- Initialize BDA ---
  1037                                      ; (Reference: kbd_buffer_init + individual field setup)
  1038 00000556 B84000                      mov ax, BDA_SEG
  1039 00000559 8ED8                        mov ds, ax
  1040                                  
  1041                                      ; Equipment list: floppy present + 80x25 color = 0x0021
  1042 0000055B C70610002100                mov word [equipment_list], 0x0021
  1043                                  
  1044                                      ; Memory size: 640 KiB
  1045 00000561 C70613008002                mov word [memory_size], 640
  1046                                  
  1047                                      ; Keyboard buffer initialization (matches kbd_buffer_init)
  1048 00000567 C7061A001E00                mov word [kbd_buffer_head], kbd_buffer   ; 0x001E
  1049 0000056D C7061C001E00                mov word [kbd_buffer_tail], kbd_buffer   ; 0x001E (empty)
  1050 00000573 C70680001E00                mov word [kbd_buffer_start], kbd_buffer  ; 0x001E
  1051 00000579 B81E00                      mov ax, kbd_buffer
  1052 0000057C 83C020                      add ax, 0x20                             ; buffer size = 32 bytes
  1053 0000057F A38200                      mov word [kbd_buffer_end], ax            ; 0x003E
  1054                                  
  1055                                      ; Clear keyboard flags
  1056 00000582 C70617000000                mov word [kbd_flags_1], 0       ; flags 1 + flags 2
  1057 00000588 C606190000                  mov byte [kbd_alt_keypad], 0
  1058                                  
  1059                                      ; Video mode and parameters
  1060 0000058D C606490003                  mov byte [video_mode], 0x03             ; mode 3 = 80x25 text
  1061 00000592 C7064A005000                mov word [video_columns], 80            ; 80 columns
  1062 00000598 C7064C000010                mov word [video_page_size], 0x1000      ; 4096 bytes per page
  1063 0000059E C7064E000000                mov word [video_page_offt], 0x0000      ; page 0 offset
  1064 000005A4 C70650000000                mov word [video_cur_pos], 0x0000        ; cursor at (0,0)
  1065 000005AA C70652000000                mov word [video_cur_pos+2], 0x0000      ; page 1 cursor
  1066 000005B0 C70654000000                mov word [video_cur_pos+4], 0x0000      ; page 2 cursor
  1067 000005B6 C70656000000                mov word [video_cur_pos+6], 0x0000      ; page 3 cursor
  1068 000005BC C70660000706                mov word [video_cur_shape], 0x0607      ; cursor shape start=6 end=7
  1069 000005C2 C606620000                  mov byte [video_page], 0x00             ; active page 0
  1070 000005C7 C7066300D403                mov word [video_port], 0x03D4           ; CRT controller port (color)
  1071 000005CD C606840018                  mov byte [video_rows], 24               ; rows minus 1
  1072 000005D2 C70685001000                mov word [video_char_height], 16        ; character height
  1073                                  
  1074                                      ; Timer ticks (start at zero)
  1075 000005D8 C7066C000000                mov word [ticks_lo], 0
  1076 000005DE C7066E000000                mov word [ticks_hi], 0
  1077 000005E4 C606700000                  mov byte [new_day], 0
  1078                                  
  1079                                      ; Floppy state
  1080 000005E9 C6063E0000                  mov byte [fdc_calib_state], 0
  1081 000005EE C6063F0000                  mov byte [fdc_motor_state], 0
  1082 000005F3 C606400000                  mov byte [fdc_motor_tout], 0
  1083 000005F8 C606410000                  mov byte [fdc_last_error], 0
  1084                                  
  1085                                      ; Clear warm boot flag
