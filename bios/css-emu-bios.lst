  1151 0000065A 1F                          pop ds
  1152 0000065B 8A04                        mov al, [si]
  1153 0000065D 8EDB                        mov ds, bx             ; restore DS = VGA segment
  1154 0000065F 84C0                        test al, al
  1155 00000661 740B                        jz .wss_done
  1156 00000663 8805                        mov [di], al
  1157 00000665 886501                      mov [di+1], ah
  1158 00000668 83C702                      add di, 2
  1159 0000066B 46                          inc si
  1160 0000066C EBEB                        jmp short .wss_loop
  1161                                  .wss_done:
  1162 0000066E 5B                          pop bx
  1163 0000066F C3                          ret
  1164                                  
