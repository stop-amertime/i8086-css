# Builder output — cabinets land here by default (see builder/build.mjs).
out/
output/

# Cabinets at repo root and their sidecars — built ad-hoc, ephemeral.
# The bench harness uses tests/bench/cache/ for its own cabinets.
/*.css
/*.meta.json
/*.disk.bin
/*.kernel.bin
/*.bios.bin

# Bench harness cabinet cache (ephemeral; ensureFresh manages it).
tests/bench/cache/

# Old benchmark harness artifacts — bench/ is being deleted.
bench/build/

# Scratch builds used during testing — any top-level file starting with tmp-.
tmp-*
tmp/

# Cabinets/HTML generated by ad-hoc runs into tests/ (conformance fixtures
# live in tests/ as .com/.asm; .css/.html under tests/ are always build output).
tests/*.css
tests/*.html

# Compiled binaries and listings
*.bin
*.lst
*.start
*.o
!bios/gossamer/gossamer.bin
!bios/gossamer/gossamer.lst
!bios/corduroy/cga-8x8.bin
!bios/corduroy/vga-dac.bin
!player/fonts/vga-8x16.bin

# Build outputs
bios/corduroy/build/
bios/corduroy/bios.map

# Node
node_modules/
dist/

# Python
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
.serena/
*.swp
*.swo

# Playwright debug artifacts
.playwright-mcp/

# Trace / conformance artifacts (JSON dumps from ref emulators, etc.)
ref-trace.json
*-trace.json
trace-*.json

# Claude/editor state
.claude/

# Disk images and archives
*.img
*.zip

# Builder cache
.cache/

# Ephemeral planning artifacts from superpowers workflow
docs/superpowers/
entry.err
