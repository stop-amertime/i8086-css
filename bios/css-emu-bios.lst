  1142                                  ; --- Write null-terminated string to VGA at DS:DI ---
  1143                                  ; AH = attribute byte (preserved). DS=VGA_SEG on entry.
  1144                                  ; SI points into BIOS ROM (CS segment). Swaps DS to read.
  1145                                  .write_splash_str:
